@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fdo: <http://www.fairnessdata.dei.unipd.it/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

fdo:2010FrequentlyOccurringSurnames a dcat:Dataset ;
    dcterms:creator "US Census Bureau"^^xsd:string ;
    dcterms:description "this dataset reports all surnames occurring 100 or more times in the 2010 US Census, broken down by race (White, Black, Asian and Pacific Islander (API), American Indian and Alaskan Native only (AIAN), multiracial, or Hispanic)" ;
    dcterms:isReferencedBy "\\url{https://www2.census.gov/topics/genealogy/2010surnames/surnames.pdf}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "US Census Bureau"^^xsd:string ;
    dcterms:title "2010 Frequently Occurring Surnames" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "200K surnames" ;
    fdo:sensitiveFeature "race" ;
    fdo:task fdo:29 ;
    dcat:landingPage "https://www.census.gov/topics/population/genealogy/data/2010_surnames.html"^^xsd:anyURI .

fdo:2016USPresidentialPoll a dcat:Dataset ;
    dcterms:creator "FiveThirtyEight"^^xsd:string ;
    dcterms:description "this dataset was collected and maintained by FiveThirtyEight, a website specialized in opinion poll analysis. This resource was developed with the goal of providing an aggregated estimate based on multiple polls, weighting each input according to sample size, recency, and historical accuracy of the polling organization. For each poll, the dataset provides the period of data collection, its sample size, the pollster conducting it, their rating, and a url linking to the source data" ;
    dcterms:isReferencedBy "\\url{https://projects.fivethirtyeight.com/2016-election-forecast/}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "FiveThirtyEight"^^xsd:string ;
    dcterms:title "2016 US Presidential Poll" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:politicalscience ;
    fdo:sampleSize "13K poll results" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:127 ;
    dcat:landingPage "http://projects.fivethirtyeight.com/general-model/president_general_polls_2016.csv"^^xsd:anyURI .

fdo:4area a dcat:Dataset ;
    dcterms:creator "University of Illinois at Urbana-Champaign"^^xsd:string ;
    dcterms:description "this dataset was extracted from DBLP to study the problem of topic modeling on documents connected by links in a graph structure. The creators extracted from DBLP articles published at 20 major conferences from four related areas, i.e., database, data mining, machine learning, and information retrieval. Each author is associated with four continuous variables based on the fraction of research papers published in these areas. The associated task is the prediction of these attributes" ;
    dcterms:isReferencedBy "\\citet{sun2009itopic}" ;
    dcterms:issued "2009"^^xsd:gYear ;
    dcterms:modified "2009"^^xsd:gYear ;
    dcterms:publisher "University of Illinois at Urbana-Champaign"^^xsd:string ;
    dcterms:title "4area" ;
    dcterms:type "author-author pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:libraryandinformationsciences ;
    fdo:sampleSize "30K nodes (authors) connected by 200K edges (co-author relations)" ;
    fdo:sensitiveFeature "author" ;
    fdo:task fdo:187 .

fdo:ANPE a dcat:Dataset ;
    dcterms:creator "Paris School of Economics; Institute of Labor Economics; CREST; ANPE; Unédic; Direction de l’Animation de la Recherche et des Études Statistiques"^^xsd:string ;
    dcterms:description "this dataset  represents a large randomized controlled trial, assigning job seekers in France to a program run by the Public employment agency (ANPE), or to a program outsourced to private providers by the Unemployment insurance organization (Unédic). The data involves 400 public employment branches and over 200,000 job-seekers. Data about job seekers includes their demographics, their placement program and the subsequent duration of unemployment spells" ;
    dcterms:isReferencedBy "\\citet{behaghel2014private}" ;
    dcterms:issued "2012"^^xsd:gYear ;
    dcterms:modified "2012"^^xsd:gYear ;
    dcterms:publisher "Paris School of Economics; Institute of Labor Economics; CREST; ANPE; Unédic; Direction de l’Animation de la Recherche et des Études Statistiques"^^xsd:string ;
    dcterms:title "ANPE" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "200K job seekers" ;
    fdo:sensitiveFeature "age, gender, nationality" ;
    fdo:task fdo:92 ;
    dcat:landingPage "https://www.openicpsr.org/openicpsr/project/113904/version/V1/view?path=/openicpsr/113904/fcr:versions/V1/Archive&type=folder"^^xsd:anyURI .

fdo:AcademicCollaborationNetworks a dcat:Dataset ;
    dcterms:creator "Carnegie Mellon University; Cornell University"^^xsd:string ;
    dcterms:description "these dataset represent two collaboration networks from the preprint server arXiv, covering scientific papers submitted to the astrophysics (AstroPh) and condensed matter (CondMat) physics categories. Each node in the network is an author, with links indicating co-authorship of one or more articles. Nodes are indicated with ids, hence information about the researchers in the graph is not immediately available. These datasets were developed to study the evolution of graphs over time" ;
    dcterms:isReferencedBy "\\citet{leskovec2007graph}" ;
    dcterms:issued "2009"^^xsd:gYear ;
    dcterms:modified "2009"^^xsd:gYear ;
    dcterms:publisher "Carnegie Mellon University; Cornell University"^^xsd:string ;
    dcterms:title "Academic Collaboration Networks" ;
    dcterms:type "author-author pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:libraryandinformationsciences ;
    fdo:sampleSize "19K nodes (authors) connected by 200K edges (indications of co-authorship) (AstroPh). 23K nodes connected by 93K edges (CondMat)" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:99 ;
    dcat:landingPage "http://snap.stanford.edu/data/ca-AstroPh.html"^^xsd:anyURI,
        "http://snap.stanford.edu/data/ca-CondMat.html"^^xsd:anyURI .

fdo:Adience a dcat:Dataset ;
    dcterms:creator "Adience; Open University of Israel"^^xsd:string ;
    dcterms:description "this resource was developed to favour the study of automated age and gender identification from images of faces. Photos were sourced from Flickr albums, among the ones automatically uploaded from iPhone and made available under Creative Commons license. All images were manually labeled for age, gender and identity ``using both the images themselves and any available contextual information''. These annotations are fundamental for the tasks associated with this dataset, i.e. age and gender estimation. One author of \\citet{Buolamwini2018gender} labeled each image in Adience with Fitzpatrick skin type" ;
    dcterms:isReferencedBy "\\citet{eidinger2014:age,Buolamwini2018gender}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "Adience; Open University of Israel"^^xsd:string ;
    dcterms:title "Adience" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "30K images of 2K subjects" ;
    fdo:sensitiveFeature "age, gender, skin type" ;
    fdo:task fdo:23 ;
    dcat:landingPage "https://talhassner.github.io/home/projects/Adience/Adience-data.html"^^xsd:anyURI .

fdo:Adressa a dcat:Dataset ;
    dcterms:creator "Norwegian University of Science and Technology; Adresseavisen"^^xsd:string ;
    dcterms:description "this dataset was curated as part of the RecTech project on recommendation technology owned by  Adresseavisen (shortened to Adressa) a large Norwegian newspaper. It summarizes one week of traffic to the newspaper website by both subscribers and non-subscribers, during February 2017. The dataset describes reading events, i.e. a reader accessing an article, providing access timestamps and user information inferred from their IP. Specific information about the articles is also available, including author, keywords, body, and mentioned entities. The dataset curators also worked on an extended version of the dataset (Adressa 20M), ten times larger than the one described here" ;
    dcterms:isReferencedBy "\\citep{gulla2017adressa}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Norwegian University of Science and Technology; Adresseavisen"^^xsd:string ;
    dcterms:title "Adressa" ;
    dcterms:type "user-article pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#news,informationsystems> ;
    fdo:sampleSize "3M ratings by 15M readers over 1K articles" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:184 ;
    dcat:landingPage "http://reclab.idi.ntnu.no/dataset/"^^xsd:anyURI .

fdo:Adult a dcat:Dataset ;
    dcterms:creator "Silicon Graphics Inc"^^xsd:string ;
    dcterms:description "this dataset was created as a resource to benchmark the performance of machine learning algorithms on socially relevant data. Each instance is a person who responded to the March 1994 US Current Population Survey, represented along demographic and socio-economic dimensions, with features describing their profession, education, age, sex, race, personal and financial condition. The dataset was extracted from the census database, preprocessed, and donated to UCI Machine Learning Repository in 1996 by Ronny Kohavi and Barry Becker. A binary variable encoding whether respondents' income is above \\$50,000 was chosen as the target of the prediction task associated with this resource. See Appendix \\ref{sec:adult} for extensive documentation" ;
    dcterms:isReferencedBy "\\citet{kohavi1996scaling,kohavi1994adult_uci,usdeptcomm1995current,hardt2021facing,mckenna2019:history,mckenna2019:history_drb}" ;
    dcterms:issued "1996"^^xsd:gYear ;
    dcterms:modified "1996"^^xsd:gYear ;
    dcterms:publisher "Silicon Graphics Inc"^^xsd:string ;
    dcterms:title "Adult" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "50K instances" ;
    fdo:sensitiveFeature "age, sex, race" ;
    fdo:task fdo:0 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/adult"^^xsd:anyURI .

fdo:AlleghenyChildWelfare a dcat:Dataset ;
    dcterms:creator "Allegheny County Department of Human Services; Auckland University of Technology; University of Southern California; University of Auckland; University of California"^^xsd:string ;
    dcterms:description "this dataset stems from an initiative by the Allegheny County’s Department of Human Services to develop assistive tools to support child maltreatment hotline screening decisions. Referrals received by Allegheny County via a hotline between September 2008 and April 2016 were assembled into a dataset. To obtain a relevant history and follow-up time for each referral, a subset of samples spanning the period from April 2010 to April 2014 is considered. Each data point pertains to a referral for suspected child abuse or neglect and contains a wealth of information from the integrated data management systems of Allegheny County. This data includes cross-sector administrative information for individuals associated with a report of child abuse or neglect, including data from child protective services, mental health services, drug, and alcohol services. The target to be estimated by risk models is future child harm, as measured e.g. by re-referrals, which complements the role of the screening staff who are focused on the information currently available about the referral" ;
    dcterms:isReferencedBy "\\citet{vaithianathan2017developing}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Allegheny County Department of Human Services; Auckland University of Technology; University of Southern California; University of Auckland; University of California"^^xsd:string ;
    dcterms:title "Allegheny Child Welfare" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialwork ;
    fdo:sampleSize "80K calls" ;
    fdo:sensitiveFeature "age, race, gender of child" ;
    fdo:task fdo:17 .

fdo:AmazonRecommendations a dcat:Dataset ;
    dcterms:creator "Indian Institute of Technology; Max Planck Institute for Software Systems"^^xsd:string ;
    dcterms:description "this dataset was crawled to study anti-competitive behaviour on Amazon, and the extent to which Amazon’s private label products are recommended on the platform. Considering the categories \\emph{backpack} and \\emph{battery}, where Amazon is known to have a strong private label presence, the creators gathered a set of organic and sponsored recommendations from Amazon.in, exploiting snowball sampling. Metadata for each product was also collected, including user rating, number of reviews, brand, seller" ;
    dcterms:isReferencedBy "\\citet{dash2021when}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Indian Institute of Technology; Max Planck Institute for Software Systems"^^xsd:string ;
    dcterms:title "Amazon Recommendations" ;
    dcterms:type "item-recommendation pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "1M recommendations associated with 20K items" ;
    fdo:sensitiveFeature "brand ownership" ;
    fdo:task fdo:38 .

fdo:AmazonReviews a dcat:Dataset ;
    dcterms:creator "University of California, San Diego"^^xsd:string ;
    dcterms:description "this is large-scale dataset of over ten million products and respective reviews on Amazon, spanning more than two decades. It was created to study the problem of image-based recommendation and its dynamics. Rich metadata are available for both products and reviews. Reviews consist of ratings, text, reviewer name, and review ID, while products include title, price, image, and sales rank of product" ;
    dcterms:isReferencedBy "\\citet{mcauley2015imagebased,he2016ups}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "University of California, San Diego"^^xsd:string ;
    dcterms:title "Amazon Reviews" ;
    dcterms:type "user-product pairs (reviews)"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "200M reviews of products" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:157 ;
    dcat:landingPage "https://nijianmo.github.io/amazon/index.html"^^xsd:anyURI .

fdo:AntelopeValleyNetworks a dcat:Dataset ;
    dcterms:creator "National University of Singapore; National University of Southern California"^^xsd:string ;
    dcterms:description "this a set of synthetic datasets generated to study the problem of influence maximization for obesity prevention. Samples of agents are generated to emulate the demographic and obesity distribution across regions in the Antelope Valley in California, exploiting data from the U.S. Census, the Los Angeles County Department of Public Health, and Los Angeles Times Mapping L.A. project. Each agent in the network has a geographic region, gender, ethnicity, age, and connections to other agents, which are more frequent for agents with similar attributes. Agents are also assigned a weight status, which may change based on interactions with other agents in their ego-network, emulating social learning" ;
    dcterms:isReferencedBy "\\citet{wilder2018optimizing,tsang2019group}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "National University of Singapore; National University of Southern California"^^xsd:string ;
    dcterms:title "Antelope Valley Networks" ;
    dcterms:type "agent-agent pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:publichealth ;
    fdo:sampleSize "20 synthetic networks, containing 500 individuals each" ;
    fdo:sensitiveFeature "ethnicity, gender, age, geography" ;
    fdo:task fdo:151 ;
    dcat:landingPage "https://github.com/bwilder0/fair_influmax_code_release"^^xsd:anyURI .

fdo:Apnea a dcat:Dataset ;
    dcterms:creator "Massachusetts Institute of Technology; Massachusetts General Hospital; Harvard Medical School"^^xsd:string ;
    dcterms:description "this dataset results from a sleep medicine study focused on establishing important factors for the automated diagnosis of Obstructive Sleep Apnea (OSA). The task associated with this dataset is the prediction of medical condition (OSA/no OSA) from available patient features, which include demographics, medical history, and symptoms" ;
    dcterms:isReferencedBy "\\citet{ustun2016clinical}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Massachusetts Institute of Technology; Massachusetts General Hospital; Harvard Medical School"^^xsd:string ;
    dcterms:title "Apnea" ;
    dcterms:type "mixture (time series and tabular data)"^^rdf:PlainLiteral ;
    fdo:domain fdo:sleepmedicine ;
    fdo:sampleSize "2K patients" ;
    fdo:sensitiveFeature "age, sex" ;
    fdo:task fdo:136 .

fdo:ArnetMinerCitationNetwork a dcat:Dataset ;
    dcterms:creator "Tsinghua University; IBM"^^xsd:string ;
    dcterms:description "this dataset is one of the many resources made available by the ArnetMiner online service. The ArnetMiner system was developed for the extraction and mining of data from academic social networks, with a focus on profiling of researchers. The DBLP Citation Network is extracted from academic resources, such as DBLP, ACM and MAG (Microsoft Academic Graph). The dataset captures the relationships between scientific articles and their authors in a connected graph structure. It can be used for tasks such as community discovery, topic modeling, centrality and influence analysis. In its latest versions, the dataset comprises over 20 fields, including paper title, keywords, abstract, venue, year, along with authors, and their affiliations. The ArnetMiner project was partially funded by the Chinese National High-tech R\\&D Program, the National Science Foundation of China, IBM China Research Lab, the Chinese Young Faculty Research Funding program and Minnesota China Collaborative Research Program" ;
    dcterms:isReferencedBy "\\citet{tang2008arnetminer}; \\url{https://www.aminer.org/}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Tsinghua University; IBM"^^xsd:string ;
    dcterms:title "ArnetMiner Citation Network" ;
    dcterms:type "article-article pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:libraryandinformationsciences ;
    fdo:sampleSize "5M papers connected by 50M citations" ;
    fdo:sensitiveFeature "author" ;
    fdo:task fdo:129 ;
    dcat:landingPage "http://www.arnetminer.org/citation"^^xsd:anyURI .

fdo:Arrhythmia a dcat:Dataset ;
    dcterms:creator "Bilkent University; Baskent University"^^xsd:string ;
    dcterms:description "data provenance for this set of patient records seems uncertain. The first work referencing this dataset dates to 1997 and details a machine learning approach for the diagnosis of arrhythmia, which presumably motivated its collection. Each data point describes a different patient; features include demographics, weight and height and clinical measurements from ECG signals, along with the diagnosis of a cardiologist into 16 different classes of arrhythmia (including none), which represents the target variable" ;
    dcterms:isReferencedBy "\\citet{guvenir1997supervised}" ;
    dcterms:issued "1997"^^xsd:gYear ;
    dcterms:modified "1997"^^xsd:gYear ;
    dcterms:publisher "Bilkent University; Baskent University"^^xsd:string ;
    dcterms:title "Arrhythmia" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:cardiology ;
    fdo:sampleSize "500 patients" ;
    fdo:sensitiveFeature "age, sex" ;
    fdo:task fdo:85 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/arrhythmia"^^xsd:anyURI .

fdo:Athletesandhealthprofessionals a dcat:Dataset ;
    dcterms:creator "Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:description "the datasets were developed to study the effects of bias in image classification. The health professional dataset (doctors and nurses) contains race and gender as sensitive features and the athlete dataset (basketball and volleyball players) contains gender and jersey color as sensitive features. Each subgroup, separated by combinations of sensitive features, is roughly balanced at ~200 images. The collected data was manually examined by the curators to remove stylized images and images containing both females and males" ;
    dcterms:isReferencedBy "\\citet{tong2020investigating}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:title "Athletes and health professionals" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "800 images of athletes and 500 images of health professionals" ;
    fdo:sensitiveFeature "Gender (both), race (health professionals), jersey color (athletes)" ;
    fdo:task fdo:142 ;
    dcat:landingPage "https://github.com/ghayat2/Datasets"^^xsd:anyURI .

fdo:AutomatedStudentAssessmentPrize_ASAP a dcat:Dataset ;
    dcterms:creator "University of Akron; The Common Pool; OpenEd Solutions"^^xsd:string ;
    dcterms:description "this dataset was collected to evaluate the feasibility of automated  essay scoring. It consists of a collection of essays by US students in grade levels 7--10, rated by at least two human raters. The dataset comes with a predefined training/validation/test split and powers the Hewlett Foundation Automated Essay Scoring competition on Kaggle. The curators tried to remove personally identifying information from the essays using Named Entity Recognizer (NER) and several heuristics" ;
    dcterms:isReferencedBy "\\citet{shermis2014stateoftheart}" ;
    dcterms:issued "2012"^^xsd:gYear ;
    dcterms:modified "2012"^^xsd:gYear ;
    dcterms:publisher "University of Akron; The Common Pool; OpenEd Solutions"^^xsd:string ;
    dcterms:title "Automated Student Assessment Prize (ASAP)" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "20K student essays" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:203 ;
    dcat:landingPage "https://www.kaggle.com/c/asap-aes/data/"^^xsd:anyURI .

fdo:BOLD a dcat:Dataset ;
    dcterms:creator "Amazon; University of California, Santa Barbara"^^xsd:string ;
    dcterms:description "this resource is a benchmark to measure biases of language models with respect to sensitive demographic attributes. The creators identified six attributes (e.g. race, profession) and values of said attribute (e.g. African American, flight nurse) for which they gather prompts from English Language Wikipedia, either from pages about the group (e.g. ``A flight nurse is a registered'') or people representing it (e.g. ``Over the years, Isaac Hayes was able''). Prompts are fed to different language models, whose outputs are automatically labelled for sentiment, regard, toxicity, emotion and gender polarity. These labels are also validated by human annotators hired on Amazon Mechanical Turk" ;
    dcterms:isReferencedBy "\\citet{dhamala2021bold}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Amazon; University of California, Santa Barbara"^^xsd:string ;
    dcterms:title "BOLD" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "20K prompts" ;
    fdo:sensitiveFeature "gender, race, religion, profession, political leaning" ;
    fdo:task fdo:37 ;
    dcat:landingPage "https://github.com/amazon-research/bold"^^xsd:anyURI .

fdo:BUPTFaces a dcat:Dataset ;
    dcterms:creator "Beijing University of Posts and Telecommunications"^^xsd:string ;
    dcterms:description "this resource consists of two datasets, developed as a large scale collection, suitable for training face verification algorithms operating on diverse populations. The underlying data collection procedure mirrors the one from RFW (\\autoref{sec:rfw}), including sourcing from MS-Celeb-1M and automated annotation of so-called \\emph{race} into one of four categories:  Caucasian, Indian, Asian and African. For categories where not enough images were readily available, the authors resort to the FreeBase celebrity list, downloading images of people from Google and cleaning them \"both automatically and manually\". The remaining images were obtained from MS-Celeb-1M (\\autoref{sec:msceleb}), on which the BUPT Faces datasets are heavily based" ;
    dcterms:isReferencedBy "\\citet{wang2020mitigating}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Beijing University of Posts and Telecommunications"^^xsd:string ;
    dcterms:title "BUPT Faces" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "2M images of 40K celebrities (BUPT-Globalface); 1M images of 30K celebrities (BUPT-Balancedface)" ;
    fdo:sensitiveFeature "race" ;
    fdo:task fdo:122 ;
    dcat:landingPage "http://www.whdeng.cn/RFW/Trainingdataste.html"^^xsd:anyURI .

fdo:BankMarketing a dcat:Dataset ;
    dcterms:creator "Instituto Universitário de Lisboa (ISCTE-IUL), ISTAR, Lisboa; University of Minho"^^xsd:string ;
    dcterms:description "often simply called \\emph{Bank} dataset in the fairness literature, this resource was produced to support a study of success factors in telemarketing of long-term deposits within a Portuguese bank, with data collected over the period 2008--2010. Each data point represents a telemarketing phone call and includes client-specific features (e.g. job, education), features about the marketing phone call (e.g. day of the week and duration) and meaningful environmental features (e.g. euribor). The classification target is a binary variable indicating client subscription to a term deposit" ;
    dcterms:isReferencedBy "\\citet{moro2014datadriven}" ;
    dcterms:issued "2012"^^xsd:gYear ;
    dcterms:modified "2012"^^xsd:gYear ;
    dcterms:publisher "Instituto Universitário de Lisboa (ISCTE-IUL), ISTAR, Lisboa; University of Minho"^^xsd:string ;
    dcterms:title "Bank Marketing" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:marketing ;
    fdo:sampleSize "40K phone contacts" ;
    fdo:sensitiveFeature "age" ;
    fdo:task fdo:69 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/Bank+Marketing"^^xsd:anyURI .

fdo:BarcelonaRoomRental a dcat:Dataset ;
    dcterms:creator "University Pompeu Fabra; Eurecat; Institute for Political Economy and Governance; ISI Foundation"^^xsd:string ;
    dcterms:description "this dataset summarizes the operations of a room rental platform in Barcelona over 30 months, from January 2017 through June 2019. It contains information about over $60,000$ users, divided into those seeking (seeker) and those listing (lister) a room. The data consists of lister-seeker pairs, such that a seeker is recommended for a room and lister. Recommendations are provided by a set of different recommender systems (recsys). For each pair, the data reports the rank in which each seeker was listed, the recsys providing the recommendation, and the post-recommendation interaction, if any, along with demographic information on both users. Textual indications of ``gay-friendliness'' in user profiles is treated as a sensitive feature (among others), as sexual orientation was previously found to be a discriminating factor in access to housing" ;
    dcterms:isReferencedBy "\\citet{solans2021comparing}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "University Pompeu Fabra; Eurecat; Institute for Political Economy and Governance; ISI Foundation"^^xsd:string ;
    dcterms:title "Barcelona Room Rental" ;
    dcterms:type "lister-seeker pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "4M pairs" ;
    fdo:sensitiveFeature "gender, age, spoken language, ``gay-friendliness''" ;
    fdo:task fdo:223 .

fdo:BenchmarkingAttributionMethods_BAM a dcat:Dataset ;
    dcterms:creator "Google"^^xsd:string ;
    dcterms:description """this dataset was developed to evaluate different explainability methods in computer vision. It was constructed by pasting object pixels from MS-COCO \\citep{lin2014microsoft} into scene images from MiniPlaces \\citep{zhou2018:places}. Objects are rescaled to a variable proportion between one third and one half of the scene images onto which they are pasted. Both scene images and object images belong to ten different classes, for a total of 100 possible combinations. Scene images were chosen between the ones that do not contain the objects from the ten MS-COCO classes. %This way, by artificially controlling within each image which pixels represent a given class and which pixels do not, this benchmark may help identifying incorrect explanations.
    This dataset enables users to freely control how each object is correlated with scenes, from which ground truth explanations can be formed. The creators also propose a few quantitative metrics to evaluate interpretability methods by either contrasting different inputs in the same dataset or contrasting two models with the same input""" ;
    dcterms:isReferencedBy "\\citet{yang2019benchmarking}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Google"^^xsd:string ;
    dcterms:title "Benchmarking Attribution Methods (BAM)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "100K images over 10 object classes and 10 image classes" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:139 ;
    dcat:landingPage "https://github.com/google-research-datasets/bam"^^xsd:anyURI .

fdo:BerkeleyStudents a dcat:Dataset ;
    dcterms:creator "University of California, Berkeley"^^xsd:string ;
    dcterms:description "this dataset holds anonymized student records at UC Berkeley from Spring 2012 through Fall 2019. It consistst of enrollment information on a per-semester basis for tens of thousands of students. For each enrollment, student course scores are provided, along with student demographic information, including gender, race, entry status and parental income. The dataset supports evaluations of equity in educational outcome as well as grade predictions for academic support interventions. It is maintained by the University's Enterprise Data and Analytics unit" ;
    dcterms:isReferencedBy "\\citet{jiang2021towards}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "University of California, Berkeley"^^xsd:string ;
    dcterms:title "Berkeley Students" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "2M enrollments across 80K students" ;
    fdo:sensitiveFeature "gender, race" ;
    fdo:task fdo:214 .

fdo:BiasinBios a dcat:Dataset ;
    dcterms:creator "Carnegie Mellon University; University of Massachusetts Lowell; Microsoft; LinkedIn"^^xsd:string ;
    dcterms:description "this dataset was developed as a large-scale study of gender bias in occupation classification. It consists of online biographies of professionals scraped from the Common Crawl. Biographies are detected in crawls when they match the regular expression ``$<$name$>$ is a(n) $<$title$>$'', with $<$title$>$ being one of twenty-eight common occupations. The gender of each person in the dataset is identified via the third person gendered pronoun, typically used in professional biographies. The envisioned task mirrors that of a job search automated system in a two-sided labor marketplace, i.e. automated occupation classification. The dataset curators provide python code to recreate the dataset from old Common Crawls. %which leaves names uncensored" ;
    dcterms:isReferencedBy "\\citet{dearteaga2019bias}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Carnegie Mellon University; University of Massachusetts Lowell; Microsoft; LinkedIn"^^xsd:string ;
    dcterms:title "Bias in Bios" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#linguistics,informationsystems> ;
    fdo:sampleSize "400K biographies" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:60 ;
    dcat:landingPage "https://github.com/Microsoft/biosbias"^^xsd:anyURI .

fdo:BiasinTranslationTemplates a dcat:Dataset ;
    dcterms:creator "Seoul National University"^^xsd:string ;
    dcterms:description "this resource was developed to study the problem of gender biases in machine translation. It consists of a set of short templates of the form \\texttt{One thing about the man/woman, [he/she] is [a \\#\\#]}, where \\texttt{[he/she]} can be a gender-neutral or gender-specific pronoun, and \\texttt{[a \\#\\#]} refers to a profession or conveys sentiment. Templates are built so that the part before the comma acts as a gender-specific clue, and the part after the comma contains information about gender and sentiment/profession. Accurate translations should correctly match the grammatical gender before and after the comma, in every word where it is required by the target language. The curators identify a set of languages to which this template is easily applicable, namely German, Korean, Portuguese, and Tagalog, which are chosen for their different properties with respect to grammatical gender. Depending on which language pair is being considered for translation, the curators identify a set of criteria for the evaluation of translation quality, with special emphasis on the correctness of grammatical gender" ;
    dcterms:isReferencedBy "\\citet{cho2021towards}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Seoul National University"^^xsd:string ;
    dcterms:title "Bias in Translation Templates" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "1K templates" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:40 ;
    dcat:landingPage "https://github.com/nolongerprejudice/tgbi-x"^^xsd:anyURI .

fdo:BingUSQueries a dcat:Dataset ;
    dcterms:creator "Microsoft"^^xsd:string ;
    dcterms:description "this dataset was created to investigate differential user satisfaction with the Bing search engine across different demographic groups. The authors selected log data of a random subset of Bing’s desktop and laptop users from the English-speaking US market over a two week period. The data was preprocessed by cleaning spam and bot queries, and it was enriched with user demographics, namely age (bucketed) and gender (binary), which were self-reported by users during account registration and automatically validated by the dataset curators. Moreover, queries were labeled with topic information. Finally, four different signals were extracted from search logs, namely graded utility, reformulation rate, page click count, and successful click count" ;
    dcterms:isReferencedBy "\\citet{mehrotra2017auditing}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Microsoft"^^xsd:string ;
    dcterms:title "Bing US Queries" ;
    dcterms:type "query-result pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "30M (non-unique) queries issued by 4M distinct users" ;
    fdo:sensitiveFeature "age, gender" ;
    fdo:task fdo:169 .

fdo:BookCorpus a dcat:Dataset ;
    dcterms:creator "University of Toronto; Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:description "this dataset was developed for the problem of learning general representations of text useful for different downstream tasks. It consist of text from 11,038 books from the web by unpublished authors available on \\url{https://www.smashwords.com/} in 2015. The BookCorpus contains thousands of duplicate books (only 7,185 are unique) and many contain copyright restrictions. The GPT \\citep{radford2018improving} and BERT \\citep{devlin2019BERT} language models were trained on this dataset" ;
    dcterms:isReferencedBy "\\citet{zhu2015aligning,bandy2021addressing}" ;
    dcterms:issued "unknown"^^xsd:gYear ;
    dcterms:modified "unknown"^^xsd:gYear ;
    dcterms:publisher "University of Toronto; Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:title "BookCorpus" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize " 1B words in 74M sentences from 11K books" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:88 .

fdo:Burst a dcat:Dataset ;
    dcterms:creator "Shopify"^^xsd:string ;
    dcterms:description "Burst is a free provider of stock photography powered by Shopify. This dataset features a subset of Burst images used as a resource to test algorithms for fair image retrieval and ranking, aimed at providing, in response to a query, a collection of photos that is balanced across demographics. Images come with human-curated tags annotated internally by the Burst team" ;
    dcterms:isReferencedBy "\\citet{karako2018using}; \\url{https://burst.shopify.com/}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Shopify"^^xsd:string ;
    dcterms:title "Burst" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "3K images" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:163 .

fdo:BusinessEntityResolution a dcat:Dataset ;
    dcterms:creator "Google"^^xsd:string ;
    dcterms:description "A proprietary Google dataset, where the task is to predict whether a pair of business descriptions describe the same real business" ;
    dcterms:isReferencedBy "\\citet{cotter2019training}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Google"^^xsd:string ;
    dcterms:title "Business Entity Resolution" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "15K samples" ;
    fdo:sensitiveFeature "geography, business size" ;
    fdo:task fdo:132 .

fdo:CIFAR a dcat:Dataset ;
    dcterms:creator "University of Toronto"^^xsd:string ;
    dcterms:description "CIFAR-10 and CIFAR-100 are a labelled subset of the 80 million tiny images database. CIFAR consists of 32x32 colour images that students were paid to annotate. The project, aimed at advancing the effectiveness of supervised learning techniques in computer vision, was funded by the the Canadian Institute for Advanced Research, after which the dataset is named" ;
    dcterms:isReferencedBy "\\citet{krizhevsky2009learning}" ;
    dcterms:issued "2009"^^xsd:gYear ;
    dcterms:modified "2009"^^xsd:gYear ;
    dcterms:publisher "University of Toronto"^^xsd:string ;
    dcterms:title "CIFAR" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "6K images x 10 classes (CIFAR-10) or 600 images x 100 classes (CIFAR-100)" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:22 ;
    fdo:variant "CIFAR-10S \\citep{wang2020towards} is a modified version specifically aimed at studying biases in image classification across an artificial sensitive attribute (color/grayscale)" ;
    dcat:landingPage "https://www.cs.toronto.edu/~kriz/cifar.html"^^xsd:anyURI .

fdo:COMPAS a dcat:Dataset ;
    dcterms:creator "ProPublica"^^xsd:string ;
    dcterms:description """this dataset was created for an external audit of racial biases in the Correctional Offender Management Profiling for Alternative Sanctions (COMPAS) risk assessment tool developed by Northpointe (now Equivant), which estimates the likelihood of a 
    defendant becoming a recidivist. Instances represent defendants scored by COMPAS in Broward County, Florida, between 2013--2014, reporting their demographics, criminal record, custody and COMPAS scores. Defendants' public criminal records were obtained from the Broward County Clerk’s Office website matching them based on date of birth, first and last names. The dataset was augmented with jail records and COMPAS scores provided by the Broward County Sheriff’s Office. Finally, public incarceration records were downloaded from the Florida Department of Corrections website. Instances are associated with two target variables (is\\_recid and is\\_violent\\_recid), indicating whether defendants were booked in jail for a criminal offense (potentially violent) that occurred after their COMPAS screening but within two years. See Appendix \\ref{sec:compas} for extensive documentation""" ;
    dcterms:isReferencedBy "\\citet{angwin2016machine, larson2016how}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "ProPublica"^^xsd:string ;
    dcterms:title "COMPAS" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "12K defendants" ;
    fdo:sensitiveFeature "sex, age, race" ;
    fdo:task fdo:65 ;
    dcat:landingPage "https://github.com/propublica/compas-analysis"^^xsd:anyURI .

fdo:CVsfromSingapore a dcat:Dataset ;
    dcterms:creator "University of Maryland"^^xsd:string ;
    dcterms:description "this dataset was developed to test demographic biases in resume filtering. In particular, the authors studied nationality bias in automated resume filtering in Singapore, across the three major ethnic groups of the city state: Chinese, Malaysian and Indian. The dataset consists of 135 resumes (45 per ethnic group) used for application to finance jobs in Singapore, collected by Jai Janyani. The dataset only includes resumes for which the origin of the candidates can be reliably inferred to be either Chinese, Malaysian, or Indian from education and initial employment. The dataset also comprises 9 finance job postings from China, Malaysia, and India (3 per country). All job-resume pairs are rated for relevance/suitability by three annotators" ;
    dcterms:isReferencedBy "\\citet{deshpande2020mitigating}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "University of Maryland"^^xsd:string ;
    dcterms:title "CVs from Singapore" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#informationsystems,managementinformationsystems> ;
    fdo:sampleSize "100 resumes" ;
    fdo:sensitiveFeature "ethnic group" ;
    fdo:task fdo:146 .

fdo:CampusRecruitment a dcat:Dataset ;
    dcterms:creator "Jain University Bangalore"^^xsd:string ;
    dcterms:description "this dataset was published to Kaggle in 2020 by Ben Roshan, who was then enrolled in an MBA in Business Analytics at Jain University Bangalore. The provenance of this dataset is not clear. It was provided by a Jain University professor as a class resource to study and experiment with data analysis. It encodes information about students at an Indian institution, including their degree, their performance in school and placement information at the end of school, including salary" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Jain University Bangalore"^^xsd:string ;
    dcterms:title "Campus Recruitment" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "200 students" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:217 ;
    dcat:landingPage "https://www.kaggle.com/datasets/benroshan/factors-affecting-campus-placement"^^xsd:anyURI .

fdo:Cars3D a dcat:Dataset ;
    dcterms:creator "University of Michigan"^^xsd:string ;
    dcterms:description "this dataset consists of CAD-generated models of 199 cars rendered from from 24 rotation angles. Originally devised for visual analogy making, it is also used for more general research on learning disentangled representation" ;
    dcterms:isReferencedBy "\\citet{reed2015deep}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "University of Michigan"^^xsd:string ;
    dcterms:title "Cars3D" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "5K images" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:82 ;
    dcat:landingPage "https://github.com/google-research/disentanglement_lib/tree/master/disentanglement_lib/data/ground_truth"^^xsd:anyURI .

fdo:CelebA a dcat:Dataset ;
    dcterms:creator "Chinese University of Hong Kong"^^xsd:string ;
    dcterms:description "CelebFaces Attributes Dataset (CelebA) features images of celebrities from the CelebFaces dataset, augmented with annotations of landmark location and binary attributes. The attributes, ranging from highly subjective features (e.g. attractive, big nose) and potentially offensive (e.g. double chin) to more objective ones (e.g. black hair) were annotated by a ``professional labeling company''" ;
    dcterms:isReferencedBy "\\citet{liu2015deep}" ;
    dcterms:issued "2015"^^xsd:gYear ;
    dcterms:modified "2015"^^xsd:gYear ;
    dcterms:publisher "Chinese University of Hong Kong"^^xsd:string ;
    dcterms:title "CelebA" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "200K face images of over 10K unique individuals" ;
    fdo:sensitiveFeature "gender, age, skin tone" ;
    fdo:task fdo:72 ;
    dcat:landingPage "http://mmlab.ie.cuhk.edu.hk/projects/CelebA.html"^^xsd:anyURI .

fdo:CheXpert a dcat:Dataset ;
    dcterms:creator "Stanford University"^^xsd:string ;
    dcterms:description "this dataset consists of chest X-ray images from patients that have been treated at the Stanford Hospital between October 2002 and July 2017. Each radiograph, either frontal or lateral, is annotated for the presence of 14 observations related to medical conditions. Most annotations were automatically extracted from free text radiology reports and validated against a set of 1,000 held-out reports, manually reviewed by a radiologist. For a subset of the X-ray images, high-quality labels are provided by a group of 3 radiologists. The task associated with this dataset is the automated diagnosis of medical conditions from radiographs" ;
    dcterms:isReferencedBy "\\citet{irvin2019chexpert,garbin2021structured}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Stanford University"^^xsd:string ;
    dcterms:title "CheXpert" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:radiology ;
    fdo:sampleSize "200K chest radiographs from 60K patients" ;
    fdo:sensitiveFeature "sex, age (of patient)" ;
    fdo:task fdo:25 ;
    dcat:landingPage "https://stanfordmlgroup.github.io/competitions/chexpert/"^^xsd:anyURI .

fdo:ChicagoRidesharing a dcat:Dataset ;
    dcterms:creator "City of Chicago"^^xsd:string ;
    dcterms:description "this resource describes all trips reported by ridesharing companies to the City of Chicago, starting November 2018. It is the result of an ongoing transparency effort, following the introduction of a city-wide ordinance requiring the disclosure of trips and and fares on part of transportation network providers. For each trip, this dataset reports geographical information (pickup and dropoff), duration and cost. To avoid individual re-identification, the granularity of times and locations is reduced to the nearest 15-minutes interval and census tract. Moreover, for rare combinations of census tract an interval, location data is provided at coarser granularity (community area)" ;
    dcterms:isReferencedBy "\\url{http://dev.cityofchicago.org/open\\%20data/data\\%20portal/2020/04/28/tnp-trips-2019-additional.html}; \\url{http://dev.cityofchicago.org/open\\%20data/data\\%20portal/2019/04/12/tnp-taxi-privacy.html}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "City of Chicago"^^xsd:string ;
    dcterms:title "Chicago Ridesharing" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:transportation ;
    fdo:sampleSize "200M trips" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:222 ;
    dcat:landingPage "https://data.cityofchicago.org/Transportation/Transportation-Network-Providers-Trips/m6dm-c72p"^^xsd:anyURI .

fdo:CiteSeerPapers a dcat:Dataset ;
    dcterms:creator "University of Maryland"^^xsd:string ;
    dcterms:description "this dataset was created to study the problem of link-based classification of connected entities. The creators extracted a network of papers from CiteSeer, belonging to one of six categories: Agents, Artificial Intelligence, Database, Human Computer Interaction, Machine Learning and Information Retrieval. Each article is associated with a bag-of-word representation, and the associated task is classification into one of six topics" ;
    dcterms:isReferencedBy "\\citet{lu2003:link}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "University of Maryland"^^xsd:string ;
    dcterms:title "CiteSeer Papers" ;
    dcterms:type "paper-paper pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:libraryandinformationsciences ;
    fdo:sampleSize "3K articles connected by 5K citations" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:112 ;
    dcat:landingPage "http://networkrepository.com/citeseer.php"^^xsd:anyURI .

fdo:CivilComments a dcat:Dataset ;
    dcterms:creator "Jigsaw; Civil Comments"^^xsd:string ;
    dcterms:description "this dataset derives from an archive of the Civil Comments platform, a browser plugin for independent news sites, whose users peer-reviewed each other's comments with civility ratings. When the plugin shut down, they decided to make comments and metadata available, including the crowd-sourced toxicity ratings. A subset of this dataset was later annotated with a variety of sensitive attributes, capturing whether members of a certain group are mentioned in comments. This dataset powers the Jigsaw Unintended Bias in Toxicity Classification challenge" ;
    dcterms:isReferencedBy "\\citet{borkan2019nuanced}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Jigsaw; Civil Comments"^^xsd:string ;
    dcterms:title "Civil Comments" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "2M comments" ;
    fdo:sensitiveFeature "race/ethnicity, gender, sexual orientation, religion, disability" ;
    fdo:task fdo:106 ;
    dcat:landingPage "https://www.kaggle.com/c/jigsaw-unintended-bias-in-toxicity-classification"^^xsd:anyURI .

fdo:ClimateAssemblyUK a dcat:Dataset ;
    dcterms:creator "Carnegie Mellon University; Harvard University; Sortition Foundation"^^xsd:string ;
    dcterms:description "this resource was curated to study the problem of subset selection for \\emph{sortition}, a political system where decisions are taken by a subset of the whole voting population selected at random. The data describes participants to Climate Assembly UK, a panel organized by the Sortition Foundation in 2020. With the goal of understanding public opinion on how the UK can meet greenhouse gas emission targets. The panel consisted of 110 UK residents selected from a pool of 1,715 who responded to an invitation from the Sortition Foundation reaching $\\sim60K$ citizens. Features for each subject in the pool describe their demographics and climate concern level" ;
    dcterms:isReferencedBy "\\citet{flanigan2020neutralizing}; \\url{https://www.climateassembly.uk/}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Carnegie Mellon University; Harvard University; Sortition Foundation"^^xsd:string ;
    dcterms:title "Climate Assembly UK" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:politicalscience ;
    fdo:sampleSize "2K pool participants" ;
    fdo:sensitiveFeature "gender, age, education, urban/rural, geography, ethnicity" ;
    fdo:task fdo:190 .

fdo:ColumbiaUniversitySpeedDating a dcat:Dataset ;
    dcterms:creator "Columbia University; Harvard University; Stanford University"^^xsd:string ;
    dcterms:description "this dataset is a result of a speed dating experiment aimed at understanding preferences in mate selection in men and women. Subjects were recruited from students at Columbia University. Fourteen rounds were conducted with different proportions of male and female subjects, over the period 2002--2004, with participants meeting each potential mate for four minutes and rating them thereafter on six attributes. They also provide an overall evaluation of each potential mate and a binary decision indicating interest in meeting again. Before an event, each participant filled in a survey disclosing their preferences, expectations, and demographics. The inference task associated with this dataset is optimal recommendation in symmetrical two-sided markets" ;
    dcterms:isReferencedBy "\\citet{fisman2006gender}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Columbia University; Harvard University; Stanford University"^^xsd:string ;
    dcterms:title "Columbia University Speed Dating" ;
    dcterms:type "person-person pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:sociology ;
    fdo:sampleSize "10K dating records involving 400 people" ;
    fdo:sensitiveFeature "gender, age, race, geography" ;
    fdo:task fdo:150 ;
    dcat:landingPage "https://data.world/annavmontoya/speed-dating-experiment"^^xsd:anyURI .

fdo:CommunitiesandCrime a dcat:Dataset ;
    dcterms:creator "La Salle University; Rutgers University"^^xsd:string ;
    dcterms:description "this dataset was curated to develop a software tool supporting the work of US police departments. It was especially aimed at identifying similar precincts to exchange best practices and share experiences among departments. The creators were supported by the police departments of Camden (NJ) and Philadelphia (PA). The factors included in the dataset were the ones deemed most important to define similarity of communities from the perspective of law enforcement; they were chosen with the help of law enforcement officials from partner institutions and academics of criminal justice, geography and public policy. The dataset includes socio-economic factors (aggregate data on age, income, immigration, and racial composition) obtained from the 1990 US census, along with information about policing (e.g. number of police cars available) based on the 1990 Law Enforcement Management and Administrative Statistics survey, and crime data derived from the 1995 FBI Uniform Crime Reports. In its released version on UCI, the task associated with the dataset is predicting the total number of violent crimes per 100K population in each community. The most referenced version of this dataset was preprocessed with a normalization step; after receiving multiple requests, the creators also published an unnormalized version" ;
    dcterms:isReferencedBy "\\citet{redmond2002datadriven}" ;
    dcterms:issued "2009"^^xsd:gYear ;
    dcterms:modified "2009"^^xsd:gYear ;
    dcterms:publisher "La Salle University; Rutgers University"^^xsd:string ;
    dcterms:title "Communities and Crime" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "2K communities" ;
    fdo:sensitiveFeature "race, geography" ;
    fdo:task fdo:67 ;
    dcat:landingPage "http://archive.ics.uci.edu/ml/datasets/communities+and+crime+unnormalized"^^xsd:anyURI,
        "https://archive.ics.uci.edu/ml/datasets/communities+and+crime"^^xsd:anyURI .

fdo:CoraPapers a dcat:Dataset ;
    dcterms:creator "Just Research Carnegie Mellon University; Massachusetts Institute of Technology; Univeristy of Maryland;  Lawrence Livermore National Laboratory"^^xsd:string ;
    dcterms:description "this resource was produced within the wider development effort for \\emph{Cora}, an Internet portal for computer science research papers available in the early 2000s. The portal supported keyword search, topical categorization of articles, and citation mapping. This dataset consists of articles and citation links between them. It contains bag-of-word representations for the text of each article, and the associated task is classification into one of seven topics" ;
    dcterms:isReferencedBy "\\citet{mccallum2000automating,sen2008collective}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Just Research Carnegie Mellon University; Massachusetts Institute of Technology; Univeristy of Maryland;  Lawrence Livermore National Laboratory"^^xsd:string ;
    dcterms:title "Cora Papers" ;
    dcterms:type "article-article pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:libraryandinformationsciences ;
    fdo:sampleSize "3K articles connected by 5K citations" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:111 ;
    dcat:landingPage "https://relational.fit.cvut.cz/dataset/CORA"^^xsd:anyURI .

fdo:CostaricaHouseholdSurvey a dcat:Dataset ;
    dcterms:creator "Instituto Nacional de Estadística y Censos"^^xsd:string ;
    dcterms:description "this data comes from the national household survey of Costa Rica, performed by the national institute of statistics and census (Instituto Nacional de Estadística y Censos). The survey is aimed at measuring the socio-economical situation in the country and informing public policy. The data collection procedure is specially designed to allow for precise conclusions with respect to six different regions of the country and about differences in urban vs rural areas; stratification along these variables is deemed suitable. The 2018 survey contains a special section on the crimes suffered by respondents" ;
    dcterms:isReferencedBy "\\url{https://www.inec.cr/sites/default/files/documetos-biblioteca-virtual/enaho-2018.pdf}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Instituto Nacional de Estadística y Censos"^^xsd:string ;
    dcterms:title "Costarica Household Survey" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "13K households" ;
    fdo:sensitiveFeature "sex, age, birthplace, disability, geography, family size" ;
    fdo:task fdo:48 ;
    dcat:landingPage "https://www.inec.cr/encuestas/encuesta-nacional-de-hogares"^^xsd:anyURI .

fdo:CreditCardDefault a dcat:Dataset ;
    dcterms:creator "Chung-Hua University; Thompson Rivers University"^^xsd:string ;
    dcterms:description "this dataset was built to investigate automated mechanisms for credit card default prediction following a wave of defaults in Taiwan connected to patters of card over-issuing and over-usage. The dataset contains payment history of customers of an important Taiwanese bank, from April to October 2005. Demographics, marital status, and education of customers are also provided, along with the amount of credit and a binary variable encoding default on payment, which is the target variable of the associated task" ;
    dcterms:isReferencedBy "\\citet{yeh2009comparisons}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Chung-Hua University; Thompson Rivers University"^^xsd:string ;
    dcterms:title "Credit Card Default" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "30K credit card holders" ;
    fdo:sensitiveFeature "gender, age" ;
    fdo:task fdo:70 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/default+of+credit+card+clients"^^xsd:anyURI .

fdo:CreditElasticities a dcat:Dataset ;
    dcterms:creator "Yale University; Dartmouth College"^^xsd:string ;
    dcterms:description "this dataset stems from a randomized trial conducted by a consumer lender in South Africa to study loan price elasticity. Prior customers were contacted by mail with limited-time loan offers at variable and randomized interest rates. The aim of the study was understanding the relationship between interest rate and customer acceptance rates, along with the benefits for the lender. Customers who accepted and received formal approval, filled in a short survey with factors of interest for the study, including demographics, education, and prior borrowing history" ;
    dcterms:isReferencedBy "\\citet{karlan2008credit}" ;
    dcterms:issued "2008"^^xsd:gYear ;
    dcterms:modified "2008"^^xsd:gYear ;
    dcterms:publisher "Yale University; Dartmouth College"^^xsd:string ;
    dcterms:title "Credit Elasticities" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "50K clients" ;
    fdo:sensitiveFeature "gender, age, geography" ;
    fdo:task fdo:178 ;
    dcat:landingPage "http://doi.org/10.3886/E113240V1"^^xsd:anyURI .

fdo:CrowdJudgement a dcat:Dataset ;
    dcterms:creator "Dartmouth College"^^xsd:string ;
    dcterms:description "this dataset was assembled to compare the performance of the COMPAS recidivism risk prediction system against that of non-expert human assessors \\citep{dressel2018accuracy}. A subset of 1,000 defendants were selected from the COMPAS dataset. Crowd-sourced assessors were recruited through Amazon Mechanical Turk. They were presented with a summary of each defendant, including demographics and previous criminal history, and asked to predict whether they would recidivate within 2 years of their most recent crime. These judgements, assembled via plain majority voting, ended up exhibiting accuracy and fairness levels comparable to that displayed by the COMPAS system. While this dataset was assembled for an experiment, it was later used to study the problem of fairness in crowdsourced judgements" ;
    dcterms:isReferencedBy "\\citep{dressel2018accuracy}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Dartmouth College"^^xsd:string ;
    dcterms:title "Crowd Judgement" ;
    dcterms:type "judge-defendant pair"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "1K defendants from COMPAS and 400 crowd-sourced labellers. Each defendant is judged by 20 different labellers" ;
    fdo:sensitiveFeature "sex, age and race of defendants and crowd-sourced judges" ;
    fdo:task fdo:2 ;
    fdo:variant "a similar dataset was collected by \\citet{wang2019empirical}" ;
    dcat:landingPage "https://farid.berkeley.edu/downloads/publications/scienceadvances17/"^^xsd:anyURI .

fdo:CuratrBritishLibraryDigitalCorpus a dcat:Dataset ;
    dcterms:creator "University College Dublin"^^xsd:string ;
    dcterms:description "this dataset is a subset of English language digital texts from the British Library focused on volumes of 19th-century fiction, obtained through the Curatr platform. It was selected for the well-researched presence of stereotypical and binary concepts of gender in this literary production. The goal of the creators was studying gender biases in large text corpora and their relationship with biases in word embeddings trained on those corpora" ;
    dcterms:isReferencedBy "\\citet{leavy2019curatr}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "University College Dublin"^^xsd:string ;
    dcterms:title "Curatr British Library Digital Corpus" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:literature ;
    fdo:sampleSize "20K  books" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:148 ;
    dcat:landingPage "http://curatr.ucd.ie/"^^xsd:anyURI .

fdo:DallasPoliceIncidents a dcat:Dataset ;
    dcterms:creator "Dallas Police Department"^^xsd:string ;
    dcterms:description "this dataset is due to the Dallas OpenData initiative\\footnote{\\url{https://www.dallasopendata.com/}} and ``reflects crimes as reported to the Dallas Police Department'' beginning June 1, 2014. Each incident comes with rich spatio-temporal data, information about the victim, the officers involved and the type of crime. A subset of the dataset is available on Kaggle\\footnote{\\url{https://www.kaggle.com/carrie1/dallaspolicereportedincidents}}" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Dallas Police Department"^^xsd:string ;
    dcterms:title "Dallas Police Incidents" ;
    dcterms:type "tabular"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "800K incidents" ;
    fdo:sensitiveFeature "age, race, and gender (of victim), geography" ;
    fdo:task fdo:103 ;
    dcat:landingPage "https://www.dallasopendata.com/Public-Safety/Police-Incidents/qv6i-rri7"^^xsd:anyURI .

fdo:DemographicsonTwitter a dcat:Dataset ;
    dcterms:creator "Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:description "this dataset was developed to test demographic classifiers on Twitter data. In particular, the tasks associated with this resource are the automatic inference of gender, age, location and political orientation of users. The true values for these attributes, which act as a ground truth for learning algorithms, were inferred from tweets and user bios, such as the ones containing the regexp \"I'm a $<$gendered noun$>$\", with gendered nouns including mother, woman, father, man" ;
    dcterms:isReferencedBy "\\citet{vijayaraghavan2017twitter}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:title "Demographics on Twitter" ;
    dcterms:type "mixture"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "80K profiles" ;
    fdo:sensitiveFeature "gender, age, political orientation, geography" ;
    fdo:task fdo:162 .

fdo:Diabetes130-USHospitals a dcat:Dataset ;
    dcterms:creator "Virginia Commonwealth University; University of Cordoba; Polish Academy of Sciences"^^xsd:string ;
    dcterms:description "this dataset contains 10 years of care data from 130 US hospitals extracted from Health Facts, a clinical database associated with a multi-institution data collection program. The dataset was extracted to study the association between the measurement of HbA1c (glycated hemoglobin) in human bloodstream and early hospital readmission, and was donated to UCI in 2014. The dataset includes patient demographics, in-hospital procedures, and diagnoses, along with information about subsequent readmissions" ;
    dcterms:isReferencedBy "\\citet{strack2014impact}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "Virginia Commonwealth University; University of Cordoba; Polish Academy of Sciences"^^xsd:string ;
    dcterms:title "Diabetes 130-US Hospitals" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:endocrinology ;
    fdo:sampleSize "100K patients" ;
    fdo:sensitiveFeature "age, race, gender" ;
    fdo:task fdo:56 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/diabetes+130-us+hospitals+for+years+1999-2008"^^xsd:anyURI .

fdo:DiversityinFaces_DiF a dcat:Dataset ;
    dcterms:creator "IBM"^^xsd:string ;
    dcterms:description "this large dataset was created to favour the development and evaluation of robust face analysis algorithms across diverse demographics and domain-specific features, such as craniofacial distances and facial contrast). One million images of people's faces from Flickr were labelled, mostly automatically, according to 10 different coding schemes, comprising, e.g., cranio-facial measurements, pose, and demographics. Age and gender were inferred both automatically and by human workers. Statistics about the diversity of this dataset along these coded measures are available in the accompanying report" ;
    dcterms:isReferencedBy "\\citet{merler2019diversity}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "IBM"^^xsd:string ;
    dcterms:title "Diversity in Faces (DiF)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "1M images" ;
    fdo:sensitiveFeature "skin color, age, and gender" ;
    fdo:task fdo:93 ;
    dcat:landingPage "https://www.ibm.com/blogs/research/2019/01/diversity-in-faces/"^^xsd:anyURI .

fdo:DrugConsumption a dcat:Dataset ;
    dcterms:creator "Rampton Hospital; Nottinghamshire Healthcare NHS Foundation Trust; University of Leicester; University of Nottingham; University of Salahaddin"^^xsd:string ;
    dcterms:description "this dataset was collected by Elaine Fehrman between March 2011 and March 2012 after receiving approval from relevant ethics boards from the University of Leicester. The goal of this dataset is to seek patterns connecting an individual’s risk of drug consumption with demographics and psychometric measurements of the Big Five personality traits (NEO-FFI-R), impulsivity (BIS-11), and sensation seeking (ImpSS). The study employed an online survey tool from Survey Gizmo to recruit participants world-wide; over 93\\% of the final usable sample reported living in an English-speaking country. Target variables summarize the consumption of 18 psychoactive substances on an ordinal scale ranging from never using the drug to using it over a decade ago, or in the last decade, year, month, week, or day. The 18 substances considered in the study are classified as central nervous system depressants, stimulants, or hallucinogens and comprise the following: alcohol, amphetamines, amyl nitrite, benzodiazepines, cannabis, chocolate, cocaine, caffeine, crack, ecstasy, heroin, ketamine, legal highs, LSD, methadone, magic mushrooms, nicotine, and Volatile Substance Abuse (VSA), along with one fictitious drug (Semeron) introduced to identify over-claimers. A version of the dataset donated to the UCI Machine Learning Repository is associated with 18 prediction tasks, i.e. one per substance" ;
    dcterms:isReferencedBy "\\citet{fehrman2017five, fehrman2019personality}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Rampton Hospital; Nottinghamshire Healthcare NHS Foundation Trust; University of Leicester; University of Nottingham; University of Salahaddin"^^xsd:string ;
    dcterms:title "Drug Consumption" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:appliedpsychology ;
    fdo:sampleSize "2K respondents" ;
    fdo:sensitiveFeature "age, gender, ethnicity, geography" ;
    fdo:task fdo:41 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/Drug+consumption+\\%28quantified\\%29"^^xsd:anyURI .

fdo:DrugNet a dcat:Dataset ;
    dcterms:creator "Institute for Community Research of Hartford; Hispanic Health Council, Hartford; Boston College"^^xsd:string ;
    dcterms:description "this dataset was collected to study drug consumption patterns in connection with social ties and behaviour of drug users. This work puts particular emphasis on situations at risk of disease transmission and to assess the opportunity for prevention via recruitment of peer educators to demonstrate, disseminate and support HIV prevention practices among their connections. Participants were recruited in Hartford neighbourhoods of high drug-use activity, mostly via street outreach and recruitment by early participants. Eligibility criteria included being at least 18 years old, using an illicit drug, and signing an informed consent form. Each participant provided data about their drug use, most common sites of usage, HIV risk practices associated with drug use and sexual behavior, and social ties deemed important by the respondent and their demographics" ;
    dcterms:isReferencedBy "\\citet{weeks2002social}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Institute for Community Research of Hartford; Hispanic Health Council, Hartford; Boston College"^^xsd:string ;
    dcterms:title "DrugNet" ;
    dcterms:type "person-person pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#socialwork,socialnetworks> ;
    fdo:sampleSize "300 people" ;
    fdo:sensitiveFeature "ethnicity, sex, age" ;
    fdo:task fdo:134 ;
    dcat:landingPage "https://sites.google.com/site/ucinetsoftware/datasets/covert-networks/drugnet"^^xsd:anyURI .

fdo:DutchCensus a dcat:Dataset ;
    dcterms:creator "Bournemouth University; TU Eindhoven"^^xsd:string ;
    dcterms:description "this dataset was derived from the 2001 census carried out by the Dutch Central Bureau for Statistics to gather data about family composition, economic activities, levels of education, and occupation of Dutch citizens and foreigners from various countries of origin. A version of the dataset commonly employed in the fairness research literature has been preprocessed and made available online. The associated task is the classification of individuals into high-income and low-income professions" ;
    dcterms:isReferencedBy "\\citet{zliobaite2011handling}; \\url{https://microdata.worldbank.org/index.php/catalog/2102/data-dictionary/F2?file_name=NLD2001-P-H}; \\url{https://www.cbs.nl/nl-nl/publicatie/2004/31/the-dutch-virtual-census-of-2001}" ;
    dcterms:issued "2001"^^xsd:gYear ;
    dcterms:modified "2001"^^xsd:gYear ;
    dcterms:publisher "Bournemouth University; TU Eindhoven"^^xsd:string ;
    dcterms:title "Dutch Census" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:demography ;
    fdo:sampleSize "60K respondents" ;
    fdo:sensitiveFeature "sex, age, citizenship" ;
    fdo:task fdo:10 ;
    dcat:landingPage "https://sites.google.com/site/conditionaldiscrimination/"^^xsd:anyURI .

fdo:EdGap a dcat:Dataset ;
    dcterms:creator "Memphis Teacher Residency"^^xsd:string ;
    dcterms:description "this dataset focuses on education performance in different US counties, with a focus on inequality of opportunity and its connection to socioeconomic factors. Along with average SAT and ACT test scores by county, this dataset reports socioeconomic data from the American Community Survey by the Bureau of Census, including  household income, unemployment, adult educational attainment, and family structure. Importantly, some states require all students to take ACT or SAT tests, while others do not. As a result, average test scores are inherently higher in states that do not require all students to test, and they are not directly comparable to average scores in states where testing is mandatory" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Memphis Teacher Residency"^^xsd:string ;
    dcterms:title "EdGap" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "2K counties" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:138 ;
    dcat:landingPage "https://www.edgap.org/"^^xsd:anyURI .

fdo:EpilepticSeizures a dcat:Dataset ;
    dcterms:creator "University of Bonn"^^xsd:string ;
    dcterms:description "this dataset was curated to study electroencephalographic (EEG) time series in relation to epilepsy. The dataset consists of EEG recordings from healthy volunteers with eyes closed and eyes open, and from epilepsy patients during seizure-free intervals and during epileptic seizures. Volunteers and patients are recorded for 23.6-sec. A version of this dataset, used in fairness research, was donated to UCI Machine Learning Repository by researchers affiliated with Rochester Institute of Technology in 2017, with a classification task based on the patients' condition and state at the time of recording. The data was later removed from UCI at the original curators' request" ;
    dcterms:isReferencedBy "\\citet{andrzejak2001indications}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "University of Bonn"^^xsd:string ;
    dcterms:title "Epileptic Seizures" ;
    dcterms:type "time series"^^rdf:PlainLiteral ;
    fdo:domain fdo:neurology ;
    fdo:sampleSize "500 individuals, each summarized by 4K-points time series" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:24 ;
    dcat:landingPage "http://epileptologie-bonn.de/cms/upload/workgroup/lehnertz/eegdata.html"^^xsd:anyURI,
        "https://archive.ics.uci.edu/ml/datasets/Epileptic+Seizure+Recognition"^^xsd:anyURI .

fdo:EquitableSchoolAccessinChicago a dcat:Dataset ;
    dcterms:creator "Salesforce"^^xsd:string ;
    dcterms:description "this resource was assembled from disparate sources to evaluate school access in Chicago for different race groups. A transportation network was inferred from data on public bus lines available on the Chicago Transit Authority website. Data on school location and quality evaluation was obtained from the Chicago Public School data portal. Finally, demographic information on race representation in different tracts was retrieved from the 2010 US census" ;
    dcterms:isReferencedBy "\\citet{ramachandran2021gaea}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Salesforce"^^xsd:string ;
    dcterms:title "Equitable School Access in Chicago" ;
    dcterms:type "location-location pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:transportation ;
    fdo:sampleSize "2K nodes (locations), connected by 8K edges (bus lines)" ;
    fdo:sensitiveFeature "race" ;
    fdo:task fdo:224 ;
    dcat:landingPage "https://github.com/salesforce/GAEA"^^xsd:anyURI .

fdo:EquityEvaluationCorpus_EEC a dcat:Dataset ;
    dcterms:creator "National Research Council Canada"^^xsd:string ;
    dcterms:description "this dataset was compiled to audit sentiment analysis systems for gender and race bias. It is based on 11 short sentence templates; 7 templates include emotion words, while the remaining 4 do not. Moreover, each sentence includes one gender- or race-associated word, such as names predominantly associated with African American or European American people. Gender-related words consist of names, nouns, and pronouns" ;
    dcterms:isReferencedBy "\\citet{kiritchenko2018examining}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "National Research Council Canada"^^xsd:string ;
    dcterms:title "Equity Evaluation Corpus (EEC)" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "9K sentences" ;
    fdo:sensitiveFeature "race, gender" ;
    fdo:task fdo:52 ;
    dcat:landingPage "https://saifmohammad.com/WebPages/Biases-SA.html"^^xsd:anyURI .

fdo:FACES a dcat:Dataset ;
    dcterms:creator "Max Planck Institute for Human Development"^^xsd:string ;
    dcterms:description "this resource contains images of Caucasian individuals of variable age and gender under six predefined facial expressions (neutrality, sadness, disgust, fear, anger, and happiness). This dataset is described as a database of emotion-related stimuli for scientific research. Subjects were hired through a model agency in Berlin, and suitably informed about the purpose of the photo-shooting session, thereafter signing an informed consent document. Each model reported their own age and gender. The necessary facial expressions were carefully explained with the help of a manual, with attention to the position of muscles. Photographs were obtained and post-processed in a standardized fashion, and later validated by raters of different ages with respect to the perceived expression and age of subjects. At a later stage, images were also annotated for attractiveness and distinctiveness. Currently, a small subset of the images is publicly available, while the full dataset is available after registration" ;
    dcterms:isReferencedBy "\\citet{ebner2010faces}" ;
    dcterms:issued "2010"^^xsd:gYear ;
    dcterms:modified "2010"^^xsd:gYear ;
    dcterms:publisher "Max Planck Institute for Human Development"^^xsd:string ;
    dcterms:title "FACES" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#computervision,experimentalpsychology> ;
    fdo:sampleSize "2K images of 200 people" ;
    fdo:sensitiveFeature "age, gender" ;
    fdo:task fdo:225 ;
    dcat:landingPage "https://faces.mpib-berlin.mpg.de/imeji/"^^xsd:anyURI .

fdo:FICO a dcat:Dataset ;
    dcterms:creator "Google; University of Texas at Austin; Toyota Technological Institute at Chicago"^^xsd:string ;
    dcterms:description "based on a sample of 301,536 TransUnion TransRisk scores from 2003, this dataset was created to study the problem of adjusting predictors for compliance with the equality of opportunity fairness metric. The TransUnion data was preprocessed and aggregated to summarize the CDF of risk scores by race (Non-Hispanic white, Black, Hispanic, Asian). The original data comes from a 2007 report to the US Congress on credit scoring and its effects on the availability and affordability of credit carried out by a dedicated Federal Reserve working group. The collection, creation, processing, and aggregation was carried out by the working group; the data was later scraped by the creators, who made it available without any modification" ;
    dcterms:isReferencedBy "\\citet{usfr2007report,hardt2016equality,barocas2019fair}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Google; University of Texas at Austin; Toyota Technological Institute at Chicago"^^xsd:string ;
    dcterms:title "FICO" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "N/As. CDFs are provided over risk scores which are normalized (0-100\\%)  and quantized with step 0.5\\%" ;
    fdo:sensitiveFeature "race" ;
    fdo:task fdo:55 ;
    dcat:landingPage "https://github.com/fairmlbook/fairmlbook.github.io/tree/master/code/creditscore/data"^^xsd:anyURI .

fdo:FIFA20Players a dcat:Dataset ;
    dcterms:creator "unknown"^^xsd:string ;
    dcterms:description "this dataset was scraped by Stefano Leone and made available on Kaggle. It includes the players' data for the Career Mode from FIFA 15 to FIFA 20, a popular football game. Several tasks are envisioned for this dataset, including a historical comparison of players" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "unknown"^^xsd:string ;
    dcterms:title "FIFA 20 Players" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:sports ;
    fdo:sampleSize "20K players" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:176 ;
    dcat:landingPage "https://www.kaggle.com/stefanoleone992/fifa-20-complete-player-dataset"^^xsd:anyURI .

fdo:FacebookEgo-networks a dcat:Dataset ;
    dcterms:creator "Stanford University"^^xsd:string ;
    dcterms:description "this dataset was collected to study the problem of  identifying users’ social circles, i.e. categorizing links between nodes in a social network. The data represents ten ego-networks whose central user was asked to fill in a survey and manually identify the circles to which their friends belonged. Features from each profile, including education, work and location are anonymized" ;
    dcterms:isReferencedBy "\\citet{leskovec2012learning}" ;
    dcterms:issued "2012"^^xsd:gYear ;
    dcterms:modified "2012"^^xsd:gYear ;
    dcterms:publisher "Stanford University"^^xsd:string ;
    dcterms:title "Facebook Ego-networks" ;
    dcterms:type "user-user pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialnetworks ;
    fdo:sampleSize "4K people connected by 90K friend relations" ;
    fdo:sensitiveFeature "geography, gender" ;
    fdo:task fdo:110 ;
    dcat:landingPage "https://snap.stanford.edu/data/egonets-Facebook.html"^^xsd:anyURI .

fdo:FacebookLargeNetwork a dcat:Dataset ;
    dcterms:creator "University of Edinburgh"^^xsd:string ;
    dcterms:description "this dataset was developed to study the effectiveness of node embeddings for learning tasks defined on graphs. The dataset concentrates on verified Facebook pages of politicians, governmental organizations, television shows, and companies, represented as nodes, while edges represent mutual likes. In addition, each page comes with node embeddings which are extracted from the textual description of each page. The original task on this dataset is page category classification" ;
    dcterms:isReferencedBy "\\citet{rozemberczki2021multi}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "University of Edinburgh"^^xsd:string ;
    dcterms:title "Facebook Large Network" ;
    dcterms:type "page-page pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialnetworks ;
    fdo:sampleSize "20K nodes (pages) connected by 200K edges (mutual likes)" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:100 ;
    dcat:landingPage "http://snap.stanford.edu/data/facebook-large-page-page-network.html"^^xsd:anyURI .

fdo:FairFace a dcat:Dataset ;
    dcterms:creator "University of California, Los Angeles"^^xsd:string ;
    dcterms:description "this dataset was developed as a balanced resource for face analysis with diverse race, gender and age composition. The associated task is race, gender and age classification. Starting from a large public image dataset (Yahoo YFCC100M), the authors sampled images incrementally to ensure diversity with respect to race, for which they considered seven categories: White, Black, Indian, East Asian, Southeast Asian, Middle East, and Latino. Sensitive attributes were annotated by workers on Amazon Mechanical Turk, and also through a model based on these annotations. Faces with low agreement between model and annotators were manually re-verified by the dataset curators. This dataset was annotated automatically with a binary Fitzpatrick skin tone label \\citep{cheng2021can}" ;
    dcterms:isReferencedBy "\\citet{karkkainen2019fairface}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "University of California, Los Angeles"^^xsd:string ;
    dcterms:title "FairFace" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "100K images" ;
    fdo:sensitiveFeature "race, age, gender, skin tone" ;
    fdo:task fdo:26 ;
    dcat:landingPage "https://github.com/joojs/fairface"^^xsd:anyURI .

fdo:FantasyFootball a dcat:Dataset ;
    dcterms:creator "Worcester Polytechnic Institute"^^xsd:string ;
    dcterms:description "this resource was curated to study the problem of fair ranking aggregation. The creators collected rankings of National Football League players from the top 25 experts on the popular fantasy sports website FantasyPros. The data covers 16 weeks during the 2019 football season. Players are assigned to different sensitive groups based on the conference of their team (American Football Conference or National Football Conference). The data available online concentrates on wide receivers" ;
    dcterms:isReferencedBy "\\citet{kuhlman2020rank}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Worcester Polytechnic Institute"^^xsd:string ;
    dcterms:title "Fantasy Football" ;
    dcterms:type "player-expert pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:sports ;
    fdo:sampleSize "50 players, ranked by 25 experts (on a weekly basis), over 16 weeks" ;
    fdo:sensitiveFeature "football conference" ;
    fdo:task fdo:215 ;
    dcat:landingPage "https://arcgit.wpi.edu/cakuhlman/VLDB2020/tree/master/charts/data"^^xsd:anyURI .

fdo:FashionMNIST a dcat:Dataset ;
    dcterms:creator "Zalando"^^xsd:string ;
    dcterms:description "this dataset is based on product assortement from the Zalando website. It contains gray-scale resized versions of thumbnail images of unique clothing products, labeled by in-house fashion experts according to their category, including e.g. trousers, coat and shirt. The envisioned task is object classification. The dataset, sharing the same size and structure as MNIST, was developed to provide a harder and more representative task, and to replace MNIST as a popular computer vision benchmark" ;
    dcterms:isReferencedBy "\\citet{xiao2017fashionmnist}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Zalando"^^xsd:string ;
    dcterms:title "Fashion MNIST" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "70K images across 10 product categories" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:20 ;
    dcat:landingPage "https://github.com/zalandoresearch/fashion-mnist"^^xsd:anyURI .

fdo:FilmTrust a dcat:Dataset ;
    dcterms:creator "Northeastern University; Nanyang Technological University; American University of Beirut; University of Cambridge"^^xsd:string ;
    dcterms:description "this dataset was crawled from the entire FilmTrust website, a movie recommendation service with a social network component. The dataset comprises user-movie ratings on a 5-star scale and user-user indications of trust about movie taste. This resource can be used to train and evaluate recommender systems" ;
    dcterms:isReferencedBy "\\citet{guo2016novel}" ;
    dcterms:issued "2011"^^xsd:gYear ;
    dcterms:modified "2011"^^xsd:gYear ;
    dcterms:publisher "Northeastern University; Nanyang Technological University; American University of Beirut; University of Cambridge"^^xsd:string ;
    dcterms:title "FilmTrust" ;
    dcterms:type "user-movie pairs and user-user pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#informationsystems,movies> ;
    fdo:sampleSize "40K ratings by 2K users over 2K movies" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:200 ;
    dcat:landingPage "https://guoguibing.github.io/librec/datasets.html"^^xsd:anyURI .

fdo:Framingham a dcat:Dataset ;
    dcterms:creator "National Heart, Lung, and Blood Institute (NHLBI); Boston University"^^xsd:string ;
    dcterms:description "the Framingham Heart Study began in 1948 under the direction of the National Heart, Lung, and Blood Institute (NHLBI), with the goal of identifying key factors that contribute to cardiovascular disease, given a mounting epidemic of cardiovascular disease whose etiology was mostly unknown at the time. Six different cohorts have been recruited over the years among citizens of Framingham, Massachusetts, without symptoms of cardiovascular disease. After the original cohort, two more were enrolled from the children and grandchildren of the first one. Additional cohorts were also started to reflect the increased racial and ethnic diversity in the town of Framingham. Participants in the study report on their habits (e.g. physical activity, smoking) and undergo regular physical examination and laboratory tests" ;
    dcterms:isReferencedBy "\\citet{kannel1979diabetes, tsao2015cohort}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "National Heart, Lung, and Blood Institute (NHLBI); Boston University"^^xsd:string ;
    dcterms:title "Framingham" ;
    dcterms:type "mixture"^^rdf:PlainLiteral ;
    fdo:domain fdo:cardiology ;
    fdo:sampleSize "15K respondents" ;
    fdo:sensitiveFeature "age, sex, race" ;
    fdo:task fdo:86 ;
    dcat:landingPage "https://framinghamheartstudy.org/"^^xsd:anyURI .

fdo:Freebase15k-237 a dcat:Dataset ;
    dcterms:creator "Microsoft; Stanford University"^^xsd:string ;
    dcterms:description "Freebase was a collaborative knowledge base which allowed its community members to fill in structured data about diverse entities and relations between them. This database was developed from a prior Freebase dataset \\citep{bordes2013:translating}, pruning it from redundant relations and augmenting it with textual relationships from the ClueWeb12 corpus. The creators of this dataset worked on the joint optimization of entity knowledge base and representations of the entities' textual relations, with the goal of providing representations of entities suited for knowledge base completion" ;
    dcterms:isReferencedBy "\\citet{toutanova2015representing}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Microsoft; Stanford University"^^xsd:string ;
    dcterms:title "Freebase15k-237" ;
    dcterms:type "entity-relation-entity triples"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "15K entities connected by 170K edges (relations)" ;
    fdo:sensitiveFeature "demographics of people featured in entities and their relations" ;
    fdo:task fdo:143 ;
    dcat:landingPage "https://www.microsoft.com/en-us/download/details.aspx?id=52312"^^xsd:anyURI .

fdo:GAPCoreference a dcat:Dataset ;
    dcterms:creator "Google"^^xsd:string ;
    dcterms:description "this resource was developed as a gender-balanced coreference resolution dataset, useful for auditing gender-dependent differences in the accuracy of existing pronoun resolution algorithms and for training new algorithms that are less gender-biased. The dataset consists of thousands of ambiguous pronoun-name pairs in sentences extracted from Wikipedia. Several measures are taken to avoid the success of naïve heuristics and to favour diversity. Most notably, while the initial (automated) stage of the data collection pipeline extracts contexts with a female:male ratio of 1:9, feminine pronouns are oversampled to achieve a 1:1 ratio. Each example is presented to and annotated  for coreference by three in-house workers" ;
    dcterms:isReferencedBy "\\citet{webster2018mind}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Google"^^xsd:string ;
    dcterms:title "GAP Coreference" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "9K sentences" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:140 ;
    dcat:landingPage "https://github.com/google-research-datasets/gap-coreference"^^xsd:anyURI .

fdo:GLUE a dcat:Dataset ;
    dcterms:creator "New York University; University of Washington; DeepMind"^^xsd:string ;
    dcterms:description "this benchmark was assembled to reliably evaluate the progress of natural language processing models. It consists of multiple datasets and associated tasks from the natural language processing domain, including paraphrase detection, textual entailment, sentiment analysis and question answering. Given the quick progress registered by language models on GLUE, a similar benchmark called SuperGLUE was subsequently released comprising more challenging and diverse tasks \\citep{wang2019:superglue}" ;
    dcterms:isReferencedBy "\\citet{wang2018glue}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "New York University; University of Washington; DeepMind"^^xsd:string ;
    dcterms:title "GLUE" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize " 100 - 400K samples. Datasets have variable sizes spanning three orders of magnitude" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:107 ;
    dcat:landingPage "https://gluebenchmark.com/"^^xsd:anyURI .

fdo:GermanCredit a dcat:Dataset ;
    dcterms:creator "Hypo Bank (OP/EDV-VP); Universität Hamburg; Strathclyde University (German Credit); Beuth University of Applied Sciences Berlin (South German Credit)"^^xsd:string ;
    dcterms:description "the German Credit dataset was created to study the problem of automated credit decisions at a regional Bank in southern Germany. Instances represent loan applicants from 1973 to 1975, who were deemed creditworthy and were granted a loan, bringing about a natural selection bias. The data summarizes their financial situation, credit history and personal situation, including housing and number of liable people. A binary variable encoding whether each loan recipient punctually payed every installment is the target of a classification task. Among covariates, marital status and sex are jointly encoded in a single variable. Many documentation mistakes are present in the UCI entry associated with this resource \\citep{hofmann1994:sg}. Due to one of these mistakes, users of this dataset are led to believe that the variable sex can be retrieved from the joint marital\\_status-sex variable, however this is false. A revised version with correct variable encodings, called South German Credit, was donated to \\citet{gromping2019:sg2} with an accompanying report \\citep{gromping2019:sg}. See Appendix \\ref{sec:german} for extensive documentation" ;
    dcterms:isReferencedBy "\\citet{gromping2019:sg}" ;
    dcterms:issued "1994"^^xsd:gYear ;
    dcterms:modified "1994"^^xsd:gYear ;
    dcterms:publisher "Hypo Bank (OP/EDV-VP); Universität Hamburg; Strathclyde University (German Credit); Beuth University of Applied Sciences Berlin (South German Credit)"^^xsd:string ;
    dcterms:title "German Credit" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "1K" ;
    fdo:sensitiveFeature "age, geography" ;
    fdo:task fdo:66 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/South+German+Credit+\\%28UPDATE\\%29"^^xsd:anyURI,
        "https://archive.ics.uci.edu/ml/datasets/statlog+(german+credit+data)"^^xsd:anyURI .

fdo:GermanPoliticalPosts a dcat:Dataset ;
    dcterms:creator "Technical University of Munich"^^xsd:string ;
    dcterms:description "this dataset was used as a training set for German word embeddings, with the goal of investigating biases in word representations. The authors used the Facebook and Twitter APIs to collect posts and comments from the social media channels of six main political parties in Germany (CDU/CSU, SPD, Bundnis90/Die Grünen, FDP, Die Linke, AfD). Facebook posts are from the period 2015--2018, while tweets were collected between January and October 2018. Overall, the dataset consists of millions of posts, for a total of half a billion tokens. A subset of the Facebook comments (100,000) were labeled by human annotators based on whether they contain sexist content, with four sub-labels indicating sexist comments, sexist buzzwords, gender-related compliments, statements against gender equality and assignment of gender stereotypical roles to people" ;
    dcterms:isReferencedBy "\\citet{papakyriakopulos2020bias}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Technical University of Munich"^^xsd:string ;
    dcterms:title "German Political Posts" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "20M posts comments and tweets" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:53 .

fdo:GoodreadsReviews a dcat:Dataset ;
    dcterms:creator "University of California, San Diego"^^xsd:string ;
    dcterms:description "there are several versions of this dataset, corresponding to different crawls. Here we refer to the most well documented one by \\citet{wan2018item}. This resource consists of anonymized reviews collected from public user \\emph{book shelves}. Rich metadata is available for books and reviews, including. authors, country code, publisher, userid, rating, timestamp, and text. A few medium-size subsamples focused on specific book genres are available. The task typically associated with this resource is book recommendation" ;
    dcterms:isReferencedBy "\\citet{wan2018item}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "University of California, San Diego"^^xsd:string ;
    dcterms:title "Goodreads Reviews" ;
    dcterms:type "user-book pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#literature,informationsystems> ;
    fdo:sampleSize "200M records from 900K users over 2M books" ;
    fdo:sensitiveFeature "author" ;
    fdo:task fdo:96 ;
    dcat:landingPage "https://sites.google.com/eng.ucsd.edu/ucsdbookgraph/"^^xsd:anyURI .

fdo:GoogleLocal a dcat:Dataset ;
    dcterms:creator "University of California, San Diego"^^xsd:string ;
    dcterms:description "this dataset contains reviews and ratings from millions of users on local businesses from five different continents. Businesses are labelled with nearly 50 thousand categories. This resource was collected as a real world example of interactions between users and ratable items, with the goal of testing novel recommendation approaches. The dataset comprises data that is specific to users (e.g. places lived), businesses (e.g. GPS coordinates), and reviews (e.g. timestamps)" ;
    dcterms:isReferencedBy "\\citet{he2017translationbased}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "University of California, San Diego"^^xsd:string ;
    dcterms:title "Google Local" ;
    dcterms:type "user-business pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "10M reviews and ratings from 5M users on 3M local businesses" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:158 ;
    dcat:landingPage "https://cseweb.ucsd.edu/~jmcauley/datasets.html#google_local"^^xsd:anyURI .

fdo:GreekWebsites a dcat:Dataset ;
    dcterms:creator "FORTH-ICS, University of Crete"^^xsd:string ;
    dcterms:description "this dataset was created to demonstrate the \\emph{bias goggles} tools, which enables users to explore diverse bias aspects connected with popular Greek web domains. The dataset is a subset of the Greek web, crawled from Greek websites that cover politics and sports, represent big industries, or are generally popular. Starting from a seed of hundreds of websites, crawlers followed the links up to depth 7, avoiding popular sites such as Facebook and Twitter. The final dataset has a graph structure, comprising pages and links between them" ;
    dcterms:isReferencedBy "\\citet{konstantakis2020bias}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "FORTH-ICS, University of Crete"^^xsd:string ;
    dcterms:title "Greek Websites" ;
    dcterms:type "page-page pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo: ;
    fdo:sampleSize "900k pages from  90k domains" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:147 ;
    dcat:landingPage "https://pangaia.ics.forth.gr/bias-goggles/about.html#Dataset"^^xsd:anyURI .

fdo:GuardianArticles a dcat:Dataset ;
    dcterms:creator "University College Dublin"^^xsd:string ;
    dcterms:description "this dataset consists of articles from \\emph{The Guardian}, retrieved from The Guardian Open Platform API. In particular, the authors crawled every article that appeared on the website between 2009 and 2018. They created this dataset to demonstrate a framework for the identification of gender biases in training data for machine learning" ;
    dcterms:isReferencedBy "\\citet{leavy2020mitigating}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "University College Dublin"^^xsd:string ;
    dcterms:title "Guardian Articles" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:news ;
    fdo:sampleSize "unknown" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:149 .

fdo:HAM10000 a dcat:Dataset ;
    dcterms:creator "Medical University of Vienna; University of Queensland"^^xsd:string ;
    dcterms:description "the dataset comprises 10,015 dermatoscopic images collected over a period of 20 years the Department of Dermatology at the Medical University of Vienna, Austria and the skin cancer practice of Cliff Rosendahl in Queensland, Australia. Images were acquired and stored through different modalities; each image depicts a lesion and comes with metadata detailing the region of skin lesion, patient demographics, and diagnosis, which is the target variable. The dataset was employed for the lesion disease classification of the ISIC 2018 challenge" ;
    dcterms:isReferencedBy "\\citet{tschandl2018ham10000}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Medical University of Vienna; University of Queensland"^^xsd:string ;
    dcterms:title "HAM10000" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:dermatology ;
    fdo:sampleSize "10K images" ;
    fdo:sensitiveFeature "age, sex" ;
    fdo:task fdo:126 ;
    dcat:landingPage "https://doi.org/10.7910/DVN/DBW86T"^^xsd:anyURI .

fdo:HMDA a dcat:Dataset ;
    dcterms:creator "Federal Financial Institutions Examination Council"^^xsd:string ;
    dcterms:description "The Home Mortgage Disclosure Act (HMDA) is a US federal law from 1975 mandating that financial institutions maintain and disclose information about mortgages to the public. Companies submit a Loan Application Register (LAR) to the Federal Financial Institutions Examination Council FFIEC who maintain and disclose the data. The LAR format is subject to changes, such as the one which happened in 2017. From 2018 onward, entries to the LAR comprise information about the financial institution (e.g.\\ geography, id), the applicants (e.g.\\ demographics, income), the house (e.g.\\ value, construction method), the mortgage conditions (type, interest rate, amount) and the outcome. Ethnicity, race, and sex of applicants are self-reported" ;
    dcterms:isReferencedBy "\\url{https://ffiec.cfpb.gov/}; \\url{https://www.consumerfinance.gov/data-research/hmda/}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Federal Financial Institutions Examination Council"^^xsd:string ;
    dcterms:title "HMDA" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "200M records" ;
    fdo:sensitiveFeature "sex, geography, race, ethnicity" ;
    fdo:task fdo:43 ;
    dcat:landingPage "https://ffiec.cfpb.gov/data-browser/"^^xsd:anyURI .

fdo:HarveyRescue a dcat:Dataset ;
    dcterms:creator "Harvey Relief Handiworks; Harvey Relief Coalition"^^xsd:string ;
    dcterms:description "this dataset is the result of crowdsourced efforts to connect rescue parties with people requesting help in the Houston area, mostly due to the flooding caused by Hurricane Harvey. Most requests are from August 28, 2017, and were sent via social media; they are timestamped and associated with the location of the people seeking help" ;
    dcterms:isReferencedBy "\\url{http://harveyrelief.handiworks.co/}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Harvey Relief Handiworks; Harvey Relief Coalition"^^xsd:string ;
    dcterms:title "Harvey Rescue" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialwork ;
    fdo:sampleSize "1K help requests" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:104 .

fdo:HeartDisease a dcat:Dataset ;
    dcterms:creator "Veterans Administration Medical Center, Long Beach; Hungarian Institute of Cardiology, Budapest; University Hospital, Zurich; University Hospital, Basel; Studer Corporation; Stanford University"^^xsd:string ;
    dcterms:description "this dataset is a collection of medical data from separate groups of patients referred for cardiac catheterisation and coronary angiography at 5 different medical centers, namely the Cleveland Clinic (data from 1981--1984), the Hungarian Institute of Cardiology in Budapest (1983--1987), the Long Beach Veterans Administration Medical Center (1984--1987) and the University Hospitals of Basel and Zurich (1985). The binary target variable in this dataset encodes a diagnosis of Coronary artery disease. Covariates relate to patient demographics, exercise data (e.g. maximum heart rate) and routine test data (e.g. resting blood pressure). Overall, 76 covariates are available but 14 are recommended. Names and social security numbers of the patients were initially available, but have been removed from the publicly available dataset" ;
    dcterms:isReferencedBy "\\citet{detrano1989international}" ;
    dcterms:issued "1988"^^xsd:gYear ;
    dcterms:modified "1988"^^xsd:gYear ;
    dcterms:publisher "Veterans Administration Medical Center, Long Beach; Hungarian Institute of Cardiology, Budapest; University Hospital, Zurich; University Hospital, Basel; Studer Corporation; Stanford University"^^xsd:string ;
    dcterms:title "Heart Disease" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:cardiology ;
    fdo:sampleSize "1K patients" ;
    fdo:sensitiveFeature "age, sex" ;
    fdo:task fdo:4 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/heart+disease"^^xsd:anyURI .

fdo:HeritageHealth a dcat:Dataset ;
    dcterms:creator "CHEO Research Institute, Inc; University of Ottawa; University of Maryland; Privacy Analytics, Inc; Kaggle; Heritage Provider Network"^^xsd:string ;
    dcterms:description "this dataset was developed as part of the Heritage Health Prize competition with the goal of reducing the cost of health care by decreasing the number of avoidable hospitalizations. The competition requires predicting the number of days a patient will spend in hospital during the 12 months following a cutoff date. The dataset features basic demographic information about patients, along with data about prior hospitalizations (e.g. length of stay and diagnosis), laboratory tests and prescriptions" ;
    dcterms:isReferencedBy "\\citet{el2012deidentification}" ;
    dcterms:issued "2011"^^xsd:gYear ;
    dcterms:modified "2011"^^xsd:gYear ;
    dcterms:publisher "CHEO Research Institute, Inc; University of Ottawa; University of Maryland; Privacy Analytics, Inc; Kaggle; Heritage Provider Network"^^xsd:string ;
    dcterms:title "Heritage Health" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:healthpolicy ;
    fdo:sampleSize "150K patients" ;
    fdo:sensitiveFeature "age, sex" ;
    fdo:task fdo:11 ;
    dcat:landingPage "https://www.kaggle.com/c/hhp/data"^^xsd:anyURI .

fdo:HighSchoolContactandFriendshipNetwork a dcat:Dataset ;
    dcterms:creator "Aix Marseille Université; Université de Toulon; Centre national de la recherche scientifique; ISI Foundation"^^xsd:string ;
    dcterms:description "this dataset was developed to compare and contrast different methods commonly employed to measure human interaction and build the underlying social network. Data corresponds to interactions and friendship relations between students of a French high school in Marseilles. The authors consider four different methods of network data collection, namely face-to-face contacts measured by two concurrent methods (sensors and diaries), self-reported friendship surveys, and Facebook links" ;
    dcterms:isReferencedBy "\\citet{mastrandrea2015contact}" ;
    dcterms:issued "2015"^^xsd:gYear ;
    dcterms:modified "2015"^^xsd:gYear ;
    dcterms:publisher "Aix Marseille Université; Université de Toulon; Centre national de la recherche scientifique; ISI Foundation"^^xsd:string ;
    dcterms:title "High School Contact and Friendship Network" ;
    dcterms:type "student-student pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialnetworks ;
    fdo:sampleSize "300 students" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:133 ;
    dcat:landingPage "http://www.sociopatterns.org/datasets/high-school-contact-and-friendship-networks/"^^xsd:anyURI .

<http://www.fairnessdata.dei.unipd.it/ontology#HomelessYouths'SocialNetworks> a dcat:Dataset ;
    dcterms:creator "University of Denver; University of Southern California"^^xsd:string ;
    dcterms:description "this dataset was collected to study methamphetamine use norms among homeless youth in association with their social networks. A sample of homeless youth aged 13--25 years was recruited between 2011---2012 from two drop-in centers in California. After obtaining informed consent/assent, participants filled in a survey and answered questions from  an interview. The survey included questions on demographics, migratory status, educational status and housing. To reconstruct the social network between them, each participant provided information for up to 50 people with whom they had interacted during the previous 30 days" ;
    dcterms:isReferencedBy "\\citet{barman2016sociometric}" ;
    dcterms:issued "2015"^^xsd:gYear ;
    dcterms:modified "2015"^^xsd:gYear ;
    dcterms:publisher "University of Denver; University of Southern California"^^xsd:string ;
    dcterms:title "Homeless Youths' Social Networks" ;
    dcterms:type "person-person pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialwork ;
    fdo:sampleSize "300 youth" ;
    fdo:sensitiveFeature "age, gender, sexual orientation, race and ethnicity" ;
    fdo:task fdo:182 .

fdo:IBMHRAnalytics a dcat:Dataset ;
    dcterms:creator "IBM"^^xsd:string ;
    dcterms:description "based on the information available on Kaggle, this is a fictional dataset created by IBM data scientists. It describes employees along dimensions that may be relevant for attrition, the target variable encoding employee departure. Available covariates include information on employee background (education, number of prior companies), work satisfaction (recent promotions, environment and job satisfaction) and seniority (years at the company, years in current role, job level)" ;
    dcterms:isReferencedBy "\\url{https://github.com/IBM/employee-attrition-aif360}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "IBM"^^xsd:string ;
    dcterms:title "IBM HR Analytics" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#informationsystems,managementinformationsystems> ;
    fdo:sampleSize "1K employees" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:216 ;
    dcat:landingPage "https://www.kaggle.com/datasets/pavansubhasht/ibm-hr-analytics-attrition-dataset"^^xsd:anyURI .

fdo:IIT-JEE a dcat:Dataset ;
    dcterms:creator "Indian Institute of Technology, Kharagpur"^^xsd:string ;
    dcterms:description "this dataset was released in response to a Right to Information application filed in June 2009, and contains country-wide results for the Joint Entrance Exam (EET) to Indian Institutes of Technology (IITs), a group of prestigious engineering schools in India. The dataset contains the marks obtained by every candidate who took the test in 2009, divided according to the specific Math, Physics, and Chemistry sections of the test. Demographics such as ZIP code, gender, and birth categories (ethnic categories relating to the caste system) are also included" ;
    dcterms:isReferencedBy "\\citet{celis2020interventions}" ;
    dcterms:issued "2009"^^xsd:gYear ;
    dcterms:modified "2009"^^xsd:gYear ;
    dcterms:publisher "Indian Institute of Technology, Kharagpur"^^xsd:string ;
    dcterms:title "IIT-JEE" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "400K students" ;
    fdo:sensitiveFeature "gender, birth category" ;
    fdo:task fdo:161 .

fdo:IJB-A a dcat:Dataset ;
    dcterms:creator "Noblis; National Institute of Standards and Technology (NIST); Intelligence Advanced Research Projects Activity (IARPA); Michigan State University"^^xsd:string ;
    dcterms:description "the IARPA Janus Benchmark A (IJB-A) dataset was proposed as a face recognition benchmark with wide geographic representation and pose variation for subjects. It consists of \\emph{in-the-wild} images and videos of 500 subjects, obtained through internet searches over Creative Commons licensed content. The subjects were manually specified by the creators of the dataset to ensure broad geographic representation. The tasks associated with the dataset are face identification and verification. The dataset curators also collected the subjects' skin color and gender, through an unspecified annotation procedure. Similar protected attributes (gender and Fitzpatrick skin type) were labelled by one author of \\citet{Buolamwini2018gender}" ;
    dcterms:isReferencedBy "\\citet{klare2015pushing}" ;
    dcterms:issued "2015"^^xsd:gYear ;
    dcterms:modified "2015"^^xsd:gYear ;
    dcterms:publisher "Noblis; National Institute of Standards and Technology (NIST); Intelligence Advanced Research Projects Activity (IARPA); Michigan State University"^^xsd:string ;
    dcterms:title "IJB-A" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "6K images of 500 subjects" ;
    fdo:sensitiveFeature "gender, skin color" ;
    fdo:task fdo:64 ;
    dcat:landingPage "https://www.nist.gov/itl/iad/image-group/ijb-dataset-request-form"^^xsd:anyURI .

fdo:ILEA a dcat:Dataset ;
    dcterms:creator "Inner London Education Authority (ILEA)"^^xsd:string ;
    dcterms:description "this dataset was created by the Inner London Education Authority (ILEA) considering data from 140 British schools. It comprises the results of public examinations taken by students of age 16 over the period 1985--1987. These values are used as a measurement of school effectiveness, with emphasis on quality of education and equality of opportunity for students of different backgrounds and ethnicities. Student-level records report their sex and ethnicity, while school-level factors include the percentage of students eligible for free meals and the percentage of girls in each institute" ;
    dcterms:isReferencedBy "\\citep{nuttall1989differential,goldstein1991multilevel}" ;
    dcterms:issued "unknown"^^xsd:gYear ;
    dcterms:modified "unknown"^^xsd:gYear ;
    dcterms:publisher "Inner London Education Authority (ILEA)"^^xsd:string ;
    dcterms:title "ILEA" ;
    dcterms:type "unknown"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "30K students from 140 secondary schools" ;
    fdo:sensitiveFeature "age, sex, ethnicity" ;
    fdo:task fdo:77 .

fdo:ImageEmbeddingAssociationTest_iEAT a dcat:Dataset ;
    dcterms:creator "Carnegie Mellon University; George Washington University"^^xsd:string ;
    dcterms:description "the Image Embedding Association Test (iEAT) is a resource for quantifying biased associations between representations of social concepts and attributes in images. It mimics seminal work on biases in WEs \\citep{caliksan2017semantics}, following the Implicit Association Test (IAT) from social psychology \\citep{greenwald1998measuring}. The curators identified several combinations of target concepts (e.g. young) and attributes (e.g. pleasant), testing similarities between representations of these concepts learnt  by unsupervised computer vision models. For each attribute/concept they obtained a set of images from the IAT, the CIFAR-100 dataset or Google Image Search, which act as the source of images and the associated sensitive attribute labels" ;
    dcterms:isReferencedBy "\\citet{steed2021image}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Carnegie Mellon University; George Washington University"^^xsd:string ;
    dcterms:title "Image Embedding Association Test (iEAT)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "200 image for 15 iEATs" ;
    fdo:sensitiveFeature "religion, gender, age, race, sexual orientation, disability, skin tone, weight" ;
    fdo:task fdo:180 ;
    dcat:landingPage "https://github.com/ryansteed/ieat/tree/master/data"^^xsd:anyURI .

fdo:ImageNet a dcat:Dataset ;
    dcterms:creator "Princeton University"^^xsd:string ;
    dcterms:description "Imagenet is one of the most influential machine learning dataset of the 2010s. Much important work on computer vision, including early breakthroughs in deep learning has been sparked by ImageNet Large Scale Visual Recognition Challenge (ILSVRC), a competition held yearly from 2010 to 2017. The most used portion of ImageNet is indeed the data powering the classification task in ILSVRC 2012, featuring 1,000 classes, over 100 of which represent different dog breeds.     Recently, several problematic biases were found in the \\texttt{person} subtree of ImageNet, tracing their causes and proposing approaches to remove them \\citep{prabhu2020large,yang2020towards,crawford2021excavating}" ;
    dcterms:isReferencedBy "\\citet{deng2009imagenet,barocas2019fair,prabhu2020large,yang2020towards,crawford2021excavating}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Princeton University"^^xsd:string ;
    dcterms:title "ImageNet" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "14M images depicting  20K categories (synsets)" ;
    fdo:sensitiveFeature "people's gender and other sensitive annotations may be present in synsets from the person subtree" ;
    fdo:task fdo:8 ;
    dcat:landingPage "https://image-net.org/"^^xsd:anyURI .

fdo:In-Situ a dcat:Dataset ;
    dcterms:creator "Twitter"^^xsd:string ;
    dcterms:description "this dataset was curated to measure biases in named entity recognition algorithms, based on gender, race and religion of people represented by entities. The authors exploit census data to build a list of 123 names typical of men and women of different race and religion. Next, they extract 289 sentences mentioning people from the  CoNLL 2003 NER test data \\citep{tjong-kim-sang2003:introduction}, itself derived from Reuters 1990s news stories. Finally, they substitute the unigram person entity from the CoNLL 2003 shared task with each of names obtained previously as specific to a demographic group" ;
    dcterms:isReferencedBy "\\citet{mishra2020assessing}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Twitter"^^xsd:string ;
    dcterms:title "In-Situ" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "50K sentences" ;
    fdo:sensitiveFeature "gender, race and religion" ;
    fdo:task fdo:145 ;
    dcat:landingPage "https://github.com/napsternxg/NER_bias"^^xsd:anyURI .

fdo:IndianCensus a dcat:Dataset ;
    dcterms:creator "Office of the Registrar General of India"^^xsd:string ;
    dcterms:description "very little information seems to be available on this dataset. It represents a count of residents of 35 Indian states, repeated every ten years between 1951 and 2001" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "unknown"^^xsd:gYear ;
    dcterms:modified "unknown"^^xsd:gYear ;
    dcterms:publisher "Office of the Registrar General of India"^^xsd:string ;
    dcterms:title "Indian Census" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:demography ;
    fdo:sampleSize "30 state" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:171 ;
    dcat:landingPage "https://www.indiabudget.gov.in/budget_archive/es2006-07/chapt2007/tab97.pdf"^^xsd:anyURI .

fdo:IndianStudentPerformance a dcat:Dataset ;
    dcterms:creator "Dibrugarh University; Sana’a University; Abdelmalek Essaâdi University"^^xsd:string ;
    dcterms:description "this dataset was curated to support educational data mining algorithms. The creators collected data from three colleges of Assam, India (Duliajan College, Doomdooma College, and Digboi College). Each data point represents a student, summarizing information on their demographics (gender, caste), family (occupation and qualification of parents), and school fruition (study hours, attendance, home-to-school travel). Among the latter there are four variables summarizing student performance in different classes and examinations, which represent the response variable of a prediction task" ;
    dcterms:isReferencedBy "\\citet{hussain2018educational}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Dibrugarh University; Sana’a University; Abdelmalek Essaâdi University"^^xsd:string ;
    dcterms:title "Indian Student Performance" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "300 students" ;
    fdo:sensitiveFeature "gender, caste, geography" ;
    fdo:task fdo:212 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/Student+Academics+Performance"^^xsd:anyURI .

fdo:InfantHealthandDevelopmentProgram_IHDP a dcat:Dataset ;
    dcterms:creator "unknown"^^xsd:string ;
    dcterms:description "this dataset is the result of the IHDP program carried out between 1985 and 1988 in the US. A longitudinal randomized trial was conducted to evaluate the effectiveness of comprehensive early intervention in reducing developmental and health problems in low birth weight premature infants. Families in the experimental group received an intervention based on an educational program delivered through home visits, a daily center-based program and a parent supporting group. Children in the study were assessed across multiple cognitive, behavioral, and health dimensions longitudinally in four phases at ages 3, 5, 8, and 18. The dataset also contains information on household composition, source of health care, parents' demographics and employment" ;
    dcterms:isReferencedBy "\\citet{brooks1992effects}" ;
    dcterms:issued "1993"^^xsd:gYear ;
    dcterms:modified "1993"^^xsd:gYear ;
    dcterms:publisher "unknown"^^xsd:string ;
    dcterms:title "Infant Health and Development Program (IHDP)" ;
    dcterms:type "mixture"^^rdf:PlainLiteral ;
    fdo:domain fdo:pediatrics ;
    fdo:sampleSize "1K infants" ;
    fdo:sensitiveFeature "race and ethnicity (of parents), age (maternal), gender (of infant)" ;
    fdo:task fdo:58 ;
    dcat:landingPage "https://www.icpsr.umich.edu/web/HMCA/studies/9795"^^xsd:anyURI .

fdo:InstagramPhotos a dcat:Dataset ;
    dcterms:creator "Columbia University"^^xsd:string ;
    dcterms:description "this dataset was crawled from Instagram to explore trade-offs between fairness and revenue in platforms that serve ads to their users. The authors crawled metadata from photos (location and tags) and users (names), using Kevin Systrom as a seed user and cascading into profiles that like or comment photos. The curators concentrated on cities with enough geotagged data, namely New York and Los Angeles. Moreover, they labeled the users with gender and race. Gender was labeled via US social security data, using the proportion of babies with a given name registered with either gender. Gender was only assigned to users with a first name for which there were both at least 50 births and 95\\% of recorded births were one gender. Race were labeled using the Face++ API on a subset of photos. Photos were not downloaded, rather they were fed to Face++ via their publicly available URL. Finally, the ground truth labels were validated by two research assistants. To emulate a location-based advertisement model, the creators devised a task aimed at predicting what topics a user will be interested in, given their locations from previous check-ins" ;
    dcterms:isReferencedBy "\\citet{riederer2017price}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Columbia University"^^xsd:string ;
    dcterms:title "Instagram Photos" ;
    dcterms:type "unknown"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "1M photos from 40K users" ;
    fdo:sensitiveFeature "race, gender, geography" ;
    fdo:task fdo:165 .

fdo:InternetAds a dcat:Dataset ;
    dcterms:creator "University College Dublin"^^xsd:string ;
    dcterms:description "this dataset was assembled to study the problem of automated advertisement removal in browsers. It consists of images crawled from randomly generated urls, manually classified as ad/no-ad. Image encodings are derived from raw html, thus containing no information about pixel values, but rather encoding width, height, anchor text and image source. The associated task is classifying each image encoding as an ad or a no-ad image" ;
    dcterms:isReferencedBy "\\citet{kushmerick1999learning}" ;
    dcterms:issued "1998"^^xsd:gYear ;
    dcterms:modified "1998"^^xsd:gYear ;
    dcterms:publisher "University College Dublin"^^xsd:string ;
    dcterms:title "Internet Ads" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:patternrecognition ;
    fdo:sampleSize "3K image encodings" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:211 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/internet+advertisements"^^xsd:anyURI .

fdo:Iris a dcat:Dataset ;
    dcterms:creator "Missouri Botanical Garden; Washington University"^^xsd:string ;
    dcterms:description "the most popular dataset on the UCI Machine Learning Repository was created by E. Anderson and popularized by R.A. Fisher in the pattern recognition community in the 1930s. The measurements in this collection represent the length and width of sepal and petals of different Iris flowers, collected to evaluate the morphological variation of different Iris species. The typical learning task associated with this dataset is labelling the species based on the available measurements" ;
    dcterms:isReferencedBy "\\citep{anderson1936species,fisher1936use}" ;
    dcterms:issued "1988"^^xsd:gYear ;
    dcterms:modified "1988"^^xsd:gYear ;
    dcterms:publisher "Missouri Botanical Garden; Washington University"^^xsd:string ;
    dcterms:title "Iris" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:plantscience ;
    fdo:sampleSize "100 samples from three species of Iris" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:12 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/iris"^^xsd:anyURI .

fdo:ItalianCarInsurance a dcat:Dataset ;
    dcterms:creator "University of Padua; Carnegie Mellon University; University of Udine"^^xsd:string ;
    dcterms:description "this resource was curated to study discriminatory practices in the Italian car insurance market. More specifically, the data was collected to estimate the direct effect of gender and birthplace on yearly quoted premiums. It was collected in 2020 from a popular Italian car insurance comparison website, where the curators tried different hypothetical driver profiles and collected the quotes provided by nine companies. Along with gender and birthplace, additional driver features include age, city of residence, insured vehicle, mileage, and a summary of claim history" ;
    dcterms:isReferencedBy "\\citet{fabris2021algorithmic}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "University of Padua; Carnegie Mellon University; University of Udine"^^xsd:string ;
    dcterms:title "Italian Car Insurance" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "2K driver profiles" ;
    fdo:sensitiveFeature "gender, birthplace" ;
    fdo:task fdo:213 .

fdo:KDDCup99 a dcat:Dataset ;
    dcterms:creator "Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:description "this dataset was developed for a data mining competition on cybersecurity, focused on building an automated network intrusion detector based on TCP dump data. The task is predicting whether a connection is legitimate and inoffensive or symptomatic of an attack, such as denial-of-service or user-to-root; tens of attack classes have been simulated and annotated within this dataset. The available features include basic TCP/IP information, network traffic and contextual features, such as number of failed login attempts" ;
    dcterms:isReferencedBy "\\citet{tavallaee2009detailed}" ;
    dcterms:issued "1999"^^xsd:gYear ;
    dcterms:modified "1999"^^xsd:gYear ;
    dcterms:publisher "Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:title "KDD Cup 99" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:computernetworks ;
    fdo:sampleSize "7M connections" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:131 ;
    dcat:landingPage "http://kdd.ics.uci.edu/databases/kddcup99/kddcup99.html"^^xsd:anyURI .

fdo:KidneyExchangeProgram a dcat:Dataset ;
    dcterms:creator "Université de Montréal; Polytechnique de Montréal"^^xsd:string ;
    dcterms:description "this dataset is based on data of the Canadian Kidney Paired Donation Program (KPD) to study strategic behavior among entities controlling part of the incompatible patient-donor pairs. Based on data from the Canadian Blood Services on the KPD and census, these instances were generated. The random instance generator is available upon request. The instances are weighted graphs. The incompatible patient-donor pairs represent the vertices of the graph, an arc means that the donor of a vertex is compatible with the patient of another vertex, and weights represent the benefit of the donation. Compatibility is encoded based on true blood type distribution and risk of transplant rejection" ;
    dcterms:isReferencedBy "\\citet{carvalho2019game}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Université de Montréal; Polytechnique de Montréal"^^xsd:string ;
    dcterms:title "Kidney Exchange Program" ;
    dcterms:type "patient-donor pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:publichealth ;
    fdo:sampleSize "180" ;
    fdo:sensitiveFeature "blood type, geography" ;
    fdo:task fdo:198 ;
    dcat:landingPage "https://github.com/mxmmargarida/KEG"^^xsd:anyURI .

fdo:KidneyMatching a dcat:Dataset ;
    dcterms:creator "unknown"^^xsd:string ;
    dcterms:description "this dataset was created via a simulator based on real data provided by the Organ and Tissue Authority of Australia. The data was validated against additional information from the Australian Bureau of Statistics, the Public and Research sets, and Wikipedia. The simulator models the probability distribution over the Blood Type and State of donors and patients, along with the quality of a donated organ (summarized by Kidney Donor Patient Index) and of a patient (quantified by the Expected Post-Transplant Survival). The envisioned task for this data is optimal matching of organs and patients" ;
    dcterms:isReferencedBy "\\citet{mattei2018axiomatic}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "unknown"^^xsd:string ;
    dcterms:title "Kidney Matching" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:publichealth ;
    fdo:sampleSize "unknown" ;
    fdo:sensitiveFeature "age, geography, blood type" ;
    fdo:task fdo:175 .

fdo:Kiva a dcat:Dataset ;
    dcterms:creator "Kiva; DePaul University"^^xsd:string ;
    dcterms:description "this dataset was obtained from \\url{kiva.org}, a non-profit organization allowing low-income entrepreneurs and students to borrow money through loan crowdfunding. The data summarizes all transactions occurred in 2017. Transactions are typically between 25\\$ to 50\\$ and range from 5\\$ to 10,000\\$. Features include information about the loan, such as its purpose, sector and amount, and data specific to the borrower and their demographics. Women are prevalent in this dataset, probably due to the priorities of partner organizations and the easier access to capital enjoyed by men in many countries" ;
    dcterms:isReferencedBy "\\citet{sonboli2019localized}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Kiva; DePaul University"^^xsd:string ;
    dcterms:title "Kiva" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "1M transactions involving 100K loans and 200K users" ;
    fdo:sensitiveFeature "gender, geography, activity" ;
    fdo:task fdo:61 .

fdo:LabeledFacesintheWild_LFW a dcat:Dataset ;
    dcterms:creator "University of Massachussets, Amherst; Stony Brook University"^^xsd:string ;
    dcterms:description "LFW is a public benchmark for face verification, maintained by researchers affiliated with the University of Massachusetts. It was built to measure the progress of face verification systems in unconstrained settings  (e.g. variable pose, illumination, resolution). The dataset consists of images of people who appeared in the news, labelled with the name of the respective individual. According to perception of human coders who were later asked to annotate this dataset, images mostly skew white, male and below 60" ;
    dcterms:isReferencedBy "\\citet{huang2007labeled,han2014age,gebru2018datasheets}" ;
    dcterms:issued "2007"^^xsd:gYear ;
    dcterms:modified "2007"^^xsd:gYear ;
    dcterms:publisher "University of Massachussets, Amherst; Stony Brook University"^^xsd:string ;
    dcterms:title "Labeled Faces in the Wild (LFW)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "13K face images of 6K individuals" ;
    fdo:sensitiveFeature "gender, age, race" ;
    fdo:task fdo:16 ;
    dcat:landingPage "http://vis-www.cs.umass.edu/lfw/"^^xsd:anyURI .

fdo:LargeMovieReview a dcat:Dataset ;
    dcterms:creator "Stanford University"^^xsd:string ;
    dcterms:description "a set of reviews from IMDB, collected, filtered and preprocessed by researchers affiliated with Stanford University. Polarity judgements are balanced in terms of positive and negative reviews and automatically inferred from star-based ratings, so that 7 or more is positive, while 4 or less is considered negative. The dataset was collected to provide a large benchmark for sentiment analysis algorithms" ;
    dcterms:isReferencedBy "\\citet{maas2011learning}" ;
    dcterms:issued "2011"^^xsd:gYear ;
    dcterms:modified "2011"^^xsd:gYear ;
    dcterms:publisher "Stanford University"^^xsd:string ;
    dcterms:title "Large Movie Review" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "50K reviews" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:51 ;
    dcat:landingPage "https://ai.stanford.edu/~amaas/data/sentiment/"^^xsd:anyURI .

fdo:Last.fm a dcat:Dataset ;
    dcterms:creator "Barcelona Music and Audio Technologies; Universitat Pompeu Fabra"^^xsd:string ;
    dcterms:description "the Last.fm datasets were collected via the Last.fm API with the purpose of studying music consumption, discovery and recommendation on the web. Two datasets are provided: LFM1K, comprising timestamped listening habits of a limited user sample ($\\sim$1K) at song granularity, and LFM360K, containing the top 50 most played artists of a wider user population ($\\sim$360K)" ;
    dcterms:isReferencedBy "\\citet{Celma:Springer2010}" ;
    dcterms:issued "2010"^^xsd:gYear ;
    dcterms:modified "2010"^^xsd:gYear ;
    dcterms:publisher "Barcelona Music and Audio Technologies; Universitat Pompeu Fabra"^^xsd:string ;
    dcterms:title "Last.fm" ;
    dcterms:type "user-song pairs (LFM1K); user-artist pairs (LFM360K)"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#music,informationsystems> ;
    fdo:sampleSize "19M timestamped records of 1K users playing songs from 170K artists (LFM1K); 20M play counts (user-artist pairs) for 400K users over 300K artists (LFM360K)" ;
    fdo:sensitiveFeature "user age, gender, geography; artist" ;
    fdo:task fdo:63 ;
    dcat:landingPage "http://ocelma.net/MusicRecommendationDataset/"^^xsd:anyURI .

fdo:LatinNewspapers a dcat:Dataset ;
    dcterms:creator "Capital One"^^xsd:string ;
    dcterms:description "this dataset was built to study gender bias in language models and their connection with the corpora they have been trained on. It was built crawling articles from the websites of three newspapers from Chile, Peru, and Mexico. More detailed information about this resource seems to be missing" ;
    dcterms:isReferencedBy "\\citet{florez2019unintended}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Capital One"^^xsd:string ;
    dcterms:title "Latin Newspapers" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:news ;
    fdo:sampleSize "60K articles" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:159 .

fdo:LawSchool a dcat:Dataset ;
    dcterms:creator "Law School Admission Council (LSAC)"^^xsd:string ;
    dcterms:description "This dataset was collected to study performance in law school and bar examination of minority examinees in connection with affirmative action programs established after 1967 and subsequent anecdotal reports suggesting low bar passage rates for black examinees. Students, law schools, and state boards of bar examiners contributed to this dataset. The study tracks students who entered law school in fall 1991 through three or more years of law school and up to five administrations of the bar examination. Variables include demographics of candidates (e.g. age, race, sex), their academic performance (undergraduate GPA, law school admission test, and GPA), personal condition (e.g. financial responsibility for others during law school)  along with information about law schools and bar exams (e.g. geographical area where it was taken). The associated task in machine learning is prediction of passage of the bar exam" ;
    dcterms:isReferencedBy "\\citet{wightman1998lsac}" ;
    dcterms:issued "1998"^^xsd:gYear ;
    dcterms:modified "1998"^^xsd:gYear ;
    dcterms:publisher "Law School Admission Council (LSAC)"^^xsd:string ;
    dcterms:title "Law School" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "20K examinees" ;
    fdo:sensitiveFeature "sex, race, age" ;
    fdo:task fdo:68 .

fdo:Libimseti a dcat:Dataset ;
    dcterms:creator "Charles University in Prague; Libimseti"^^xsd:string ;
    dcterms:description "this dataset was collected to explore the effectiveness of recommendations in online dating services based on collaborative filtering. It was collected in collaboration with employees of the dating platform libimseti.cz, one of the largest Czech dating websites at the time. The data consists of anonymous ratings provided by (and to) users of the web service on a 10-point scale" ;
    dcterms:isReferencedBy "\\citet{brozovsky2006recommender,brozovsky2007recommender}" ;
    dcterms:issued "2007"^^xsd:gYear ;
    dcterms:modified "2007"^^xsd:gYear ;
    dcterms:publisher "Charles University in Prague; Libimseti"^^xsd:string ;
    dcterms:title "Libimseti" ;
    dcterms:type "user-user pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#sociology,informationsystems> ;
    fdo:sampleSize "10M ratings over 200K users" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:91 ;
    dcat:landingPage "http://colfi.wz.cz/"^^xsd:anyURI .

<http://www.fairnessdata.dei.unipd.it/ontology#LosAngelesCityAttorney’sOfficeRecords> a dcat:Dataset ;
    dcterms:creator "Los Angeles City Attorney’s Office; University of Chicago"^^xsd:string ;
    dcterms:description "this dataset was extracted from the Los Angeles City Attorney’s case management system. It consists of a collection of records aimed at powering data-driven approaches to decision making and resource allocation for misdemeanour recidivism reduction via individually tailored social service interventions. Focusing on cases handled by the office between 1995--2017, the data includes information about jail bookings, charges, court appearances, outcomes, and demographics" ;
    dcterms:isReferencedBy "\\citep{rodolfa2020case}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Los Angeles City Attorney’s Office; University of Chicago"^^xsd:string ;
    dcterms:title "Los Angeles City Attorney’s Office Records" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "1M unique individuals associated with 2M cases" ;
    fdo:sensitiveFeature "race, ethnicity" ;
    fdo:task fdo:181 .

fdo:MEPS-HC a dcat:Dataset ;
    dcterms:creator "Agency for Healthcare Research and Quality"^^xsd:string ;
    dcterms:description "the Medical Expenditure Panel Survey (MEPS) data is collected by the US Department of Health and Human Services, to survey healthcare spending and utilization by US citizens.  Overall, this is a set of large-scale surveys of families and individuals, their employers, and medical providers (e.g. doctors, hospitals, pharmacies). The Household Component (HC) focuses on households and individuals, who provide information about their demographics, medical conditions and expenses, health insurance coverage, and access to care. Individuals included in a panel undergo five rounds of interviews over two years. Healthcare expenditure is often regarded as a target variable in machine learning applications, where it has been used as a proxy for healthcare utilization, with the goal of identifying patients in need" ;
    dcterms:isReferencedBy "\\url{https://www.ahrq.gov/data/meps.html}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Agency for Healthcare Research and Quality"^^xsd:string ;
    dcterms:title "MEPS-HC" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:healthpolicy ;
    fdo:sampleSize "30K, variable on a yearly basis" ;
    fdo:sensitiveFeature "gender, ethnicity, age" ;
    fdo:task fdo:5 ;
    dcat:landingPage "https://meps.ahrq.gov/mepsweb/data_stats/download_data_files.jsp"^^xsd:anyURI .

fdo:MGGGStates a dcat:Dataset ;
    dcterms:creator "Tufts University"^^xsd:string ;
    dcterms:description "developed by the Metric Geometry and Gerrymandering Group\\footnote{\\url{https://mggg.org/}}, this dataset contains precinct-level aggregated information about demographics and political leaning of voters in each district. The data hinges on several distinct sources of data, including GIS mapping files from the US Census. Bureau\\footnote{\\url{https://www.census.gov/geographies/mapping-files.html}}, demographic data from IPUMS\\footnote{\\url{https://www.nhgis.org/}} and election data from MIT Election and Data Science \\footnote{\\url{https://electionlab.mit.edu/}}. Source and precise data format vary by state" ;
    dcterms:isReferencedBy "\\url{https://mggg.org/}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Tufts University"^^xsd:string ;
    dcterms:title "MGGG States" ;
    dcterms:type "mixture"^^rdf:PlainLiteral ;
    fdo:domain fdo:politicalscience ;
    fdo:sampleSize "variable number of precincts (thousands) per state" ;
    fdo:sensitiveFeature "race, political affiliation (representation in different precincts)" ;
    fdo:task fdo:18 ;
    dcat:landingPage "https://github.com/mggg-states"^^xsd:anyURI .

fdo:MIMIC-CXR-JPG a dcat:Dataset ;
    dcterms:creator "Massachusetts Institute of Technology; Beth Israel Deaconess Medical Center; Stanford University; Harvard Medical School; National Library of Medicine"^^xsd:string ;
    dcterms:description "this dataset was curated to encourage research in medical computer vision. It consists of  chest x-rays sourced from the Beth Israel Deaconess Medical Center between 2011--2016. Each image is tagged with one or more of fourteen labels, derived from the corresponding free-text radiology reports via natural language processing tools. A subset of 687 report-label pairs have been validated by a board of certified radiologists with 8 years of experience" ;
    dcterms:isReferencedBy "\\citep{johnson2019mimic}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Massachusetts Institute of Technology; Beth Israel Deaconess Medical Center; Stanford University; Harvard Medical School; National Library of Medicine"^^xsd:string ;
    dcterms:title "MIMIC-CXR-JPG" ;
    dcterms:type "images"^^rdf:PlainLiteral ;
    fdo:domain fdo:radiology ;
    fdo:sampleSize "400K images of 70K patients" ;
    fdo:sensitiveFeature "sex" ;
    fdo:task fdo:179 ;
    dcat:landingPage "https://physionet.org/content/mimic-cxr-jpg/2.0.0/"^^xsd:anyURI .

fdo:MIMIC-III a dcat:Dataset ;
    dcterms:creator "Massachusetts Institute of Technology; Beth Israel Deaconess Medical Center; A*STAR"^^xsd:string ;
    dcterms:description "this dataset was extracted from a database of patients admitted to critical care units at the Beth Israel Deaconess Medical Center in Boston (MA), following the widespread adoption of digital health records in US hospitals. Data comprises vital signs, medications, laboratory measurements, notes and observations by care providers, fluid balance, procedure codes, diagnostic codes, imaging reports, length of stay, survival data, and demographics. The dataset spans over a decade of intensive care unit stays for adult and neonatal patients" ;
    dcterms:isReferencedBy "\\citet{johnson2016mimiciii}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Massachusetts Institute of Technology; Beth Israel Deaconess Medical Center; A*STAR"^^xsd:string ;
    dcterms:title "MIMIC-III" ;
    dcterms:type "mixture"^^rdf:PlainLiteral ;
    fdo:domain fdo:criticalcaremedicine ;
    fdo:sampleSize " 60K patients" ;
    fdo:sensitiveFeature "age, ethnicity, gender" ;
    fdo:task fdo:95 ;
    dcat:landingPage "https://mimic.mit.edu/"^^xsd:anyURI .

fdo:MLFairnessGym a dcat:Dataset ;
    dcterms:creator "Google"^^xsd:string ;
    dcterms:description "this resource was developed to study the long-term behaviour and emergent properties of fair ML systems. It is an extension of OpenAI Gym \\citep{brockman2016openai}, simulating the actions of agents within environments as Markov Decision Processes. As of 2021, four environments have been released. (1) \\emph{Lending} emulates the decisions of a bank, based on perceived credit-worthiness of individuals, which is distributed according to an artificial sensitive feature. (2) \\emph{Attention allocation} concentrates on agents tasked with monitoring sites for incidents. (3) \\emph{College admission} relates to sequential game theory, where agents represent colleges and environments contain students capable of strategically manipulating their features at different costs, for instance through preparation courses. (4) \\emph{Infectious disease} models the problem of vaccine allocation and its long-term consequences on people in different demographic groups" ;
    dcterms:isReferencedBy "\\citet{damour2020fairness}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Google"^^xsd:string ;
    dcterms:title "ML Fairness Gym" ;
    dcterms:type "time series"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#N/A> ;
    fdo:sampleSize "variable" ;
    fdo:sensitiveFeature "synthetic" ;
    fdo:task fdo:49 ;
    dcat:landingPage "https://github.com/google/ml-fairness-gym"^^xsd:anyURI .

fdo:MNIST a dcat:Dataset ;
    dcterms:creator "AT\\&T Labs"^^xsd:string ;
    dcterms:description "one of the most famous resources in computer vision, this dataset was created from an earlier database released by the National Institute of Standards and Technology (NIST). It consists of hand-written digits collected among high-school students and Census Bureau employees, which have to be correctly labelled by image processing systems. Several augmentations have also been used in the fairness literature, discussed at the end of this section" ;
    dcterms:isReferencedBy "\\citet{lecun1998gradientbased,barocas2019fair}" ;
    dcterms:issued "1998"^^xsd:gYear ;
    dcterms:modified "1998"^^xsd:gYear ;
    dcterms:publisher "AT\\&T Labs"^^xsd:string ;
    dcterms:title "MNIST" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "70K images across 10 digits" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:19 ;
    fdo:variant """\\begin{itemize}
        \\item MNIST-USPS \\citep{li2020deep}: merge with USPS dataset of handwritten digits \\citep{hull1994:database}.
        \\item Color-reverse MNIST \\citep{li2020deep} or MNIST-Invert \\citep{zhang2021towards}: images from MNIST, reversed via $p=255-p$ for each pixel $p$.
        \\item Color MNIST \\citep{arjovsky2020invariant}: images from MNIST colored red or green based on class label.
        \\item C-MNIST: images from MNIST, such that both digits and background are colored.
    \\end{itemize}""" ;
    dcat:landingPage "http://yann.lecun.com/exdb/mnist/"^^xsd:anyURI .

fdo:MS-COCO a dcat:Dataset ;
    dcterms:creator "Cornell University;  Toyota Technological Institute; Facebook; Microsoft; Brown University;  California Institute of Technology; University of California at Irvine"^^xsd:string ;
    dcterms:description "this dataset was created with the goal of improving the state of the art in object recognition. The dataset consists of over 300,000 labeled images collected from Flickr.  Each image was annotated based on whether it contains one or more of the 91 object types proposed by the authors. Segmentations are also provided to indicate the region where objects are located in each image. Finally, five human-generated captions are provided for each image. Annotation, segmentation and captioning were performed by human annotators hired on Amazon Mechanical Turk. A subset of the images depicting people have been  augmented with gender labels ``man'' and ``woman'' based on whether captions mention one word but not the other \\citep{zhao2017men,hendricks2018women}" ;
    dcterms:isReferencedBy "\\citet{lin2014microsoft}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "Cornell University;  Toyota Technological Institute; Facebook; Microsoft; Brown University;  California Institute of Technology; University of California at Irvine"^^xsd:string ;
    dcterms:title "MS-COCO" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "300K images" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:164 ;
    dcat:landingPage "https://cocodataset.org/"^^xsd:anyURI .

fdo:MS-Celeb-1M a dcat:Dataset ;
    dcterms:creator "Microsoft"^^xsd:string ;
    dcterms:description "this dataset was created as a large scale public benchmark for face recognition. The creators cover a wide range of countries and emphasizes diversity echoing outdated notions of race: ``We cover all the major races in the world (Caucasian, Mongoloid, and Negroid)'' \\citep{guo2016msceleb1m}.  While (in theory) containing only images of celebrities, the dataset was found to feature people who simply must maintain an online presence, and was retracted for this reason. Despite termination of the hosting website, the dataset is still searched for, available and used to build new fairness datasets, such as RFW (\\autoref{sec:rfw}) and BUPT Faces (\\autoref{sec:bupt}). The dataset was recently augmented with gender and nationality data automatically inferred from biographies of people \\citep{mcduff2019characterizing}. From nationality, a race-related attribute was also annotated on a subset of 20,000 images" ;
    dcterms:isReferencedBy "\\citet{guo2016msceleb1m,mcduff2019characterizing,murgia2019microsoft}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Microsoft"^^xsd:string ;
    dcterms:title "MS-Celeb-1M" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "10M images representing 100K people" ;
    fdo:sensitiveFeature "gender, race, geography" ;
    fdo:task fdo:90 .

fdo:MicrosoftLearningtoRank a dcat:Dataset ;
    dcterms:creator "Microsoft"^^xsd:string ;
    dcterms:description "this dataset was released to spur advances in learning to rank algorithms, capable of producing a list of documents in response to a text query, ranked according to their relevance for the query. The dataset contains relevance judgements for query-document pairs, obtained ``from a retired labeling set'' of the Bing search engine. Over 100 numerical features are provided for each query-document pair, summarizing the salient lexical properties of the pair and the quality of the webpage, including its page rank" ;
    dcterms:isReferencedBy "\\citep{qin2013introducing}" ;
    dcterms:issued "2013"^^xsd:gYear ;
    dcterms:modified "2013"^^xsd:gYear ;
    dcterms:publisher "Microsoft"^^xsd:string ;
    dcterms:title "Microsoft Learning to Rank" ;
    dcterms:type "query document pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "30K queries" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:108 ;
    dcat:landingPage "https://www.microsoft.com/en-us/research/project/mslr/"^^xsd:anyURI .

fdo:MillionPlaylistDataset_MPD a dcat:Dataset ;
    dcterms:creator "Spotify; Johannes Kepler University; University of Massachusetts"^^xsd:string ;
    dcterms:description "this dataset powered the 2018 RecSys Challenge on automatic playlist continuation. It consists of a sample of public Spotify playlists created by US Spotify users between 2010--2017. Each playlist consists of a title, track list and additional metadata. For each track, MPD provides the title, artist, album, duration and Spotify pointers. User data is anonymized. The dataset was augmented with record label information crawled from the web \\citep{knees2019towards}" ;
    dcterms:isReferencedBy "\\citet{chen2018recsys}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Spotify; Johannes Kepler University; University of Massachusetts"^^xsd:string ;
    dcterms:title "Million Playlist Dataset (MPD)" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#music,informationsystems> ;
    fdo:sampleSize "1M playlists containing 2M unique tracks by 300K artists" ;
    fdo:sensitiveFeature "artist, record label" ;
    fdo:task fdo:199 ;
    dcat:landingPage "https://www.aicrowd.com/challenges/spotify-million-playlist-dataset-challenge"^^xsd:anyURI .

fdo:MillionSongDataset_MSD a dcat:Dataset ;
    dcterms:creator "Columbia University; The Echo Nest"^^xsd:string ;
    dcterms:description "this dataset was created as a large-scale benchmark for algorithms in the musical domain. Song data was acquired through The Echo Nest API, capturing a wide array of information about the song (duration, loudness, key, tempo, etc.) and the artist (name, id, location, etc.). In total the dataset creators retrieved one million songs, and for each song 55 fields are provided as metadata. This dataset also powers the Million Song Dataset Challenge, integrating the MSD with implicit feedback from taste profiles gather from an undisclosed set of applications" ;
    dcterms:isReferencedBy "\\citet{bertinmahieux2011million,mcfee2012milllion}" ;
    dcterms:issued "2012"^^xsd:gYear ;
    dcterms:modified "2012"^^xsd:gYear ;
    dcterms:publisher "Columbia University; The Echo Nest"^^xsd:string ;
    dcterms:title "Million Song Dataset (MSD)" ;
    dcterms:type "user-song pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#music,informationsystems> ;
    fdo:sampleSize "50M play counts over 1M users and 400K songs" ;
    fdo:sensitiveFeature "artist; geography" ;
    fdo:task fdo:160 ;
    dcat:landingPage "http://millionsongdataset.com/"^^xsd:anyURI,
        "https://www.kaggle.com/c/msdchallenge"^^xsd:anyURI .

fdo:MobileMoneyLoans a dcat:Dataset ;
    dcterms:creator "unknown"^^xsd:string ;
    dcterms:description "this dataset captures the ongoing collaboration between some banks and mobile network operators in East Africa. Phone data, including mobile money transactions, is used as ``soft'' financial data to create a credit score. Mobile money (bank-less) transactions represent a low-barrier tool for the financial inclusion of the poor and are fairly popular in some African countries" ;
    dcterms:isReferencedBy "\\citet{speakman2018:three}" ;
    dcterms:issued "unknown"^^xsd:gYear ;
    dcterms:modified "unknown"^^xsd:gYear ;
    dcterms:publisher "unknown"^^xsd:string ;
    dcterms:title "Mobile Money Loans" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "200K people" ;
    fdo:sensitiveFeature "age, gender" ;
    fdo:task fdo:6 .

fdo:MovieLens a dcat:Dataset ;
    dcterms:creator "University of Minnesota"^^xsd:string ;
    dcterms:description "first released in 1998, MovieLens datasets represent user ratings from the movie recommender platform run by the GroupLens research group from the University of Minnesota. While different datasets have been released by GroupLens, in this section we concentrate on MovieLens 1M, the one predominantly used in fairness research. User-system interactions take the form of a quadruple (UserID, MovieID, Rating, Timestamp), with ratings expressed on a 1-5 star scale. The dataset also reports user demographics such as age and gender, which is voluntarily provided by the users" ;
    dcterms:isReferencedBy "\\citet{harper2015movielens}" ;
    dcterms:issued "2003"^^xsd:gYear ;
    dcterms:modified "2003"^^xsd:gYear ;
    dcterms:publisher "University of Minnesota"^^xsd:string ;
    dcterms:title "MovieLens" ;
    dcterms:type "user-movie pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#informationsystems,movies> ;
    fdo:sampleSize "1M reviews by 6K users over 4K movies" ;
    fdo:sensitiveFeature "gender, age" ;
    fdo:task fdo:71 ;
    dcat:landingPage "https://grouplens.org/datasets/movielens/1m/"^^xsd:anyURI .

fdo:Multi-taskFacialLandmark_MTFL a dcat:Dataset ;
    dcterms:creator "The Chinese University of Hong Kong"^^xsd:string ;
    dcterms:description "this dataset was developed to evaluate the effectiveness of multi-task learning in problems of facial landmark detection. The dataset builds upon an existing collection of outdoor face images sourced from the web already labelled with bounding boxes and landmarks \\citep{yi2013deep}, by annotating whether subjects are smiling or wearing glasses, along with their gender and pose. These annotations, whose provenance is not documented, allow researchers to define additional classification tasks for their multi-task learning pipeline" ;
    dcterms:isReferencedBy "\\citet{zhang2014facial,zhang2015learning}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "The Chinese University of Hong Kong"^^xsd:string ;
    dcterms:title "Multi-task Facial Landmark (MTFL)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "10K images" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:119 ;
    dcat:landingPage "http://mmlab.ie.cuhk.edu.hk/projects/TCDCN.html"^^xsd:anyURI .

fdo:NYCTaxiTrips a dcat:Dataset ;
    dcterms:creator "University of Illinois"^^xsd:string ;
    dcterms:description "this dataset was collected through a Freedom of Information Law request from the NYC Taxi and Limousine Commission. Data points represent New York taxi trips over 4 years (2010--2013), complete with spatio-temporal data, trip duration, number of passengers, and cost. Reportedly, the dataset contains a large number of errors, including misreported trip distance, duration, and GPS coordinates. Overall, these errors account for 7\\% of all trips in the dataset" ;
    dcterms:isReferencedBy "\\url{https://bit.ly/3yrT8jt}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "University of Illinois"^^xsd:string ;
    dcterms:title "NYC Taxi Trips" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:transportation ;
    fdo:sampleSize "700M taxi trips" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:13 ;
    fdo:variant "a similar, smaller dataset was obtained by Chris Whong from the NYC Taxi and Limousine Commission under the Freedom of Information Law.\\footnote{\\url{http://www.andresmh.com/nyctaxitrips/}}" ;
    dcat:landingPage "https://experts.illinois.edu/en/datasets/new-york-city-taxi-trip-data-2010-2013-2"^^xsd:anyURI .

fdo:NationalLongitudinalSurveyofYouth a dcat:Dataset ;
    dcterms:creator "US Bureau of Labor Statistics"^^xsd:string ;
    dcterms:description "the National Longitudinal Surveys from the US Bureau of Labor Statistics follow the lives of representative samples of US citizens, focusing on their labor market activities and other significant life events. Subjects periodically provide responses to questions about their education, employment, housing, income, health, and more. Two different cohorts were started in 1979 (NLSY79) and (NLSY97), which have been associated with machine learning tasks of income prediction and GPA prediction respectively" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "US Bureau of Labor Statistics"^^xsd:string ;
    dcterms:title "National Longitudinal Survey of Youth" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:demography ;
    fdo:sampleSize "10K respondents (NLSY79); 9K respondents (NLSY97)" ;
    fdo:sensitiveFeature "age, race, sex" ;
    fdo:task fdo:74 ;
    dcat:landingPage "https://www.bls.gov/nls/nlsy79.htm"^^xsd:anyURI,
        "https://www.bls.gov/nls/nlsy97.htm"^^xsd:anyURI .

fdo:NationalLungScreeningTrial_NLST a dcat:Dataset ;
    dcterms:creator "National Cancer Institute's Division of Cancer Prevention, Division of Cancer Treatment and Diagnosis"^^xsd:string ;
    dcterms:description "the NLST was a randomized controlled trial aimed at understanding whether imaging through low-dose helical computed tomography reduces lung cancer mortality relative to chest radiography. Participants were recruited at 33 screening centers across the US, among subjects deemed at risk of lung cancer based on age and smoking history, and were made aware of the trial. A breadth of features about participants is available, including demographics, disease history, smoking history, family history of lung cancer, type, and results of screening exams" ;
    dcterms:isReferencedBy "\\citet{national2011national}; \\url{https://www.cancer.gov/types/lung/research/nlst}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "National Cancer Institute's Division of Cancer Prevention, Division of Cancer Treatment and Diagnosis"^^xsd:string ;
    dcterms:title "National Lung Screening Trial (NLST)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:radiology ;
    fdo:sampleSize "50K participants" ;
    fdo:sensitiveFeature "age, ethnicity, race, sex" ;
    fdo:task fdo:135 ;
    dcat:landingPage "https://cdas.cancer.gov/nlst/"^^xsd:anyURI .

fdo:NewYorkTimesAnnotatedCorpus a dcat:Dataset ;
    dcterms:creator "The New York Times"^^xsd:string ;
    dcterms:description "this corpus contains nearly two million articles published in The New York Times over the period 1987--2007. For some articles, annotations by library scientists are available, including topics, mentioned entities, and summaries. The data is provided in News Industry Text Format (NITF)" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "2008"^^xsd:gYear ;
    dcterms:modified "2008"^^xsd:gYear ;
    dcterms:publisher "The New York Times"^^xsd:string ;
    dcterms:title "New York Times Annotated Corpus" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:news ;
    fdo:sampleSize "2M articles" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:195 ;
    dcat:landingPage "https://catalog.ldc.upenn.edu/LDC2008T19"^^xsd:anyURI .

fdo:NomineesCorpus a dcat:Dataset ;
    dcterms:creator "University of Amsterdam"^^xsd:string ;
    dcterms:description "this corpus was curated to study gender-related differences in literary production, with attention to perception of quality. It consists of fifty Dutch-language fiction novels nominated for either the AKO Literatuurprijs(shortlist) or the Libris Literatuur Prijs (longlist) in the period 2007--2012. The corpus was curated to control for nominee gender and country of origin. Word counts, LIWC counts, and metadata for this dataset are available at \\url{http://dx.doi.org/10.17632/tmp32v54ss.2}" ;
    dcterms:isReferencedBy "\\citet{koolen2017:stereotypes,koolen2018reading}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "University of Amsterdam"^^xsd:string ;
    dcterms:title "Nominees Corpus" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:literature ;
    fdo:sampleSize "50 novels" ;
    fdo:sensitiveFeature "gender, geography (of author)" ;
    fdo:task fdo:201 .

fdo:NorthCarolinaVoters a dcat:Dataset ;
    dcterms:creator "North Carolina State Board of Elections"^^xsd:string ;
    dcterms:description "US voter data is collected, curated, and maintained for multiple reasons. Data about voters in North Carolina is collected publicly as part of voter registration requirements and also privately. Private companies curating these datasets sell voter data as part of products, which include outreach lists and analytics. These datasets include voters' full names, address, demographics, and party affiliation" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "North Carolina State Board of Elections"^^xsd:string ;
    dcterms:title "North Carolina Voters" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:politicalscience ;
    fdo:sampleSize "8M voters" ;
    fdo:sensitiveFeature "race, ethnicity, age, geography" ;
    fdo:task fdo:14 ;
    fdo:variant "a privately curated version of this dataset is maintained by L2.\\footnote{\\url{https://l2-data.com/states/north-carolina/}}" ;
    dcat:landingPage "https://www.ncsbe.gov/results-data/voter-registration-data"^^xsd:anyURI .

fdo:Nursery a dcat:Dataset ;
    dcterms:creator "University of Maribor; Jožef Stefan Institute; University of Ljubljana; Center for Public Enterprises in Developing Countries"^^xsd:string ;
    dcterms:description "this dataset encodes applications for a nursery school in Ljubljana, Slovenia. To favour transparent and objective decision-making, a computer-based decision support system was developed for the selection and ranking of applications. The target variable reported is thus the output of an expert systems based on a set of rules, taking as an input information about the family, including housing, occupation and financial status, included in the dataset. The variables were reportedly constructed in a careful manner, taking into account laws that were in force at that time and following advice given by leading experts in that field. However, the variables also appear to be coded rather subjectively. For example, the variable \\emph{social condition} admits as a value \\emph{Slightly problematic}, allegedly reserved for ``When education ability of parents is low (unequal, inconsistent education, exaggerated pretentiousness or indulgence, neurotic reactions of parents), or there are improper relations in family (easier forms of parental personality disturbances, privileged or ignored children, conflicts in the family)''. Given that the true map between inputs and outputs is known, this resource is mostly useful to evaluate methods of structure discovery" ;
    dcterms:isReferencedBy "\\citet{olave1989application}" ;
    dcterms:issued "1997"^^xsd:gYear ;
    dcterms:modified "1997"^^xsd:gYear ;
    dcterms:publisher "University of Maribor; Jožef Stefan Institute; University of Ljubljana; Center for Public Enterprises in Developing Countries"^^xsd:string ;
    dcterms:title "Nursery" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "10K combinations of input data (hypothetical applicants)" ;
    fdo:sensitiveFeature "family wealth" ;
    fdo:task fdo:80 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/nursery"^^xsd:anyURI .

fdo:OccupationsinGoogleImages a dcat:Dataset ;
    dcterms:creator "Yale Universiy"^^xsd:string ;
    dcterms:description "this dataset was collected to study gender and skin tone diversity in image search results for jobs, and its relation with gender and race conentration in different professions. The dataset consists of the top 100 results for 96 occupations from  Google Image Search, collected in December 2019. The creators hired workers on  Amazon Mechanical Turk to label the gender (male, female) and Fitzpatrick skin tone (Type 1--6) of the primary person in each image, adding ``Not applicable'' and ``Cannot determine'' as possible options. Three labels were collected for each image, to which the majority label was assigned where possible" ;
    dcterms:isReferencedBy "\\citet{celis2020implicit}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Yale Universiy"^^xsd:string ;
    dcterms:title "Occupations in Google Images" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "10K images of 100 occupations" ;
    fdo:sensitiveFeature "gender, skin tone (inferred)" ;
    fdo:task fdo:30 ;
    dcat:landingPage "https://drive.google.com/drive/u/0/folders/1j9I5ESc-7NRCZ-zSD0C6LHjeNp42RjkJ"^^xsd:anyURI .

fdo:Office31 a dcat:Dataset ;
    dcterms:creator "University of California, Berkeley"^^xsd:string ;
    dcterms:description "this dataset was curated to support domain adaptation algorithms for computer vision systems. It features images of 31 different office tools (e.g. chair, keyboard, printer) from 3 different domains: listings on Amazon, high quality camera images, low quality webcam shots" ;
    dcterms:isReferencedBy "\\citet{saenko2010adapting}" ;
    dcterms:issued "2011"^^xsd:gYear ;
    dcterms:modified "2011"^^xsd:gYear ;
    dcterms:publisher "University of California, Berkeley"^^xsd:string ;
    dcterms:title "Office31" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "4K images" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:120 ;
    dcat:landingPage "https://paperswithcode.com/dataset/office-31"^^xsd:anyURI .

fdo:OlympicAthletes a dcat:Dataset ;
    dcterms:creator "unknown"^^xsd:string ;
    dcterms:description "this is a historical sports-related dataset on the modern Olympic Games from their first edition in 1896 to the 2016 Rio Games. The dataset was consolidated by Randi H Griffin utilizing SportsReference as the primary source of information. For each athlete, the dataset comprises demographics, height, weight, competition, and medal" ;
    dcterms:isReferencedBy "\\url{https://www.sports-reference.com/}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "unknown"^^xsd:string ;
    dcterms:title "Olympic Athletes" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:sports ;
    fdo:sampleSize "300K athletes" ;
    fdo:sensitiveFeature "sex, age" ;
    fdo:task fdo:62 ;
    dcat:landingPage "https://www.kaggle.com/heesoo37/120-years-of-olympic-history-athletes-and-results"^^xsd:anyURI .

fdo:Omniglot a dcat:Dataset ;
    dcterms:creator "New York University; University of Toronto; Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:description "this dataset was designed to study the problem of automatically learning basic visual concepts. It consists of handwritten characters from different alphabets drawn online via Amazon Mechanical Turk by 20 different people" ;
    dcterms:isReferencedBy "\\citet{lake2015humanlevel}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "New York University; University of Toronto; Massachusetts Institute of Technology"^^xsd:string ;
    dcterms:title "Omniglot" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "2K images  from 50 different alphabets" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:118 ;
    dcat:landingPage "https://github.com/brendenlake/omniglot"^^xsd:anyURI .

fdo:Onebillionwordbenchmark a dcat:Dataset ;
    dcterms:creator "Google; University of Edinburgh; Cantab Research Ltd"^^xsd:string ;
    dcterms:description "this dataset was proposed in 2014 as a benchmark for language models. The authors sourced English textual data from the EMNLP 6th workshop on Statistical Machine Translation\\footnote{\\url{http://statmt.org/wmt11/training-monolingual.tgz}}, more specifically the Monolingual language model training data, comprising a news crawl from 2007--2011 and data from the European Parliament website. Preprocessing includes removal of duplicate sentences, rare words (appearing less than 3 times) and mapping out-of-vocabulary words to the \\texttt{$<$UNK$>$} token. The ELMo contextualized WEs \\citep{peters2018:deep} were trained on this benchmark" ;
    dcterms:isReferencedBy "\\citet{chelba2014billion}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "Google; University of Edinburgh; Cantab Research Ltd"^^xsd:string ;
    dcterms:title "One billion word benchmark" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "800M words" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:87 ;
    dcat:landingPage "https://opensource.google/projects/lm-benchmark"^^xsd:anyURI .

fdo:OnlineFreelanceMarketplaces a dcat:Dataset ;
    dcterms:creator "Northeastern University, GESIS Leibniz Institute for the Social Sciences, University of Koblenz-Landau, ETH Zürich"^^xsd:string ;
    dcterms:description "this dataset was created to audit racial and gender biases on TaskRabbit and Fiverr, two popular online freelancing marketplaces. The dataset was built by crawling workers' profiles from both websites, including metadata, activities, and past job reviews. Profiles were later annotated with perceived demographics (gender and race) by Amazon Mechanical Turk based on profile images. On TaskRabbit, the authors executed search queries for all task categories in the 10 largest cities where the service is available, logging workers' ranking in search results. On Fiverr,  they concentrated on 9 tasks of diverse nature. The total number of queries that were issued on each platform, resulting in as many search result pages, is not explicitly stated" ;
    dcterms:isReferencedBy "\\citet{hannak2017bias}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Northeastern University, GESIS Leibniz Institute for the Social Sciences, University of Koblenz-Landau, ETH Zürich"^^xsd:string ;
    dcterms:title "Online Freelance Marketplaces" ;
    dcterms:type "query-result pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "10K workers (Fiverr); 4K (TaskRabbit)" ;
    fdo:sensitiveFeature "gender, race" ;
    fdo:task fdo:167 .

fdo:OpenImagesDataset a dcat:Dataset ;
    dcterms:creator "Google"^^xsd:string ;
    dcterms:description """this dataset was curated to improve and measure the performance of computer vision algorithms. Images with CC-BY license were downloaded from Flickr, and further filtered to remove near-duplicates, inappropriate content, and images appearing elsewhere in the internet. Different versions of this dataset were released, progressively adding a wealth of information on these images, including labels, bounding boxes, segmentation masks, visual relationships, and localized narratives. Bounding boxes relate to 600 classes, including ``person'', which admits ``girl'', ``boy'', ``woman'', and ``man'' as a subclass. %Labels were generated automatically and later verified by humans with majority voting, with a variable annotator pool size depending on the estimated complexity of verifying each label.
    Image-level labels are generated automatically and verified by humans, resulting in annotations for a subset of present and absent classes (positive and negative image-level labels). Based on the positive image-level labels, spatial annotations are produced by human annotators: bounding boxes \\citep{kuznetsova2020open}, visual relationships \\citep{kuznetsova2020open}, and validation+test segmentations are drawn fully manually \\citep{benenson2019large}; while segmentations in train are drawn using an interactive algorithm \\citep{benenson2019large}. Further, independent of any other annotations, rich localized dense image captions are collected by asking humans to provide detailed free-from image descriptions while they hover the mouse over the regions they describe (Localized Narratives \\citep{pont2020connecting})""" ;
    dcterms:isReferencedBy "\\citep{kuznetsova2020open,schumann2021step,benenson2019large,pont2020connecting}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Google"^^xsd:string ;
    dcterms:title "Open Images Dataset" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "9M images" ;
    fdo:sensitiveFeature "gender, age" ;
    fdo:task fdo:218 ;
    dcat:landingPage "https://storage.googleapis.com/openimages/web/index.html"^^xsd:anyURI .

fdo:PP-Pathways a dcat:Dataset ;
    dcterms:creator "Stanford University; Chan Zuckerberg Biohub"^^xsd:string ;
    dcterms:description "this dataset represents a network of physical interactions between proteins that are experimentally documented in humans. The dataset was assembled to study the problem of automated discovery of the proteins (nodes) associated with a given disease. Starting from a few known disease-associated proteins and a a map of protein-protein interactions (edges), the task is to find the full list of proteins associated with said disease" ;
    dcterms:isReferencedBy "\\citet{agrawal2018large}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Stanford University; Chan Zuckerberg Biohub"^^xsd:string ;
    dcterms:title "PP-Pathways" ;
    dcterms:type "protein-protein pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:biology ;
    fdo:sampleSize "20K proteins (nodes) linked by 300K physical interactions" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:98 ;
    dcat:landingPage "http://snap.stanford.edu/biodata/datasets/10000/10000-PP-Pathways.html"^^xsd:anyURI .

fdo:Paper-ReviewerMatching a dcat:Dataset ;
    dcterms:creator "unknown"^^xsd:string ;
    dcterms:description "this dataset summarizes the peer review assignment process of 3 different conferences, namely one edition of Medical Imaging and Deep Learning (MIDL) and two editions of the Conference on Computer Vision and Pattern Recognition (called CVPR and CVPR2018). The data, provided by OpenReview and the Computer Vision Foundation, consist of a matrix of paper-reviewer affinities, a set of coverage constraints to ensure each paper is properly reviewed, and a set of upper bound constraints to avoid imposing an excessive burden on reviewers" ;
    dcterms:isReferencedBy "\\citet{kobren2019paper}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "unknown"^^xsd:string ;
    dcterms:title "Paper-Reviewer Matching" ;
    dcterms:type "paper-reviewer pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:libraryandinformationsciences ;
    fdo:sampleSize "200 reviewers for 100 papers (MIDL); 1K reviewers for 3K papers (CVPR). 3K reviewers for 5K papers (CVPR2018)" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:191 .

fdo:PhiladelphiaCrimeIncidents a dcat:Dataset ;
    dcterms:creator "Philadelphia Police Department"^^xsd:string ;
    dcterms:description "this dataset is provided as part of OpenDataPhilly initiative. It summarizes hundreds of thousands of crime incidents handled by the Philadelphia Police Department over a period of ten years (2006--2016). The dataset comes with fine spatial and temporal granularity and has been used to monitor seasonal and historical trends and measure the effect of police strategies" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Philadelphia Police Department"^^xsd:string ;
    dcterms:title "Philadelphia Crime Incidents" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "1M crime incidents" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:59 ;
    dcat:landingPage "https://www.opendataphilly.org/dataset/crime-incidents"^^xsd:anyURI .

fdo:PilotParliamentsBenchmark_PPB a dcat:Dataset ;
    dcterms:creator "Massachusetts Institute of Technology; Microsoft"^^xsd:string ;
    dcterms:description "this dataset was developed as a benchmark with a balanced representation of gender and skin type to evaluate the performance of face analysis technology. The dataset features images of parliamentary representatives from three African countries (Rwanda, Senegal, South Africa) and three European countries (Iceland, Finland, Sweden) to achieve a good balance between skin type and gender while reducing potential harms connected with lack of consent from the people involved. Three annotators provided gender and Fitzpatrick labels. A certified surgical dermatologist provided the definitive Fitzpatrick skin type labels. Gender was annotated based on name, gendered title, and photo appearance" ;
    dcterms:isReferencedBy "\\citet{Buolamwini2018gender}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Massachusetts Institute of Technology; Microsoft"^^xsd:string ;
    dcterms:title "Pilot Parliaments Benchmark (PPB)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "1K images of 1K individuals" ;
    fdo:sensitiveFeature "gender, skin type" ;
    fdo:task fdo:73 ;
    dcat:landingPage "http://gendershades.org/"^^xsd:anyURI .

fdo:PimaIndiansDiabetesDataset_PIDD a dcat:Dataset ;
    dcterms:creator "Logistics Management Institute; National Institute of Diabetes Digestive and Kidney Diseases; John Hopkins University"^^xsd:string ;
    dcterms:description "this resource owes its name to the respective entry on the UCI repository (now unavailable), and was derived from a medical study of Native Americans from the Gila River Community, often called Pima. The study was initiated in the 1960s by the National Institute of Diabetes and Digestive and Kidney Diseases and found a large prevalence of \\emph{diabetes mellitus} in this population. The dataset commonly available nowadays represents a subset of the original study, focusing on women of age 21 or older. It reports whether they tested positive for diabetes, along with eight covariates that were found to be significant risk factors for this population. These include the number of pregnancies, skin thickness, and body mass index, based on which algorithms should predict the test results" ;
    dcterms:isReferencedBy "\\citet{smith1988using,radin2017digital}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Logistics Management Institute; National Institute of Diabetes Digestive and Kidney Diseases; John Hopkins University"^^xsd:string ;
    dcterms:title "Pima Indians Diabetes Dataset (PIDD)" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:endocrinology ;
    fdo:sampleSize "800 subjects" ;
    fdo:sensitiveFeature "age" ;
    fdo:task fdo:130 ;
    dcat:landingPage "https://www.kaggle.com/uciml/pima-indians-diabetes-database"^^xsd:anyURI .

fdo:PokecSocialNetwork a dcat:Dataset ;
    dcterms:creator "University of Zilina"^^xsd:string ;
    dcterms:description "this graph dataset summarizes the networks of Pokec users, a social network service popular in Slovakia and Czech Republic. Due to default privacy settings being predefined as public, a wealth of information for each profile was collected by curators including information on demographics, politics, education, marital status, and children wherever available. This resource was collected to perform data analysis in social networks" ;
    dcterms:isReferencedBy "\\citet{takac2012data}" ;
    dcterms:issued "2013"^^xsd:gYear ;
    dcterms:modified "2013"^^xsd:gYear ;
    dcterms:publisher "University of Zilina"^^xsd:string ;
    dcterms:title "Pokec Social Network" ;
    dcterms:type "user-user pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialnetworks ;
    fdo:sampleSize "2M nodes (profiles) connected by 30M edges (friendship relations)" ;
    fdo:sensitiveFeature "gender, geography, age" ;
    fdo:task fdo:186 ;
    dcat:landingPage "https://snap.stanford.edu/data/soc-pokec.html"^^xsd:anyURI .

fdo:PopularBabyNames a dcat:Dataset ;
    dcterms:creator "City of New York, Department of Health and Mental Hygiene (NYC names); United States Social Security Administration (US names)"^^xsd:string ;
    dcterms:description "this dataset summarizes birth registration in New York City, focusing on names sex and race of newborns, providing a reliable source of data to assess naming trends in New York. A similar nation-wide database is maintained by the US Social Security Administration" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "City of New York, Department of Health and Mental Hygiene (NYC names); United States Social Security Administration (US names)"^^xsd:string ;
    dcterms:title "Popular Baby Names" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "3K unique names (NYC names); 30K unique names (US names)" ;
    fdo:sensitiveFeature "sex, race" ;
    fdo:task fdo:9 ;
    dcat:landingPage "https://catalog.data.gov/dataset/popular-baby-names"^^xsd:anyURI,
        "https://www.ssa.gov/oact/babynames/limits.html"^^xsd:anyURI .

fdo:PovertyinColombia a dcat:Dataset ;
    dcterms:creator "Departamento Administrativo Nacional de Estadística"^^xsd:string ;
    dcterms:description "this dataset stems from an official survey of households performed yearly by the Colombian national statistics department (Departamento Administrativo Nacional de Estadística). The survey is aimed at soliciting information about employment, income, and demographics. The data serves as an input for studies on poverty in Colombia" ;
    dcterms:isReferencedBy "\\url{https://www.dane.gov.co/files/investigaciones/condiciones_vida/pobreza/2018/bt_pobreza_monetaria_18.pdf}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Departamento Administrativo Nacional de Estadística"^^xsd:string ;
    dcterms:title "Poverty in Colombia" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "unknown" ;
    fdo:sensitiveFeature "age, sex, geography" ;
    fdo:task fdo:47 ;
    dcat:landingPage "https://www.dane.gov.co/index.php/estadisticas-por-tema/pobreza-y-condiciones-de-vida/pobreza-y-desigualdad/pobreza-monetaria-y-multidimensional-en-colombia-2018"^^xsd:anyURI .

fdo:ProsperLoansNetwork a dcat:Dataset ;
    dcterms:creator "Prosper; University College Dublin"^^xsd:string ;
    dcterms:description "this dataset represents transactions on the Prosper marketplace, a famous peer-to-peer lending service where US-based users can register as lenders or borrowers. This resource has a graph structure and covers the period 2005--2011. Loan records include user ids, timestamps, loan amount, and rate. The dataset was first associated with a study of arbitrage and its profitability in a peer-to-peer lending system" ;
    dcterms:isReferencedBy "\\citet{redmond2013temporal}" ;
    dcterms:issued "2015"^^xsd:gYear ;
    dcterms:modified "2015"^^xsd:gYear ;
    dcterms:publisher "Prosper; University College Dublin"^^xsd:string ;
    dcterms:title "Prosper Loans Network" ;
    dcterms:type "lender-borrower pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:finance ;
    fdo:sampleSize "3M loan records involving 100K people" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:152 ;
    dcat:landingPage "http://mlg.ucd.ie/datasets/prosper.html"^^xsd:anyURI .

fdo:PubMedDiabetesPapers a dcat:Dataset ;
    dcterms:creator "University of Maryland"^^xsd:string ;
    dcterms:description "this dataset was created to study the problem of classification of connected entities via active learning. The creators extracted a set of articles related to diabetes from PubMed, along with their citation network. The task associated with the dataset is inferring a label specifying the type of diabetes addressed in each publication. For this task, TF/IDF-weighted term frequencies of every article are available" ;
    dcterms:isReferencedBy "\\citet{namata2012query}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "University of Maryland"^^xsd:string ;
    dcterms:title "PubMed Diabetes Papers" ;
    dcterms:type "article-article pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:libraryandinformationsciences ;
    fdo:sampleSize "20K articles connected by 40K citations" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:113 ;
    dcat:landingPage "https://linqs.soe.ucsc.edu/data"^^xsd:anyURI .

fdo:PymetricsBiasGroup a dcat:Dataset ;
    dcterms:creator "Pymetrics"^^xsd:string ;
    dcterms:description "Pymetrics is a company that offers a candidate screening tool to employers. Candidates play a core set of twelve games, derived from psychological studies. The resulting gamified psychological measurements are exploited to build predictive models for hiring, where positive examples are provided by high-performing employees from the employer. Pymetrics staff maintain a \\emph{Pymetrics Bias Group} dataset for internal fairness audits by asking players to fill in an optional demographic survey after they complete the games" ;
    dcterms:isReferencedBy "\\citet{wilson2021building}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Pymetrics"^^xsd:string ;
    dcterms:title "Pymetrics Bias Group" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#informationsystems,managementinformationsystems> ;
    fdo:sampleSize "10K users" ;
    fdo:sensitiveFeature "gender, race" ;
    fdo:task fdo:173 .

fdo:RaceonTwitter a dcat:Dataset ;
    dcterms:creator "University of Pennsylvania"^^xsd:string ;
    dcterms:description "this dataset was collected to power applications of user-level race prediction on Twitter. Twitter users were hired through Qualtrics, were they filled in a survey providing their Twitter handle and demographics, including race, gender, age, education, and income. The dataset creators downloaded the most recent 3,200 tweets by the users who provided their handle. The data, allegedly released in an anonymized and aggregated format, appears to be unavailable" ;
    dcterms:isReferencedBy "\\citet{preotiucpietro2018user}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "University of Pennsylvania"^^xsd:string ;
    dcterms:title "Race on Twitter" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "5M tweets from 4K users" ;
    fdo:sensitiveFeature "race, gender, age" ;
    fdo:task fdo:36 ;
    dcat:landingPage "http://www.preotiuc.ro/"^^xsd:anyURI .

fdo:RacialFacesintheWild_RFW a dcat:Dataset ;
    dcterms:creator "Beijing University of Posts; Telecommunications and Canon Information Technology (Beijing)"^^xsd:string ;
    dcterms:description "this dataset was developed as a benchmark for face verification algorithms operating on diverse populations. The dataset comprises 4 clusters of images extracted from MS-Celeb-1M (\\autoref{sec:msceleb}), a dataset that was discontinued by Microsoft due to privacy violations. Clusters are of similar size and contain individuals labelled Caucasian, Asian, Indian and African. Half of the labels (Asian, Indian) are derived from the ``Nationality attribute of FreeBase celebrities''; the remaining half (Caucasian, African) is automatically estimated via the Face++ API. This attribute is referred to as ``race'' by the authors, who also assert ``carefully and manually'' cleaning every image. Clusters feature multiple images of each individual to allow for face verification applications" ;
    dcterms:isReferencedBy "\\citet{wang2019racial}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Beijing University of Posts; Telecommunications and Canon Information Technology (Beijing)"^^xsd:string ;
    dcterms:title "Racial Faces in the Wild (RFW)" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "50K images of 10K individuals" ;
    fdo:sensitiveFeature "race (inferrred)" ;
    fdo:task fdo:121 ;
    dcat:landingPage "http://www.whdeng.cn/RFW/testing.html"^^xsd:anyURI .

fdo:Real-TimeCrimeForecastingChallenge a dcat:Dataset ;
    dcterms:creator "National Institute of Justice"^^xsd:string ;
    dcterms:description "this dataset was assembled and released by the US National Institute of Justice in 2017 with the goal of advancing the state of automated crime forecasting. It consists of calls-for-service (CFS) records provided by the Portland Police Bureau for the period 2012--2017. Each CFS record contains spatio-temporal data and crime-related categories. The dataset was released as part of a challenge with a toal prize of 1,200,000\\$" ;
    dcterms:isReferencedBy "\\citet{conduent2018:real}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "National Institute of Justice"^^xsd:string ;
    dcterms:title "Real-Time Crime Forecasting Challenge" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize " 700K CFS records" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:102 ;
    dcat:landingPage "https://nij.ojp.gov/funding/real-time-crime-forecasting-challenge-posting#data"^^xsd:anyURI .

fdo:RecidivismofFelonsonProbation a dcat:Dataset ;
    dcterms:creator "US Department of Justice; National Association of Criminal Justice Planners"^^xsd:string ;
    dcterms:description "this dataset covers probation cases of persons who were sentenced in 1986 in 32 urban and suburban US jurisdictions. It was assembled to study the behaviour of individuals on probation and their compliance with court orders across states. Possible outcomes include successful discharge, new felony rearrest, and absconding. The information on probation cases was frequently obtained through manual reviews and transcription of probation files, mostly by college students. Variables include probationer's demographics, educational level, wage, history of convictions, disciplinary hearings and probation sentences. The final dataset consists of $\\sim10$K probation cases ``representative of 79,043 probationers''" ;
    dcterms:isReferencedBy "\\url{https://bjs.ojp.gov/data-collection/recidivism-survey-felons-probation}" ;
    dcterms:issued "2005"^^xsd:gYear ;
    dcterms:modified "2005"^^xsd:gYear ;
    dcterms:publisher "US Department of Justice; National Association of Criminal Justice Planners"^^xsd:string ;
    dcterms:title "Recidivism of Felons on Probation" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "10K probation cases" ;
    fdo:sensitiveFeature "sex, race, ethnicity, age" ;
    fdo:task fdo:172 ;
    dcat:landingPage "https://www.icpsr.umich.edu/web/NACJD/studies/9574"^^xsd:anyURI .

fdo:RedditComments a dcat:Dataset ;
    dcterms:creator "Pushshift data"^^xsd:string ;
    dcterms:description "this resource consists of Reddit comments and relative metadata, crawled and made available online for research purposes. While the available dumps cover the period 2006-2021, below the ``sample size'' field refers to comments from 2014 used in one surveyed work" ;
    dcterms:isReferencedBy "\\citet{guo2021detecting}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Pushshift data"^^xsd:string ;
    dcterms:title "Reddit Comments" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#socialmedia,linguistics> ;
    fdo:sampleSize "500M comments" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:221 ;
    dcat:landingPage "https://files.pushshift.io/reddit/comments/"^^xsd:anyURI .

fdo:RenalFailure a dcat:Dataset ;
    dcterms:creator "New York University; New York University Langone Medical Center"^^xsd:string ;
    dcterms:description "the dataset was created to compare the performance of two different algorithms for automated renal failure risk assessment. Considering patients who received care at NYU Langone Medical Center, each entry encodes their health records, demographics, disease history, and lab results. The final version of the dataset has a cutoff date, considering only patients who did not have kidney failure by that time, and reporting, as a target ground truth, whether they proceeded to have kidney failure within the next year" ;
    dcterms:isReferencedBy "\\citet{williams2019quantification}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "New York University; New York University Langone Medical Center"^^xsd:string ;
    dcterms:title "Renal Failure" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:nephrology ;
    fdo:sampleSize "2M patients" ;
    fdo:sensitiveFeature "age, gender, race" ;
    fdo:task fdo:155 .

fdo:Reuters5050 a dcat:Dataset ;
    dcterms:creator "University of the Aegean"^^xsd:string ;
    dcterms:description "this dataset was extracted from the Reuters Corpus Volume 1 (RCV1), a large corpus of newswire stories, to study the problem of authorship attribution. The 50 most prolific authors were selected from RCV1, considering only texts labeled corporate/industrial. The dataset consists of short news stories from these authors, labelled with the name of the author" ;
    dcterms:isReferencedBy "\\citet{houvardas2006n}" ;
    dcterms:issued "2011"^^xsd:gYear ;
    dcterms:modified "2011"^^xsd:gYear ;
    dcterms:publisher "University of the Aegean"^^xsd:string ;
    dcterms:title "Reuters 50 50" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:news ;
    fdo:sampleSize "5K articles" ;
    fdo:sensitiveFeature "author, textual references to people and their demographics" ;
    fdo:task fdo:188 ;
    dcat:landingPage "http://archive.ics.uci.edu/ml/datasets/Reuter_50_50"^^xsd:anyURI .

fdo:Ricci a dcat:Dataset ;
    dcterms:creator "Haverford College"^^xsd:string ;
    dcterms:description "this dataset relates to the US supreme court labor case on discrimination \\emph{Ricci vs DeStefano} (2009), connected with the disparate impact doctrine. It represents 118 firefighter promotion tests, providing the scores and race of each test taker. Eighteen firefighters from the New Haven Fire Department claimed ``reverse discrimination'' after the city refused to certify a promotion examination where they had obtained high scores. The reasons why city officials avoided certifying the examination included concerns of potential violation of the `four-fiths' rule, as, given the vacancies at the time, no black firefighter would be promoted. The dataset was published and popularized by Weiwen Miao for pedagogical use" ;
    dcterms:isReferencedBy "\\citet{gastwirth2009formal,miao2010did}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Haverford College"^^xsd:string ;
    dcterms:title "Ricci" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "100 test takers" ;
    fdo:sensitiveFeature "race" ;
    fdo:task fdo:57 ;
    dcat:landingPage "http://jse.amstat.org/jse_data_archive.htm"^^xsd:anyURI,
        "https://github.com/algofairness/fairness-comparison/tree/master/fairness/data/raw"^^xsd:anyURI .

fdo:RiceFacebookNetwork a dcat:Dataset ;
    dcterms:creator "MPI-SWS; Rice University; Northeastern University"^^xsd:string ;
    dcterms:description "this dataset repesents the Facebook sub-network of students and alumni of Rice University. It consists of a crawl of reachable profiles in the Rice Facebook network, augmented with academic information obtained from Rice University directories. This collection was created to study the problem of inferring unknown attributes in a social network based on the network graph and attributes that are available for a fraction of users" ;
    dcterms:isReferencedBy "\\citet{mislove2010you}" ;
    dcterms:issued "2010"^^xsd:gYear ;
    dcterms:modified "2010"^^xsd:gYear ;
    dcterms:publisher "MPI-SWS; Rice University; Northeastern University"^^xsd:string ;
    dcterms:title "Rice Facebook Network" ;
    dcterms:type "user-user pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialnetworks ;
    fdo:sampleSize "1K profiles connected by 40K edges" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:156 .

fdo:RiddleofLiteraryQuality a dcat:Dataset ;
    dcterms:creator "Huygens ING – KNAW; University of Amsterdam; Fryske Akademy"^^xsd:string ;
    dcterms:description "this text corpus was assembled to study the factors that correlate with the acceptance of a text as literary (or non-literary) and good (or bad). It consists of 401 Dutch-language novels published between 2007--2012. These works were selected for being bestsellers or often lent from libraries in the period 2009--2012. Due to copyright reasons, the data is not publicly available" ;
    dcterms:isReferencedBy "\\citet{koolen2017:stereotypes}; \\url{https://literaryquality.huygens.knaw.nl/}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Huygens ING – KNAW; University of Amsterdam; Fryske Akademy"^^xsd:string ;
    dcterms:title "Riddle of Literary Quality" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:literature ;
    fdo:sampleSize "400 novels" ;
    fdo:sensitiveFeature "gender (of author)" ;
    fdo:task fdo:202 .

fdo:Ride-hailingApp a dcat:Dataset ;
    dcterms:creator "Max Planck Institute for Software Systems; Max Planck Institute for Informatics"^^xsd:string ;
    dcterms:description "this dataset was gathered from a ride-hailing app operating in an undisclosed major Asian city. It summarizes spatio-temporal data about ride requests (jobs) and assignments to drivers during 29 consecutive days. The data tracks the position and status of taxis logging data every 30-90 seconds" ;
    dcterms:isReferencedBy "\\citet{suhr2019twosided}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Max Planck Institute for Software Systems; Max Planck Institute for Informatics"^^xsd:string ;
    dcterms:title "Ride-hailing App" ;
    dcterms:type "driver-job pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:transportation ;
    fdo:sampleSize "1K drivers handling 200K job requests" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:192 .

fdo:RtGender a dcat:Dataset ;
    dcterms:creator "Stanford University; University of Michigan; Carnegie Mellon University"^^xsd:string ;
    dcterms:description "this dataset captures differences in online commenting behaviour to posts and videos of female and male users. It was created by collecting posts and top-level comments from four platforms: Facebook, Reddit, Fitocracy, TED talks. For each of the four sources, the possibility to reliably report the gender of the poster or presenter shaped the data collection procedure. Authors of posts and videos were selected among users self-reporting their gender or public figures for which gender annotations were available. For instance, the authors created two Facebook-based datasets: one containing all posts and associated top-level comments for all 412 members of US parliament who have public Facebook pages, and a similar one for 105 American public figures (journalists, novelists, actors, actresses, etc.). The gender of these figures was derived based on their presence on Wikipedia category pages relevant for gender.\\footnote{e.g. \\url{https://en.wikipedia.org/wiki/Category:American_female_tennis_players}} The gender of commenters and a reliable ID to identify them across comments may be useful for some analyses. The authors report commenters' first names and a randomized ID, which should support these goals, while reducing chances of re-identification based on last name and Facebook ID" ;
    dcterms:isReferencedBy "\\citep{voigt2018rtgender}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Stanford University; University of Michigan; Carnegie Mellon University"^^xsd:string ;
    dcterms:title "RtGender" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#socialmedia,linguistics> ;
    fdo:sampleSize "2M posts with 25M comments" ;
    fdo:sensitiveFeature "gender.\\footnote{Annotations for Facebook and TED come from Wikipedia and \\citet{mirkin2015:motivating} respectively. Reddit and Fitocracy rely on self-reported labels.}" ;
    fdo:task fdo:153 ;
    dcat:landingPage "https://nlp.stanford.edu/robvoigt/rtgender/"^^xsd:anyURI .

fdo:SIIM-ISICMelanomaClassification a dcat:Dataset ;
    dcterms:creator "Memorial Sloan Kettering Cancer Center; University of Queensland; University of Athens; IBM; Universitat de Barcelona; Melanoma Institute Australia; Sydney Melanoma Diagnostic Center; Emory University; Medical University of Vienna; Mayo Clinic; SUNY Downstate Medical School; Stony brook Medical School; Rabin Medical Center; Weill Cornell Medical College"^^xsd:string ;
    dcterms:description "this dataset was developed to advance the study of automated melanoma classification. The resource consists of dermoscopy images from six medical centers. Images in the dataset are tagged with a patient identifier, allowing lesions from the same patient to be mapped to one another. Images were queried from medical databases among patients with dermoscopy imaging from 1998 to 2019, ranging in quality from 307,200 to 24,000,000 pixels. A curated subset is employed for the 2020 ISIC Grand Challenge.\\footnote{\\url{https://www.kaggle.com/c/siim-isic-melanoma-classification}} This dataset was annotated automatically with a binary Fitzpatrick skin tone label \\citep{cheng2021can}" ;
    dcterms:isReferencedBy "\\citet{rotemberg2021patient}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Memorial Sloan Kettering Cancer Center; University of Queensland; University of Athens; IBM; Universitat de Barcelona; Melanoma Institute Australia; Sydney Melanoma Diagnostic Center; Emory University; Medical University of Vienna; Mayo Clinic; SUNY Downstate Medical School; Stony brook Medical School; Rabin Medical Center; Weill Cornell Medical College"^^xsd:string ;
    dcterms:title "SIIM-ISIC Melanoma Classification" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:dermatology ;
    fdo:sampleSize "30K images of 2K patients" ;
    fdo:sensitiveFeature "skin type" ;
    fdo:task fdo:27 ;
    dcat:landingPage "-"^^xsd:anyURI,
        "."^^xsd:anyURI,
        "/"^^xsd:anyURI,
        "0"^^xsd:anyURI,
        "1"^^xsd:anyURI,
        "2"^^xsd:anyURI,
        "3"^^xsd:anyURI,
        "4"^^xsd:anyURI,
        "7"^^xsd:anyURI,
        "9"^^xsd:anyURI,
        ":"^^xsd:anyURI,
        "d"^^xsd:anyURI,
        "g"^^xsd:anyURI,
        "h"^^xsd:anyURI,
        "i"^^xsd:anyURI,
        "l"^^xsd:anyURI,
        "o"^^xsd:anyURI,
        "p"^^xsd:anyURI,
        "r"^^xsd:anyURI,
        "s"^^xsd:anyURI,
        "t"^^xsd:anyURI,
        "u"^^xsd:anyURI,
        "{"^^xsd:anyURI,
        "}"^^xsd:anyURI .

fdo:SafeGraphResearchRelease a dcat:Dataset ;
    dcterms:creator "Safegraph"^^xsd:string ;
    dcterms:description "this dataset captures mobility patterns in the US and Canada. It is maintained by SafeGraph, a data company powering analytics about access to Points-of-Interest (POI) and mobility, including pandemic research. SafeGraph data is sourced from millions of mobile devices, whose users allow location tracking by some apps. The \\emph{Research Release} dataset consists of aggregated estimates of hourly visit counts to over 6 million POI. Given the increasing importance of SafeGraph data, directly influencing not only private initiative but also public policy, audits of data representativeness are being carried out both internally \\citep{squire2019measuring} and externally \\citep{coston2021leveraging}" ;
    dcterms:isReferencedBy "\\url{https://docs.safegraph.com/v4.0/docs}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Safegraph"^^xsd:string ;
    dcterms:title "SafeGraph Research Release" ;
    dcterms:type "mixture"^^rdf:PlainLiteral ;
    fdo:domain fdo:urbanstudies ;
    fdo:sampleSize "7M POI" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:39 ;
    dcat:landingPage "https://www.safegraph.com/academics"^^xsd:anyURI .

<http://www.fairnessdata.dei.unipd.it/ontology#Scientist+Painter> a dcat:Dataset ;
    dcterms:creator "École Polytechnique Fédérale de Lausanne (EPFL); Microsoft; University of California, Berkeley"^^xsd:string ;
    dcterms:description "this resource was crawled to study the problem of fair and diverse representation in subsets of instances selected from a large dataset, with a focus on gender concentration in professions. The dataset consists of approximately 800 images that equally represent male scientists, female scientists, male painters, and female painters. These images were gathered from Google image search, selecting the top 200 medium sized JPEG files that passed the strictest level of Safe Search filtering. Then, each image was processed to obtain sets of 128-dimensional SIFT descriptors. The descriptors are combined, subsampled and then clustered using k-means into 256 clusters" ;
    dcterms:isReferencedBy "\\citet{celis2016fair}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "École Polytechnique Fédérale de Lausanne (EPFL); Microsoft; University of California, Berkeley"^^xsd:string ;
    dcterms:title "Scientist+Painter" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "800 images" ;
    fdo:sensitiveFeature "male/female" ;
    fdo:task fdo:137 ;
    dcat:landingPage "goo.gl/hNukfP"^^xsd:anyURI .

fdo:Section203determinations a dcat:Dataset ;
    dcterms:creator "US Census Bureau"^^xsd:string ;
    dcterms:description "this dataset is created in support of the language minority provisions of the Voting Rights Act, Section 203. The data contains information about limited-English proficient voting population by jurisdiction, which is used to determine whether election materials must be printed in minority languages. For each combination of language protected by Section 203 and US jurisdiction, the dataset provides information about total population, population of voting age, US citizen population of voting age, combining this information with language spoken at home and overall English proficiency" ;
    dcterms:isReferencedBy "\\url{https://www.census.gov/programs-surveys/decennial-census/about/voting-rights/voting-rights-determination-file.2016.html}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "US Census Bureau"^^xsd:string ;
    dcterms:title "Section 203 determinations" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:demography ;
    fdo:sampleSize "600K combinations of jurisdictions and languages potentially spoken therein" ;
    fdo:sensitiveFeature "geography, language" ;
    fdo:task fdo:45 ;
    dcat:landingPage "https://www.census.gov/data/datasets/2016/dec/rdo/section-203-determinations.html"^^xsd:anyURI .

fdo:Sentiment140 a dcat:Dataset ;
    dcterms:creator "Stanford University"^^xsd:string ;
    dcterms:description "this dataset was created to study the problem of sentiment analysis in social media, envisioning applications of product quality and brand reputation analysis via Twitter monitoring. The sentiment of tweets, retrieved via Twitter API, is automatically inferred based on the presence of emoticons conveying joy or sadness. This dataset is part of the LEAF benchmark for federated learning. In federated learning settings, devices correspond to accounts" ;
    dcterms:isReferencedBy "\\citet{go2009twitter}" ;
    dcterms:issued "2012"^^xsd:gYear ;
    dcterms:modified "2012"^^xsd:gYear ;
    dcterms:publisher "Stanford University"^^xsd:string ;
    dcterms:title "Sentiment140" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "2M tweets by 600K accounts" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:116 ;
    dcat:landingPage "http://help.sentiment140.com/home"^^xsd:anyURI .

fdo:SeoulBikeSharing a dcat:Dataset ;
    dcterms:creator "Sunchon National University"^^xsd:string ;
    dcterms:description "this resource, summarizing hourly public rental history of \\emph{Seoul Bikes}, was curated to study the problem of bike sharing demand prediction. The data was downloaded from the Seoul Public Data Park website of South Korea and spans one year of utilization (December 2017 to November 2018) of Seoul Bikes, a bike sharing system that started in 2015. This dataset consists of hourly information about weather (e.g. temperature, solar radiation, rainfall) and time (date, time, season, holiday), along with the number of bikes rented at each hour, which is the target of a prediction task" ;
    dcterms:isReferencedBy "\\citet{sathishkumar2020rule,sathishkumar2020using}, \\url{https://data.seoul.go.kr/index.do}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Sunchon National University"^^xsd:string ;
    dcterms:title "Seoul Bike Sharing" ;
    dcterms:type "time series"^^rdf:PlainLiteral ;
    fdo:domain fdo:transportation ;
    fdo:sampleSize "9K hourly points" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:210 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/Seoul+Bike+Sharing+Demand"^^xsd:anyURI .

fdo:Shakespeare a dcat:Dataset ;
    dcterms:creator "Google; Carnegie Mellon University; Determined AI"^^xsd:string ;
    dcterms:description "this dataset is available as part of the LEAF benchmark for federated learning \\citep{caldas2018leaf}. It is built from ``The Complete Works of William Shakespeare'', where each speaking role represents a different device. The task envisioned for this dataset is next character prediction" ;
    dcterms:isReferencedBy "\\citet{mcmahan2017communicationefficient,caldas2018leaf}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Google; Carnegie Mellon University; Determined AI"^^xsd:string ;
    dcterms:title "Shakespeare" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:literature ;
    fdo:sampleSize "4M tokens over 1K speaking roles" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:117 ;
    dcat:landingPage "https://github.com/TalwalkarLab/leaf/tree/master/data"^^xsd:anyURI,
        "https://www.tensorflow.org/federated/api_docs/python/tff/simulation/datasets/shakespeare"^^xsd:anyURI .

fdo:ShanghaiTaxiTrajectories a dcat:Dataset ;
    dcterms:creator "Shanghai Jiao Tong University; CITI-INRIA Lab"^^xsd:string ;
    dcterms:description "this semi-synthetic dataset represents the road network and traffic patterns of Shanghai. Trajectories were collected from thousands of taxis operating in Shanghai. Spatio-temporal traffic patterns were extracted from these trajectories and used to build the dataset" ;
    dcterms:isReferencedBy "\\citet{qian2015scram}" ;
    dcterms:issued "2015"^^xsd:gYear ;
    dcterms:modified "2015"^^xsd:gYear ;
    dcterms:publisher "Shanghai Jiao Tong University; CITI-INRIA Lab"^^xsd:string ;
    dcterms:title "Shanghai Taxi Trajectories" ;
    dcterms:type "unknown"^^rdf:PlainLiteral ;
    fdo:domain fdo:transportation ;
    fdo:sampleSize "unknown" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:194 .

fdo:SmallNORB a dcat:Dataset ;
    dcterms:creator "New York University; NEC Labs America"^^xsd:string ;
    dcterms:description "this dataset was assembled by researchers affiliated with New York University as a benchmark for robust object recognition under variable pose and lighting conditions. It consists of images of 50 different toys  belonging to 5 categories (four-legged animals, human figures, airplanes, trucks, and cars) obtained by 2 different cameras" ;
    dcterms:isReferencedBy "\\citet{lecun2004learning}" ;
    dcterms:issued "2005"^^xsd:gYear ;
    dcterms:modified "2005"^^xsd:gYear ;
    dcterms:publisher "New York University; NEC Labs America"^^xsd:string ;
    dcterms:title "SmallNORB" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "100K images" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:83 ;
    dcat:landingPage "https://cs.nyu.edu/~ylclab/data/norb-v1.0-small/"^^xsd:anyURI .

fdo:SplidditDivideGoods a dcat:Dataset ;
    dcterms:creator "Spliddit"^^xsd:string ;
    dcterms:description "this dataset summarizes instances of usage of the \\emph{divide goods} feature of Spliddit, a not-for-profit academic endeavor providing easy access to fair division methods. A typical use case for the service is inheritance division. Participants express their preferences by dividing 1,000 points between the available goods. In response, the service provides suggestions that are meant to maximize the overall satisfaction of all stakeholders" ;
    dcterms:isReferencedBy "\\citet{caragiannis2016unreasonable}; \\url{http://www.spliddit.org/apps/goods}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Spliddit"^^xsd:string ;
    dcterms:title "Spliddit Divide Goods" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "1K division instances" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:185 .

fdo:StanfordMedicineResearchDataRepository a dcat:Dataset ;
    dcterms:creator "Stanford University"^^xsd:string ;
    dcterms:description "this is a data lake/repository developed at Stanford University, supporting a number of data sources and access pipelines. The aim of the underlying project is favouring access to clinical data for research purposes through flexible and robust management of medical data. The data comes from Stanford Health Care, the Stanford Children’s Hospital, the University Healthcare Alliance and Packard Children's Health Alliance clinics" ;
    dcterms:isReferencedBy "\\citet{lowe2009stride,datta2020new}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Stanford University"^^xsd:string ;
    dcterms:title "Stanford Medicine Research Data Repository" ;
    dcterms:type "mixture"^^rdf:PlainLiteral ;
    fdo:domain fdo:medicine ;
    fdo:sampleSize "3M individuals" ;
    fdo:sensitiveFeature "race, ethnicity, gender, age" ;
    fdo:task fdo:7 ;
    dcat:landingPage "https://starr.stanford.edu/"^^xsd:anyURI .

fdo:StateCourtProcessingStatistics_SCPS a dcat:Dataset ;
    dcterms:creator "US Department of Justice"^^xsd:string ;
    dcterms:description "this resource was curated as part of the SCPS program. The program tracked felony defendants from charging by the prosecutor until disposition of their cases for a maximum of 12 months (24 months for murder cases). The data represents felony cases filed in approximately 40 populous US counties in the period 1990-2009. Defendants are summarized by 106 variables summarizing demographics, arrest charges, criminal history, pretrial release and detention, adjudication, and sentencing" ;
    dcterms:isReferencedBy "\\url{https://bjs.ojp.gov/data-collection/state-court-processing-statistics-scps}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "US Department of Justice"^^xsd:string ;
    dcterms:title "State Court Processing Statistics (SCPS)" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "200K defendants" ;
    fdo:sensitiveFeature "gender, race, age, geography" ;
    fdo:task fdo:174 ;
    dcat:landingPage "https://www.icpsr.umich.edu/web/NACJD/studies/2038/datadocumentation"^^xsd:anyURI .

fdo:Steemit a dcat:Dataset ;
    dcterms:creator "Hong Kong University of Science and Technology; WeBank"^^xsd:string ;
    dcterms:description "this resource was collected to test novel approaches for personalized content recommendation in social networks. It consists of two separate datasets summarizing interactions in the Spanish subnetwork and the English subsnetwork of Steemit, a blockchain-based social media website. The datasets summarize user-post interactions in a binary fashion, using comments as a proxy for positive engagement. The datasets cover a whole year of commenting activities over the period 2017--2018 and comprise the text of posts" ;
    dcterms:isReferencedBy "\\citet{xiao2019beyond}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Hong Kong University of Science and Technology; WeBank"^^xsd:string ;
    dcterms:title "Steemit" ;
    dcterms:type "user-post pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "50K users interacting over 200K posts" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:193 ;
    dcat:landingPage "https://github.com/HKUST-KnowComp/Social-Explorative-Attention-Networks"^^xsd:anyURI .

<http://www.fairnessdata.dei.unipd.it/ontology#Stop,QuestionandFrisk> a dcat:Dataset ;
    dcterms:creator "New York Police Department"^^xsd:string ;
    dcterms:description "Stop, Question and Frisk (SQF) is an expression that commonly refers to a New York City policing program under which officers can briefly detain, question, and search a citizen if the officer has a reasonable suspicion of criminal activity. Concerns about race-based disparities in this practice have been expressed multiple times, especially in connection with the subjective nature of ``reasonable suspicion'' and the fact that being in a ``high-crime area'' lawfully lowers the bar of want may constitute reasonable suspicion. The NYPD has a policy of keeping track of most stops, recording them in UF-250 forms which are maintained centrally and distributed by the NYPD. The form includes several information such as place and time of a stop, the duration of the stop and its outcome along with data on demographics and physical appearance of the suspect. Currently available data pertains to years 2003--2020" ;
    dcterms:isReferencedBy "\\citet{gelman2007analysis, goel2016precinct}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "New York Police Department"^^xsd:string ;
    dcterms:title "Stop, Question and Frisk" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "1M records" ;
    fdo:sensitiveFeature "race, age, sex, geography" ;
    fdo:task fdo:97 ;
    dcat:landingPage "https://www1.nyc.gov/site/nypd/stats/reports-analysis/stopfrisk.page"^^xsd:anyURI .

fdo:StrategicSubjectList a dcat:Dataset ;
    dcterms:creator "Chicago Police Department; Illinois Institute of Technology"^^xsd:string ;
    dcterms:description "this dataset was funded through a Bureau of Justice Assistance grant and leveraged by the Illinois Institute of Technology to develop the Chicago Police Department’s Strategic Subject Algorithm. The algorithm provides a risk score which reflects an individual’s probability of being involved in a shooting incident either as a victim or an offender. For each individual, the dataset provides information about the circumstances of their arrest, their demographics and criminal history. The dataset covers arrest data from the period 2012--2016; the associated program was discontinued in 2019" ;
    dcterms:isReferencedBy "\\citet{hollywood2019real}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Chicago Police Department; Illinois Institute of Technology"^^xsd:string ;
    dcterms:title "Strategic Subject List" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "400K individuals" ;
    fdo:sensitiveFeature "ace, sex, age" ;
    fdo:task fdo:44 ;
    dcat:landingPage "https://data.cityofchicago.org/Public-Safety/Strategic-Subject-List-Historical/4aki-r3np"^^xsd:anyURI .

fdo:Student a dcat:Dataset ;
    dcterms:creator "University of Minho"^^xsd:string ;
    dcterms:description "the data was collected from two Portuguese public secondary schools in the Alentejo region, to investigate student achievement prediction and identify decisive factors in student success. The data tracks student performance in Mathematics and Portuguese through school year 2005-2006 and is complemented by demographic, socio-econonomical, and personal data obtained through a questionnaire. Numerical grades (20-point scale) collected by students over three terms are typically the target of the associated prediction task" ;
    dcterms:isReferencedBy "\\citet{cortez2008using}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "University of Minho"^^xsd:string ;
    dcterms:title "Student" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "600 students" ;
    fdo:sensitiveFeature "sex, age" ;
    fdo:task fdo:15 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/student+performance"^^xsd:anyURI .

fdo:Sushi a dcat:Dataset ;
    dcterms:creator "Japanese National Institute of Advanced Industrial Science and Technology (AIST)"^^xsd:string ;
    dcterms:description "this dataset was sourced online via a commercial survey service to evaluate rank-based approaches to solicit preferences and provide recommendations. The dataset captures the preferences for different types of sushi held by people in different areas of Japan. These are encoded both as ratings in a 5-point scale and ordered lists of preferences, which recommenders should learn via collaborative filtering. Demographic data was also collected to study geographical preference patterns" ;
    dcterms:isReferencedBy "\\citet{kamishima2003:nantonac}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Japanese National Institute of Advanced Industrial Science and Technology (AIST)"^^xsd:string ;
    dcterms:title "Sushi" ;
    dcterms:type "user-sushi pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo: ;
    fdo:sampleSize "5K respondents" ;
    fdo:sensitiveFeature "gender, age, geography" ;
    fdo:task fdo:124 ;
    dcat:landingPage "https://www.kamishima.net/\\%20sushi/"^^xsd:anyURI .

fdo:SymptomsinQueries a dcat:Dataset ;
    dcterms:creator "Microsoft; Ben-Gurion University of the Negev"^^xsd:string ;
    dcterms:description "the purpose of this dataset is to study, using only aggregate statistics, the fairness and accuracy of a classifier that predicts whether an individual has a certain type of cancer based on their Bing search queries. The dataset does not include individual data points. It provides, for each US state, and for 18 types of cancer, the proportion of individuals who have this cancer in the state according to CDC 2019 data,\\footnote{\\url{https://gis.cdc.gov/Cancer/USCS/DataViz.html}} and the proportion of individuals who are predicted to have this cancer according to the classifier that was calculated using Bing queries" ;
    dcterms:isReferencedBy "\\citet{sabato2020bounding}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Microsoft; Ben-Gurion University of the Negev"^^xsd:string ;
    dcterms:title "Symptoms in Queries" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#informationsystems,publichealth> ;
    fdo:sampleSize "statistics for 20 cancer types across 50 US states" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:128 ;
    dcat:landingPage "https://github.com/sivansabato/bfa/blob/master/cancer_data.m"^^xsd:anyURI .

fdo:TAPERTwitterLists a dcat:Dataset ;
    dcterms:creator "Texas A\\&M University"^^xsd:string ;
    dcterms:description "this resource was collected to study the problem of personalized expert recommendation, leveraging Twitter lists where users labelled other users as relevant for (or expert in) a given topic. The creators started from a seed dataset of over 12 million geo-tagged Twitter lists, which they filtered to only keep US-based users in topics: news, music, technology, celebrities, sports, business, politics, food, fashion, art, science, education, marketing, movie, photography, and health. A subset of this dataset was annotated with user race (whites and non-whites) via Face++ \\citep{zhu2018fairnessaware}" ;
    dcterms:isReferencedBy "\\citet{ge2016taper}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Texas A\\&M University"^^xsd:string ;
    dcterms:title "TAPER Twitter Lists" ;
    dcterms:type "user-topic pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "10K Twitter lists featuring 8K list members" ;
    fdo:sensitiveFeature "race" ;
    fdo:task fdo:166 .

fdo:TIMIT a dcat:Dataset ;
    dcterms:creator "University of Pennsylvania; National Institute of Standards and Technology; Massachusetts Institute of Technology; SRI International; Texas Instruments"^^xsd:string ;
    dcterms:description "this resource was curated to power studies of phonetics and to evaulate systems of automated speech recognition. The dataset features speakers of different American English dialects, and includes time-aligned orthographic, phonetic and word transcriptions. Utterances are sampled at a 16kHz frequency" ;
    dcterms:isReferencedBy "\\url{https://en.wikipedia.org/wiki/TIMIT}" ;
    dcterms:issued "1993"^^xsd:gYear ;
    dcterms:modified "1993"^^xsd:gYear ;
    dcterms:publisher "University of Pennsylvania; National Institute of Standards and Technology; Massachusetts Institute of Technology; SRI International; Texas Instruments"^^xsd:string ;
    dcterms:title "TIMIT" ;
    dcterms:type "time series"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "600 speakers, each uttering 10 sentences" ;
    fdo:sensitiveFeature "dialect, gender" ;
    fdo:task fdo:219 ;
    dcat:landingPage "https://catalog.ldc.upenn.edu/LDC93S1"^^xsd:anyURI .

fdo:TRECRobust04 a dcat:Dataset ;
    dcterms:creator "National Institute of Standards and Technology"^^xsd:string ;
    dcterms:description "this classic information retrieval collection is a set of topics, documents and relevance judgements collected as part of the Text REtrieval Conference (TREC) 2004 Robust Retrieval Track to catalyze research improving the consistency of information retrieval technology. Documents are taken from articles published during the 1990s in the Financial Times Limited, the Federal Register, the Foreign Broadcast Information Service, and the Los Angeles Times. Graded relevance (not relevant, relevant, highly relevant) was judged by human assessors for a subset of all possible topic-document combinations, which were selected as ``promising'' by the automated systems that entered the TREC initiative. The associated task is predicting the relevance of documents for various textual queries" ;
    dcterms:isReferencedBy "\\citet{voorhees2005overview}" ;
    dcterms:issued "2005"^^xsd:gYear ;
    dcterms:modified "2005"^^xsd:gYear ;
    dcterms:publisher "National Institute of Standards and Technology"^^xsd:string ;
    dcterms:title "TREC Robust04" ;
    dcterms:type "query-document pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#news,informationsystems> ;
    fdo:sampleSize "300K relevance judgements over 200 queries and 500K documents" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:197 ;
    dcat:landingPage "https://trec.nist.gov/data/t13_robust.html"^^xsd:anyURI .

fdo:TaskRabbit a dcat:Dataset ;
    dcterms:creator "Technische Universität Berlin; Harvard University"^^xsd:string ;
    dcterms:description "this resource was assembled to study the effectiveness of fair ranking approaches in improving outcomes for protected groups in online hiring. It consists of the top 10 results returned by the online freelance marketplace TaskRabbit for three queries: ``Shopping'', ``Event staffing'', and ``Moving Assistace''. The geographic location for a query was especially selected to yield a ranking with 3 female candidates among the top 10, with most of them appearing in the bottom 5, which may be a motivating condition for a fairness intervention. Candidates' gender was manually labelled by creators based on pronoun usage and profile pictures. For each profile, the authors extracted information on job suitability, including TaskRabbit relevance scores, number of completed tasks and positive reviews" ;
    dcterms:isReferencedBy "\\citet{suhr2021does}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Technische Universität Berlin; Harvard University"^^xsd:string ;
    dcterms:title "TaskRabbit" ;
    dcterms:type "query-worker pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "3 rankings (one per query) of 10 workers" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:220 .

fdo:ToyDataset1 a dcat:Dataset ;
    dcterms:creator "Max Planck Institute for Software Systems"^^xsd:string ;
    dcterms:description "this dataset consists of $\\sim4$K points generated as follows. Binary class labels $y$ are generated at random for each point. Next, two-dimensional features $x$ are assigned to each point, sampling from gaussian distributions whose mean and variance depend on $y$, so that $p(x|y=1) = \\mathcal{N}([2; 2], [5, 1; 1, 5])$;  $p(x|y=-1) = \\mathcal{N}([-2; -2], [10, 1; 1, 3])$. Finally, each point's sensitive attribute $z$ is sampled from a Bernoulli distribution so that $p(z = 1) = p(x'|y = 1)/(p(x'|y = 1) + p(x'|y = 1))$, where $x'$ is a rotated version of $x$: $x' = [\\text{cos}(\\phi),  -\\text{sin}(\\phi); \\text{sin}(\\phi), \\text{cos}(\\phi)]x$. Parameter $\\phi$ controls the correlation between class label $y$ and sensitive attribute $z$" ;
    dcterms:isReferencedBy "\\citet{zafar2017fairness}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Max Planck Institute for Software Systems"^^xsd:string ;
    dcterms:title "Toy Dataset 1" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#N/A> ;
    fdo:sampleSize "4K points" ;
    fdo:sensitiveFeature "N/A" ;
    fdo:task fdo:205 ;
    dcat:landingPage "https://github.com/mbilalzafar/fair-classification/tree/master/disparate_impact/synthetic_data_demo"^^xsd:anyURI .

fdo:ToyDataset2 a dcat:Dataset ;
    dcterms:creator "Cornell University"^^xsd:string ;
    dcterms:description "this dataset contains synthetic relevance judgements over pairs of queries and documents that are biased against a minority group. For each query, there are 10 candidate documents, 8 from group $G_0$ and 2 from minority group $G_1$. Each document is associated with a feature vector $(x_1, x_2)$, with both components sampled uniformly at random from the interval $(0,3)$. The relevance of documents is set to $y=x_1+x_2$ and clipped between 0 and 5. Feature $x_2$ is then corrupted and replaced by zero for group $G_1$, leading to a biased representation between groups, such that any use of $x_2$ should lead to unfair rankings" ;
    dcterms:isReferencedBy "\\citet{singh2019policy}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "Cornell University"^^xsd:string ;
    dcterms:title "Toy Dataset 2" ;
    dcterms:type "query-document pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#N/A> ;
    fdo:sampleSize "1K relevance judgements overs  100 queries with 10 candidate documents" ;
    fdo:sensitiveFeature "N/A" ;
    fdo:task fdo:206 ;
    dcat:landingPage "https://github.com/ashudeep/Fair-PGRank"^^xsd:anyURI .

fdo:ToyDataset3 a dcat:Dataset ;
    dcterms:creator "Carnegie Mellon University; University of California, San Diego"^^xsd:string ;
    dcterms:description """this dataset was created to demonstrate undesirable properties of a family of fair classification approaches. Each instance in the dataset is associated with a sensitive attribute $z$, a target variable $y$ encoding employability, one feature that is important for the problem at hand and correlated with $z$ (work\\_experience) and a second feature which is unimportant yet also correlated with $z$ (hair\\_length). The data generating process is the following:
    
    \\begin{align*}
     z_i &\\sim \\text{Bernoulli}(0.5) \\nonumber \\\\
    \\text{hair\\_length}_i| z_i = 1 &\\sim  35 \\cdot \\text{Beta}(2, 2) \\nonumber \\\\
    \\text{hair\\_length}_i| z_i = 0 &\\sim  35 \\cdot \\text{Beta}(2, 7) \\nonumber \\\\
    \\text{work\\_exp}_i| z_i  &\\sim \\text{Poisson}(25 + 6z_i) - \\text{Normal}(20,0.2) \\nonumber \\\\
    y_i| \\text{work\\_exp}_i  &\\sim 2 \\cdot \\text{Bernoulli}(p_i) - 1, \\nonumber \\\\
    \\text{where} p_i &= 1/ (1 + \\text{exp}[-(-25.5 + 2.5\\text{work\\_exp})]) \\nonumber \\\\
    \\end{align*}""" ;
    dcterms:isReferencedBy "\\citet{lipton2018does}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Carnegie Mellon University; University of California, San Diego"^^xsd:string ;
    dcterms:title "Toy Dataset 3" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#N/A> ;
    fdo:sampleSize "2K points" ;
    fdo:sensitiveFeature "N/A" ;
    fdo:task fdo:207 .

fdo:ToyDataset4 a dcat:Dataset ;
    dcterms:creator "Istituto Italiano di Tecnologia; University of Genoa; University of Waterloo; University College London"^^xsd:string ;
    dcterms:description """in this toy example, features are generated according to four 2-dimensional isotropic Gaussian distributions with different mean $\\mu$ and variance $\\sigma^2$. Each of the four distributions corresponds to a different combination of binary label $y$ and protected attribute $s$ as follows: 
    (1) $s=a, y=+1: \\mu=(-1,-1), \\sigma^2=0.8$;
    (2) $s=a, y=-1: \\mu=(1,1), \\sigma^2=0.8$; 
    (3) $s=b; y=+1: \\mu=(0.5,-0.5), \\sigma^2=0.5$; 
    (4) $s=b, y=-1: \\mu=(0.5,0.5), \\sigma^2=0.5$""" ;
    dcterms:isReferencedBy "\\citet{donini2018empirical}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Istituto Italiano di Tecnologia; University of Genoa; University of Waterloo; University College London"^^xsd:string ;
    dcterms:title "Toy Dataset 4" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#N/A> ;
    fdo:sampleSize "6K points" ;
    fdo:sensitiveFeature "N/A" ;
    fdo:task fdo:208 ;
    dcat:landingPage "https://github.com/jmikko/fair_ERM"^^xsd:anyURI .

fdo:TwitchSocialNetworks a dcat:Dataset ;
    dcterms:creator "University of Edinburgh"^^xsd:string ;
    dcterms:description "this dataset was developed to study the effectiveness of node embeddings for learning tasks defined on graphs. This resource concentrates on Twitch content creators streaming in 6 different languages. The dataset has users as nodes, mutual friendships as edges, and node embedddings summarizing  games liked, location and streaming habits. The original task on this dataset is predicting whether a streamer uses explicit language" ;
    dcterms:isReferencedBy "\\citet{rozemberczki2021multi}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "University of Edinburgh"^^xsd:string ;
    dcterms:title "Twitch Social Networks" ;
    dcterms:type "user-user pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialnetworks ;
    fdo:sampleSize "30K nodes (users) connected by 400K edges (mutual friendship)" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:101 ;
    dcat:landingPage "http://snap.stanford.edu/data/twitch-social-networks.html"^^xsd:anyURI .

fdo:TwitterAAE a dcat:Dataset ;
    dcterms:creator "University of Massachusetts Amherst"^^xsd:string ;
    dcterms:description "this resource was developed to study the use of dialect language on social media. The authors used Twitter APIs to collect public tweets sent on mobile phones from US users in 2013. They devise a distant supervision approach based on geolocation to annotate the probable language/dialect of the tweet, distinguishing between African American English (AAE) and Standard American English (SAE). To validate their approach, the creators studied the phonological and syntactic divergence of AAE tweets vs. SAE tweets, ensuring they align with linguistic phenomena that typically distinguish these variants of English" ;
    dcterms:isReferencedBy "\\citet{blodgett2016demographic}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "University of Massachusetts Amherst"^^xsd:string ;
    dcterms:title "TwitterAAE" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#socialmedia,linguistics> ;
    fdo:sampleSize "8M tweets" ;
    fdo:sensitiveFeature "dialect (related to race)" ;
    fdo:task fdo:35 ;
    dcat:landingPage "http://slanglab.cs.umass.edu/TwitterAAE/"^^xsd:anyURI .

fdo:TwitterAbusiveBehavior a dcat:Dataset ;
    dcterms:creator "Aristotle University of Thessaloniki; Cyprus University of Technology; Telefonica; University of Alabama at Birmingham; University College London"^^xsd:string ;
    dcterms:description "this dataset is the result of an eight-month crowdsourced study of various forms of abusive behavior on Twitter. The authors began by considering a wide variety of inappropriate speech categories, analyzing how they are used by amateur annotators hired on CrowdFlower. After two exploratory rounds, they merged some labels and eliminated others, converging to a final four-class categorization into (normal, spam, abusive, hateful), requiring five crowdsourced judgements per tweet. Tweets were sampled according to a boosted random sampling technique. A large part of the dataset is randomly sampled, with the addition of tweets that are likely to belong to one or more of the minority (non-normal) classes. The dataset is available as a table mapping tweet IDs to behavior category, making it possible to identify Twitter users in this dataset" ;
    dcterms:isReferencedBy "\\citet{founta2018large}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Aristotle University of Thessaloniki; Cyprus University of Technology; Telefonica; University of Alabama at Birmingham; University College London"^^xsd:string ;
    dcterms:title "Twitter Abusive Behavior" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "100K tweets" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:31 ;
    dcat:landingPage "https://github.com/ENCASEH2020/hatespeech-twitter"^^xsd:anyURI .

fdo:TwitterHateSpeechDetection a dcat:Dataset ;
    dcterms:creator "University of Copenhagen"^^xsd:string ;
    dcterms:description "this dataset was developed to study the problem of automated hate speech detection. The creators used the Twitter API to search for tweets containing racist and sexist terms and hashtags. The annotation was carried out by the authors, with an external review by a 25-year-old woman studying gender studies. After identifying a list of eleven criteria to identify hate speech against a minority, each tweet was labelled as sexism, racism or none. The task associated with this resource is hate speech detection. The dataset is available as a table mapping tweet IDs to hate speech category, making it possible to identify Twitter users in this dataset" ;
    dcterms:isReferencedBy "\\citet{waseem2016hateful}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "University of Copenhagen"^^xsd:string ;
    dcterms:title "Twitter Hate Speech Detection" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "20K tweets" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:33 .

fdo:TwitterOffensiveLanguage a dcat:Dataset ;
    dcterms:creator "Cornell University; Qatar Computing Research Institute"^^xsd:string ;
    dcterms:description "this dataset was developed to study the problem of automated hate speech detection, and to distinguish between hate speech and other kinds of offensive language. The creators used the Twitter API to search for tweets containing terms from a hate speech lexicon compiled by \\emph{Hatebase.org}. Workers on CrowdFlower annotated a random subset of these tweets as hate speech, offensive but not hate speech, or neither offensive nor hate speech. Workers were explicitly told that the mere presence of a slur word does not amount to hate speech. Three of more workers annotated each tweet" ;
    dcterms:isReferencedBy "\\citet{davidson2017automated}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Cornell University; Qatar Computing Research Institute"^^xsd:string ;
    dcterms:title "Twitter Offensive Language" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "20K tweets" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:32 ;
    dcat:landingPage "https://github.com/t-davidson/hate-speech-and-offensive-language/tree/master/data"^^xsd:anyURI .

fdo:TwitterOnlineHarrassment a dcat:Dataset ;
    dcterms:creator "University of Maryland"^^xsd:string ;
    dcterms:description "this dataset was developed as multidisciplinary resource to study online harrassment. The authors searched a stream of tweets for keywords likely to denote violent, offensive, threatening or hateful content based on race, gender, religion and sexual orientation. They developed coding guidelines to label a tweet as harrassing or non/harrassing and spent three weeks reviewing and refining it, annotating sample tweets as a group, and discussing the results. The curators are not publicly sharing the dataset due to Twitter terms of service restrictions and privacy concerns about individuals whose tweets are included; researchers can request access" ;
    dcterms:isReferencedBy "\\citet{golbeck2017large}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "University of Maryland"^^xsd:string ;
    dcterms:title "Twitter Online Harrassment" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "40K tweets" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:34 .

fdo:TwitterPoliticalSearches a dcat:Dataset ;
    dcterms:creator "Max Planck Institute for Software Systems; University of Illinois at Urbana-Champaign; Indian Institute of Engineering Science and Technology, Shibpur; Adobe Research"^^xsd:string ;
    dcterms:description "this dataset was collected to study political biases in Twitter search results, due to political leaning of tweets and biases in the Twitter ranking algorithm. The authors identified 25 popular political queries in December 2015, and collected relevant tweets during a week in which two presidential debates occurred, via the Twitter streaming API. Tweets were annotated based on users' political leaning. Users' leaning was automatically inferred from their topics of interest, via a classifier trained on representative sets of democratic and republican users. Both the accuracy of classifiers and the validity of user leaning as a proxy for tweet leaning was validated by workers recruited on Amazon Mechanical Turk" ;
    dcterms:isReferencedBy "\\citet{kulshrestha2017quantifying}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "Max Planck Institute for Software Systems; University of Illinois at Urbana-Champaign; Indian Institute of Engineering Science and Technology, Shibpur; Adobe Research"^^xsd:string ;
    dcterms:title "Twitter Political Searches" ;
    dcterms:type "query-result pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "30K search results containing 30K distinct tweets from 20K users" ;
    fdo:sensitiveFeature "political leaning" ;
    fdo:task fdo:168 .

fdo:TwitterPresidentialPolitics a dcat:Dataset ;
    dcterms:creator "Clarkson University"^^xsd:string ;
    dcterms:description "this dataset was created by collecting tweets, through the Twitter API, from 576 accounts linked to presidential candidates and members of congress, from the entire account history until December 2019. Out of all the accounts considered, 258 accounts were classified as Republican and 318 as Democratic. The dataset was collected to build a political bias subspace from word embeddings, which could be a flexible tool to quantitatively investigate political leaning in text-based media" ;
    dcterms:isReferencedBy "\\citet{gordon2020studying}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Clarkson University"^^xsd:string ;
    dcterms:title "Twitter Presidential Politics" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "1M tweets from 500 accounts" ;
    fdo:sensitiveFeature "political leaning" ;
    fdo:task fdo:154 .

fdo:TwitterTrendingTopics a dcat:Dataset ;
    dcterms:creator "Indian Institute of Technology Kharagpur; Max Planck Institute for Software Systems; Grenoble INP"^^xsd:string ;
    dcterms:description "this dataset was used to study the problem of fair recommendation. It comprises a random sample (1\\%) of all tweets posted in the US between February and July 2017, obtained  through the Twitter Streaming API. This sample is paired with a collection of trending Twitter topics queried every 15-minutes through the Twitter REST API in July 2017. User interest in each topic was inferred using Twitter lists and follower-followee graphs. Finally, user demographics were also annotated to evaluate how user interest in different topics skews with respect to race, age, and gender. These attributes were obtained feeding user profile images to Face++" ;
    dcterms:isReferencedBy "\\citet{chakraborty2019equality}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Indian Institute of Technology Kharagpur; Max Planck Institute for Software Systems; Grenoble INP"^^xsd:string ;
    dcterms:title "Twitter Trending Topics" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "200M tweets by 10M users and 10K trending topics" ;
    fdo:sensitiveFeature "race, age, and gender" ;
    fdo:task fdo:183 .

fdo:U.S.HarmonizedTariffSchedules_HTS a dcat:Dataset ;
    dcterms:creator "US International Trade Commission"^^xsd:string ;
    dcterms:description "this resource represents a comprehensive classification system for goods imported in the US, which defines the applicable tariffs. It defines a fine-grained categorization for goods, based e.g. on their material and shape. The chapter on apparel was explicitly criticized for its differential treatment of men's and women's clothing, effectively resulting in discriminatory tariffs for consumers" ;
    dcterms:isReferencedBy "\\citet{barbaro2007apparel}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "US International Trade Commission"^^xsd:string ;
    dcterms:title "U.S. Harmonized Tariff Schedules (HTS)" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "unknown" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:170 ;
    dcat:landingPage "https://hts.usitc.gov/current"^^xsd:anyURI .

fdo:USCensusData_1990 a dcat:Dataset ;
    dcterms:creator "Microsoft"^^xsd:string ;
    dcterms:description "this resource is a one percent sample extracted from the 1990 US census data as a benchmark for clustering algorithms on large datasets. It contains a variety of features about different aspects of participants' lives, including demographics, wealth, and military service" ;
    dcterms:isReferencedBy "\\citet{meek2002learning}" ;
    dcterms:issued "1999"^^xsd:gYear ;
    dcterms:modified "1999"^^xsd:gYear ;
    dcterms:publisher "Microsoft"^^xsd:string ;
    dcterms:title "US Census Data (1990)" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:demography ;
    fdo:sampleSize "2M respondents" ;
    fdo:sensitiveFeature "age, sex" ;
    fdo:task fdo:76 ;
    dcat:landingPage "https://archive.ics.uci.edu/ml/datasets/US+Census+Data+(1990)"^^xsd:anyURI .

fdo:USFamilyIncome a dcat:Dataset ;
    dcterms:creator "US Bureau of Labor Statistics; US Census Bureau"^^xsd:string ;
    dcterms:description "this resource was compiled from the Current Population Survey (CPS) Annual Social and Economic (ASEC) Supplement. It contains income data for over 80,000 thousand US families, broken down by age and race (White, Black, Asian, and Hispanic)" ;
    dcterms:isReferencedBy "\\url{https://www2.census.gov/programs-surveys/cps/techdocs/cpsmar20.pdf}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "US Bureau of Labor Statistics; US Census Bureau"^^xsd:string ;
    dcterms:title "US Family Income" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:economics ;
    fdo:sampleSize "4 races x 12 age categories x 41 income categories" ;
    fdo:sensitiveFeature "age, race" ;
    fdo:task fdo:28 ;
    dcat:landingPage "https://www.census.gov/data/tables/time-series/demo/income-poverty/cps-finc/finc-02.html"^^xsd:anyURI .

fdo:USFederalJudges a dcat:Dataset ;
    dcterms:creator "Yale University"^^xsd:string ;
    dcterms:description "this dataset was extracted from \\citet{epstein2013behavior} to study the problem of judicial subset selection from the point of view of justice, fairness and interpretability. Given the fact that in several judicial systems a subset of judges is selected from the whole judicial body to decide the outcome of appeals, the creators extract cases were three judges are required from \\citet{epstein2013behavior}, covering the period 2000--2004. They emulate prior probabilities of affirmance/reversal for specific judges based on their past decisions. The task associated with this dataset is the optimal selection of a subset of judges, so that the procedure is interpretable, the subset contains at least one female (junior) judge and the decision of the subset coincides with the decision of the whole judicial body" ;
    dcterms:isReferencedBy "\\citet{huang2020towards}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Yale University"^^xsd:string ;
    dcterms:title "US Federal Judges" ;
    dcterms:type "judge-case pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:law ;
    fdo:sampleSize "300 judges selected for 2K cases" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:3 .

fdo:USStudentPerformance a dcat:Dataset ;
    dcterms:creator "Cornell University"^^xsd:string ;
    dcterms:description "this resource represents students at an undisclosed US research university, spanning the Fall 2014 to Spring 2019 terms. The associated task is predicting student success based on university administrative records. Student features include demographics and academic information on prior achievement and standardized test scores" ;
    dcterms:isReferencedBy "\\citet{lee2020evaluation}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Cornell University"^^xsd:string ;
    dcterms:title "US Student Performance" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "unknown" ;
    fdo:sensitiveFeature "gender, racial-ethnic group" ;
    fdo:task fdo:196 .

fdo:UTKFace a dcat:Dataset ;
    dcterms:creator "University of Tennessee"^^xsd:string ;
    dcterms:description "the dataset was developed as a diverse resource for face regression and progression (models of aging), where diversity is intended with respect to age, gender and race. The creators sourced part of the images from two existing datasets (Morph and CACD datasets). To increase the representation of some age groups, additional images were crawled from major search engines based on specific keywords (e.g., baby). Age, gender, and race were estimated through an algorithm and validated by a human annotator" ;
    dcterms:isReferencedBy "\\citet{zhifei2017age}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "University of Tennessee"^^xsd:string ;
    dcterms:title "UTK Face" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "20K face images" ;
    fdo:sensitiveFeature "age, gender, race (inferred)" ;
    fdo:task fdo:21 ;
    dcat:landingPage "https://susanqq.github.io/UTKFace/"^^xsd:anyURI .

fdo:UniGe a dcat:Dataset ;
    dcterms:creator "University of Genoa"^^xsd:string ;
    dcterms:description "this dataset is connected with the \\emph{DROP@UNIGE} project, aimed at studying the dynamics of university dropout, focusing on the University of Genoa as a case study. In ML fairness literature, the most common version of the dataset focuses on students who enrolled in 2017. Students are associated with attributes describing their ethnicity, gender, financial status, and prior school experience. The target variable encodes early academic success, as summarized by students' grades at the end of the first semester" ;
    dcterms:isReferencedBy "\\citet{oneto2017dropout}" ;
    dcterms:issued "unknown"^^xsd:gYear ;
    dcterms:modified "unknown"^^xsd:gYear ;
    dcterms:publisher "University of Genoa"^^xsd:string ;
    dcterms:title "UniGe" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:education ;
    fdo:sampleSize "5K students" ;
    fdo:sensitiveFeature "ethnicity, gender, financial status" ;
    fdo:task fdo:75 .

fdo:UniversityFacebookNetworks a dcat:Dataset ;
    dcterms:creator "Facebook; University of North Carolina; Harvard University; University of Oxford"^^xsd:string ;
    dcterms:description "a collection of 100 datasets shared with researchers in anonymized format by Adam D’Angelo of Facebook. The datasets used in the fairness literature consist of a 2005 snapshot from the Facebook network of the Universities of Oklahoma (Oklahoma97), North Carolina (UNC28), Caltech (Caltech36), Reed College (Reed98), and Michigan State (Michigan23), and links between them. User data comprises gender, class year, and anonymized data fields representing high school, major, and dormitory residences" ;
    dcterms:isReferencedBy "\\citet{red2011comparing}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Facebook; University of North Carolina; Harvard University; University of Oxford"^^xsd:string ;
    dcterms:title "University Facebook Networks" ;
    dcterms:type "user-user pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialnetworks ;
    fdo:sampleSize "20K people connected by 1M friend relations (Oklahoma97); 20K people connected by 1M friend relations (UNC28); 30K people connected by 1M friend relations (Michigan23); 1K people connected by 20K friend relations (Reed98); 1K people connected by 20K friend relations (Caltech36)" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:109 ;
    dcat:landingPage "http://networkrepository.com/socfb-Oklahoma97.php"^^xsd:anyURI,
        "http://networkrepository.com/socfb-UNC28.php"^^xsd:anyURI,
        "https://networkrepository.com/socfb-Caltech36.php"^^xsd:anyURI,
        "https://networkrepository.com/socfb-Michigan23.php"^^xsd:anyURI,
        "https://networkrepository.com/socfb-Reed98.php"^^xsd:anyURI .

fdo:Vehicle a dcat:Dataset ;
    dcterms:creator "University of Wisconsin-Madison"^^xsd:string ;
    dcterms:description "this dataset comprises measurements from a distributed network of acoustic, seismic, and infrared sensors, as different types of military vehicles are driven in their proximity. This dataset was developed as part of a project supported by DARPA for the task of vehicle detection and type classification" ;
    dcterms:isReferencedBy "\\citet{duarte2004vehicle}" ;
    dcterms:issued "2013"^^xsd:gYear ;
    dcterms:modified "2013"^^xsd:gYear ;
    dcterms:publisher "University of Wisconsin-Madison"^^xsd:string ;
    dcterms:title "Vehicle" ;
    dcterms:type "time series"^^rdf:PlainLiteral ;
    fdo:domain fdo:signalprocessing ;
    fdo:sampleSize "unknown" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:115 ;
    dcat:landingPage "http://www.ecs.umass.edu/mduarte/Software.html"^^xsd:anyURI .

fdo:VictorianEraAuthorshipAttribution a dcat:Dataset ;
    dcterms:creator "Purdue University"^^xsd:string ;
    dcterms:description "this resource was developed to benchmark different authorship attribution techniques. Querying the Gdelt database, the creators focus on English language authors from the 19th century with at least five books available. The corpus was split into text fragments of 1,000 words each. Only the most frequent 10,000 words were kept, while the remaining ones were removed" ;
    dcterms:isReferencedBy "\\citet{gungor2018benchmarking}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Purdue University"^^xsd:string ;
    dcterms:title "Victorian Era Authorship Attribution" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:literature ;
    fdo:sampleSize "100K text fragments" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:189 ;
    dcat:landingPage "http://archive.ics.uci.edu/ml/datasets/Victorian+Era+Authorship+Attribution"^^xsd:anyURI .

fdo:VisualQuestionAnswering_VQA a dcat:Dataset ;
    dcterms:creator "Georgia Institute of Technology; Carnegie Mellon University; Army Research Lab;   Facebook AI Research"^^xsd:string ;
    dcterms:description "this dataset is curated as a benchmark for open-ended visual question answering. The collection features both real images from MS-COCO \\citep{lin2014microsoft} and abstract scenes with human figures. Questions and answers were compiled by workers on Mechanical Turk who were instructed to formulate questions that require seeing the associated image for a correct answer" ;
    dcterms:isReferencedBy "\\citet{goyal2017making}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Georgia Institute of Technology; Carnegie Mellon University; Army Research Lab;   Facebook AI Research"^^xsd:string ;
    dcterms:title "Visual Question Answering (VQA)" ;
    dcterms:type "mixture (image, text)"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "1M questions over 300K images" ;
    fdo:sensitiveFeature "visual and textual references to gender" ;
    fdo:task fdo:123 ;
    dcat:landingPage "https://visualqa.org/"^^xsd:anyURI .

fdo:Warfarin a dcat:Dataset ;
    dcterms:creator "PharmGKB; International Warfarin Pharmacogenetics Consortium"^^xsd:string ;
    dcterms:description "this dataset was collected as part of a study about algorithmic estimation of optimal warfarin dosage as an oral anticoagulation treatment. The study was carried out by the International Warfarin Pharmacogenetics  Consortium, comprising 21 research groups from 9 countries and 4 continents. The dataset was co-curated by staff at the Pharmacogenomics Knowledge Base (PharmGKB) including, for thousands of patients at centers around the world, their demographics, comorbities, other medications and genetic factors, along with the steady-state dose of warfarin that led to stable levels of anticoagulation without adverse events" ;
    dcterms:isReferencedBy "\\citet{international2009estimation}" ;
    dcterms:issued "2009"^^xsd:gYear ;
    dcterms:modified "2009"^^xsd:gYear ;
    dcterms:publisher "PharmGKB; International Warfarin Pharmacogenetics Consortium"^^xsd:string ;
    dcterms:title "Warfarin" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:pharmacology ;
    fdo:sampleSize "6K patients" ;
    fdo:sensitiveFeature "sex, ethnicity, age" ;
    fdo:task fdo:42 ;
    dcat:landingPage "https://www.pharmgkb.org/downloads"^^xsd:anyURI .

fdo:Waterbirds a dcat:Dataset ;
    dcterms:creator "Stanford University; Microsoft"^^xsd:string ;
    dcterms:description "this computer vision dataset consists of photos where subjects and backgrounds are carefully paired to induce spurious correlations. Subjects are birds, taken from the CUB dataset \\citep{wah2011Caltechucsd}, divided into waterbirds and landbirds. Pixel-level segmentation  masks are exploited to cut out subjects and paste them onto land or water backgrounds from the Places dataset \\citep{zhou2018:places}. While in the provided validation and test splits both landbirds and waterbirds appear with the same frequency on either background, the training split is imbalanced so that 95\\% of all waterbirds are placed against a water background and 95\\% of all landbirds are depicted against a land background" ;
    dcterms:isReferencedBy "\\citet{sagawa2020distributionally}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "Stanford University; Microsoft"^^xsd:string ;
    dcterms:title "Waterbirds" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "10K images" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:114 ;
    dcat:landingPage "https://github.com/ejones313/worst-group-sc/tree/main/src/data"^^xsd:anyURI .

fdo:WebText a dcat:Dataset ;
    dcterms:creator "OpenAI"^^xsd:string ;
    dcterms:description "this resource is a web scrape collected to train the GPT-2 language model. The authors considered all outbound links from Reddit which collected at least 3 \\emph{karma}. This inclusion criterion signals that the link received some upvotes by redditors and is treated as a quality heuristic for the webpage. To extract text data from each link, a combination of Dragnet \\citep{peters2013content} and Newspaper\\footnote{\\url{https://github.com/codelucas/newspaper}} extractors was exploited. The curators performed deduplication and removed all Wikipedia pages to reduce text overlap with Wikipedia-based datasets" ;
    dcterms:isReferencedBy "\\citet{radford2019language}" ;
    dcterms:issued "2019"^^xsd:gYear ;
    dcterms:modified "2019"^^xsd:gYear ;
    dcterms:publisher "OpenAI"^^xsd:string ;
    dcterms:title "WebText" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize " 8M documents" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:89 ;
    dcat:landingPage "https://github.com/openai/gpt-2-output-dataset"^^xsd:anyURI .

fdo:Wholesale a dcat:Dataset ;
    dcterms:creator "Université Pierre et Marie Curie; University Institute of Lisbon; INRIA"^^xsd:string ;
    dcterms:description "this dataset represents Portuguese businesses from the catering industry purchasing goods from the same wholesaler. The businesses are located in Lisbon, Oporto, and a third undisclosed area; 298 are from the Horeca (Hotel/Restaurant/Café) channel and 142 from the Retail channel. Each data point comprises this information along with yearly expenditures on different categories of products (e.g. milk, frozen goods, delicatessen). Collection of this data was presumably carried out by the wholesaler in a business intelligence initiative primarily aimed at customer segmentation and targeted marketing" ;
    dcterms:isReferencedBy "\\citet{baudry2015enhancing}" ;
    dcterms:issued "2014"^^xsd:gYear ;
    dcterms:modified "2014"^^xsd:gYear ;
    dcterms:publisher "Université Pierre et Marie Curie; University Institute of Lisbon; INRIA"^^xsd:string ;
    dcterms:title "Wholesale" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:marketing ;
    fdo:sampleSize "400 businesses" ;
    fdo:sensitiveFeature "geography" ;
    fdo:task fdo:125 ;
    dcat:landingPage "http://archive.ics.uci.edu/ml/datasets/wholesale+customers"^^xsd:anyURI .

fdo:Wikidata a dcat:Dataset ;
    dcterms:creator "Wikimedia Foundation"^^xsd:string ;
    dcterms:description "founded in 2012, Wikidata is a free, collaborative, multilingual knowledge base, maintained by editors and partly automated. It consists of items linked by properties. The most common items include humans, administrative territorial entities, architectural structures, chemical compounds, films, and scholarly articles" ;
    dcterms:isReferencedBy "\\url{https://www.wikidata.org/wiki/Wikidata:Main_Page}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Wikimedia Foundation"^^xsd:string ;
    dcterms:title "Wikidata" ;
    dcterms:type "item-property-value triples"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "90M items" ;
    fdo:sensitiveFeature "demographics of people featured in entities (age, sex, geography) and their relations" ;
    fdo:task fdo:144 ;
    dcat:landingPage "https://www.wikidata.org/wiki/Wikidata:Data_access"^^xsd:anyURI .

fdo:WikipediaToxicComments a dcat:Dataset ;
    dcterms:creator "Wikimedia foundation; Google"^^xsd:string ;
    dcterms:description "this dataset was developed as a resource to analyze discourse and personal attacks on Wikipedia talk pages, which are used by editors to discuss improvements. It is aimed at using ML for better online conversations and flag posts that are likely to make other participants leave. The data consists of Wikipedia comments labelled by 5,000 crowd-workers according to their toxicity level (toxic, severe\\_toxic) and type (obscene, threat, insult, identity\\_hate). This resource powers a public Kaggle competition" ;
    dcterms:isReferencedBy "\\url{https://www.perspectiveapi.com/research/}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Wikimedia foundation; Google"^^xsd:string ;
    dcterms:title "Wikipedia Toxic Comments" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "160K comments" ;
    fdo:sensitiveFeature "textual reference to people and their demographics" ;
    fdo:task fdo:1 ;
    dcat:landingPage "https://www.kaggle.com/c/jigsaw-toxic-comment-classification-challenge"^^xsd:anyURI .

fdo:Wikipediadumps a dcat:Dataset ;
    dcterms:creator "Wikimedia Foundation"^^xsd:string ;
    dcterms:description "Wikipedia dumps are maintained and updated regularly by the Wikimedia Foundation. Typically, they contain every article available in a language at a given time. As a large source of curated text, they have often been used by the natural language processing and computational linguistics communities to extract models of human language. We find usage of German, English, Mandarin Chinese, Spanish, Arabic, French, Farsi, Urdu, and Wolof dumps in the surveyed articles" ;
    dcterms:isReferencedBy "\\url{https://meta.wikimedia.org/wiki/Data_dumps}" ;
    dcterms:issued "present"^^xsd:gYear ;
    dcterms:modified "present"^^xsd:gYear ;
    dcterms:publisher "Wikimedia Foundation"^^xsd:string ;
    dcterms:title "Wikipedia dumps" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "6M articles (EN), 3M articles (DE) as of May 2021" ;
    fdo:sensitiveFeature "textual references to people and their demographics" ;
    fdo:task fdo:50 ;
    dcat:landingPage "https://dumps.wikimedia.org/dewiki/"^^xsd:anyURI,
        "https://dumps.wikimedia.org/enwiki/"^^xsd:anyURI .

fdo:Willingness-to-PayforVaccine a dcat:Dataset ;
    dcterms:creator "University of Gothenburg"^^xsd:string ;
    dcterms:description "this dataset resulted from a study of willingness to pay for a vaccine against tick-borne encephalitis in Sweden. Thousands of citizens from different areas of the country filled in a survey about exposure, risk perception, knowledge, and protective behavior related to ticks and tick-borne diseases, along with socioeconomic information. The central question of the survey asks how much respondents would be willing to pay for a vaccine that provides a three-year protection against tick-borne encephalitis" ;
    dcterms:isReferencedBy "\\citet{slunge2015willingness}" ;
    dcterms:issued "2015"^^xsd:gYear ;
    dcterms:modified "2015"^^xsd:gYear ;
    dcterms:publisher "University of Gothenburg"^^xsd:string ;
    dcterms:title "Willingness-to-Pay for Vaccine" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:publichealth ;
    fdo:sampleSize "2K respondents" ;
    fdo:sensitiveFeature "age, gender, geography" ;
    fdo:task fdo:177 ;
    dcat:landingPage "https://snd.gu.se/sv/catalogue/study/snd0987/1#dataset"^^xsd:anyURI .

fdo:Winobias a dcat:Dataset ;
    dcterms:creator "University of California Los Angeles;  University of Virginia; Allen Institute for Artificial Intelligence"^^xsd:string ;
    dcterms:description "similarly to Winogender, this benchmark was built to study coreference resolution and gender bias, focusing on words that relate to professions with diverse gender representation. Example: ``The physician hired the secretary because he (she) was overwhelmed with clients''. The correct pronoun resolution is clear from the syntax or semantics of the sentence and can be either stereotypical or counter-stereotypical. The accuracy of biased coreference resolution systems will vary accordingly" ;
    dcterms:isReferencedBy "\\citet{zhao2018gender}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "University of California Los Angeles;  University of Virginia; Allen Institute for Artificial Intelligence"^^xsd:string ;
    dcterms:title "Winobias" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "3K sentences" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:79 ;
    dcat:landingPage "https://github.com/uclanlp/corefBias/tree/master/WinoBias/wino"^^xsd:anyURI .

fdo:Winogender a dcat:Dataset ;
    dcterms:creator "Johns Hopkins University"^^xsd:string ;
    dcterms:description "this dataset was crafted to systematically study gender bias in systems for coreference resolution, the task of resolving whom pronouns refer to in a sentence. This resource follows the Winograd schemas, with sentence templates mentioning a profession (nurse), a participant (patient), and a pronoun referring to either one of them: ``The nurse notified the patient that her/his/their shift would be ending in an hour.'' Sentence templates have been crafted so that the pronoun resolution can be done unambiguously based on contextual information, hence unbiased systems should display similar error rates, regardless of gender concentrations in different professions. The ground truth for each sentence has been validated by workers on Mechanical Turk with accuracy over 99\\%" ;
    dcterms:isReferencedBy "\\citet{rudinger2018gender}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "Johns Hopkins University"^^xsd:string ;
    dcterms:title "Winogender" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "700 sentences" ;
    fdo:sensitiveFeature "gender" ;
    fdo:task fdo:78 ;
    fdo:variant "Winogender-NER \\citep{mishra2020assessing} is a modified version of the template appropriate for named entity recognition" ;
    dcat:landingPage "https://github.com/rudinger/winogender-schemas"^^xsd:anyURI .

fdo:WordEmbeddingAssociationTest_WEAT a dcat:Dataset ;
    dcterms:creator "Princeton University; University of Bath"^^xsd:string ;
    dcterms:description "this resource was created to audit biases in English WEs. Following the Implicit Association Test (IAT) from social psychology \\citep{greenwald1998measuring}, this dataset defines two groups of target words, relating e.g. to flowers and insects, and two groups of attribute words, relating e.g. to pleasantness and unpleasantness. The dataset can be used to measure biased associations between the target words and the attribute words represented by a set of WEs. WEAT comprises ten tests across different word categories. The most salient for the purposes of algorithmic fairness support tests of associations between race and pleasantness, age and pleasantness, gender and career (vs family), gender and propensity to math (vs arts). Race-related words are first names predominantly associated with African American or European American individuals. Gender is encoded in a similar fashion, or with intrinsically gendered words (e.g. mother)" ;
    dcterms:isReferencedBy "\\citet{caliksan2017semantics}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Princeton University; University of Bath"^^xsd:string ;
    dcterms:title "Word Embedding Association Test (WEAT)" ;
    dcterms:type "text"^^rdf:PlainLiteral ;
    fdo:domain fdo:linguistics ;
    fdo:sampleSize "10 groups of words, with 10-60 words in each group" ;
    fdo:sensitiveFeature "race, gender" ;
    fdo:task fdo:209 ;
    dcat:landingPage "https://arxiv.org/pdf/1608.07187.pdf"^^xsd:anyURI .

<http://www.fairnessdata.dei.unipd.it/ontology#Yahoo!A1SearchMarketing> a dcat:Dataset ;
    dcterms:creator "Yahoo! Labs"^^xsd:string ;
    dcterms:description "this dataset contains bids from all advertisers who participated in Yahoo! Search Marketing auctions for the top 1000 search queries from June 15, 2002, to June 14, 2003. The identities of advertisers and the queries they target are anonymized for confidentiality reasons" ;
    dcterms:isReferencedBy "" ;
    dcterms:issued "after $2003$"^^xsd:gYear ;
    dcterms:modified "after $2003$"^^xsd:gYear ;
    dcterms:publisher "Yahoo! Labs"^^xsd:string ;
    dcterms:title "Yahoo! A1 Search Marketing" ;
    dcterms:type "advertiser-keyword pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:marketing ;
    fdo:sampleSize "20M bids by 10K advertisers over 1K search queries" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:54 ;
    dcat:landingPage "https://webscope.sandbox.yahoo.com/catalog.php?datatype=a"^^xsd:anyURI .

<http://www.fairnessdata.dei.unipd.it/ontology#Yahoo!c14BLearningtoRank> a dcat:Dataset ;
    dcterms:creator "Yahoo! Labs"^^xsd:string ;
    dcterms:description "this resource consists of 2 datasets which encode the interactions of Yahoo! users with the search engine in the US and an unknown Asian country. This data is a subset of the entire training set used internally to train the ranking functions of the Yahoo! search engine. Textual features are deliberately obfuscated and the final data consists of numerical features which encode query-document pairs. Query-document pairs are assigned multigraded relevance judgements by a professional editor" ;
    dcterms:isReferencedBy "\\citet{chapelle2010yahoo}" ;
    dcterms:issued "2011"^^xsd:gYear ;
    dcterms:modified "2011"^^xsd:gYear ;
    dcterms:publisher "Yahoo! Labs"^^xsd:string ;
    dcterms:title "Yahoo! c14B Learning to Rank" ;
    dcterms:type "query-document pairs"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "40K queries, 900K documents" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:46 ;
    dcat:landingPage "https://webscope.sandbox.yahoo.com/catalog.php?datatype=c"^^xsd:anyURI .

fdo:YouTubeDialectAccuracy a dcat:Dataset ;
    dcterms:creator "University of Washington"^^xsd:string ;
    dcterms:description "this dataset was curated to audit the accuracy of YouTube's automated captioning system across two genders and five dialects of English. Eighty speakers were sampled from videos matching the query ``accent challenge $<$region$>$'' or ``accent tag $<$region$>$'', where $<$region$>$ is one of five areas selected for geographic separation and distinct local dialects: California, Georgia, New England, New Zealand and Scotland. This curation choice targets a popular internet phenomenon (called ``accent tag'', ``dialect meme'' or ``accent challenge'') consisting of videos of people from different areas presenting themselves and their linguistic background, subsequently reading a list of words designed to elicit pronounciation differences dependent on dialect. This resource focuses only on the word portion of these videos, with a ``phonetically-trained listener familiar with the dialects'' performing the annotation for word caption accuracy" ;
    dcterms:isReferencedBy "\\citet{tatman2017:gender}" ;
    dcterms:issued "2016"^^xsd:gYear ;
    dcterms:modified "2016"^^xsd:gYear ;
    dcterms:publisher "University of Washington"^^xsd:string ;
    dcterms:title "YouTube Dialect Accuracy" ;
    dcterms:type "tabular data"^^rdf:PlainLiteral ;
    fdo:domain fdo:socialmedia ;
    fdo:sampleSize "100 speakers" ;
    fdo:sensitiveFeature "gender, geography" ;
    fdo:task fdo:204 ;
    dcat:landingPage "https://github.com/rctatman/youtubeDialectAccuracy"^^xsd:anyURI .

fdo:Yownews a dcat:Dataset ;
    dcterms:creator "Carnegie Mellon University"^^xsd:string ;
    dcterms:description "this dataset was collected to support research on personalized information integration and retrieval. The data, consisting of implicit and explicit user feedback stored in interaction logs, was gathered in a user study via a special browser accessing a web-based news story filtering system. The task associated with this resource is personalized news recommendation" ;
    dcterms:isReferencedBy "\\citet{zhang2005bayesian}; \\url{https://users.soe.ucsc.edu/~yiz/piir/}" ;
    dcterms:issued "2009"^^xsd:gYear ;
    dcterms:modified "2009"^^xsd:gYear ;
    dcterms:publisher "Carnegie Mellon University"^^xsd:string ;
    dcterms:title "Yow news" ;
    dcterms:type "user-story pairs"^^rdf:PlainLiteral ;
    fdo:domain <http://www.fairnessdata.dei.unipd.it/ontology#news,informationsystems> ;
    fdo:sampleSize "10K interaction logs" ;
    fdo:sensitiveFeature "news provider" ;
    fdo:task fdo:105 ;
    dcat:landingPage "https://users.soe.ucsc.edu/~yiz/papers/data/YOWStudy/"^^xsd:anyURI .

fdo:ZillowSearches a dcat:Dataset ;
    dcterms:creator "Boston University; Zillow Group"^^xsd:string ;
    dcterms:description "this is a proprietary dataset from Zillow, a famous real estate marketplace. It consists of a random sample of over 13,000 search sessions covering more than 36,000 property listings. Each listing consists of several features, some of which are considered salient by the creators and a sensible target for fair ranking algorithms. Among these are the ownership of the house (Zillow, independent realtor, new construction listed by builders) and the availability of 3D/video tours of the property. This dataset was collected internally to study the problem of fair recommendation and ranking on Zillow data" ;
    dcterms:isReferencedBy "\\citet{chaudhari2020general}" ;
    dcterms:issued "2020"^^xsd:gYear ;
    dcterms:modified "2020"^^xsd:gYear ;
    dcterms:publisher "Boston University; Zillow Group"^^xsd:string ;
    dcterms:title "Zillow Searches" ;
    dcterms:type "unknown"^^rdf:PlainLiteral ;
    fdo:domain fdo:informationsystems ;
    fdo:sampleSize "10K search sessions featuring 40K property listings" ;
    fdo:sensitiveFeature "ownership, tour availability" ;
    fdo:task fdo:141 .

fdo:dSprites a dcat:Dataset ;
    dcterms:creator "Google"^^xsd:string ;
    dcterms:description "this dataset was assembled by researchers affiliated with Google DeepMind as an artificial benchmark for unsupervised methods aimed at learning disentangled data representations. Each image in the dataset consists of a black-and-white sprite with variable shape, scale, orientation and position. Together these are the \\emph{generative factors} underlying each image. Ideally, systems trained on this data should learn disentangled representations, such that latent image representations are clearly associated with changes in a single generative factor" ;
    dcterms:isReferencedBy "\\citet{Higgins2017betaVAELB}" ;
    dcterms:issued "2017"^^xsd:gYear ;
    dcterms:modified "2017"^^xsd:gYear ;
    dcterms:publisher "Google"^^xsd:string ;
    dcterms:title "dSprites" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "700K images" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:81 ;
    dcat:landingPage "https://github.com/deepmind/dsprites-dataset"^^xsd:anyURI .

fdo:iNaturalistDatasets a dcat:Dataset ;
    dcterms:creator "California Institute of Technology; University of Edinburgh; Google; Cornell University; iNaturalist"^^xsd:string ;
    dcterms:description "these datasets were curated as challenging real-world benchmarks for large-scale fine-grained visual classification and feature visually similar classes with large class imbalance. They consist of images of plants and animals from iNaturalist, a social network where nature enthusiasts share information and observations about biodiversity. There are four different releases of the dataset: 2017, 2018, 2019, and 2021. A subset of the images are also annotated with bounding boxes and have additional metadata such as where and when the images were captured" ;
    dcterms:isReferencedBy "\\cite{vanhorn2018inaturalist,van2021benchmarking}" ;
    dcterms:issued "2021"^^xsd:gYear ;
    dcterms:modified "2021"^^xsd:gYear ;
    dcterms:publisher "California Institute of Technology; University of Edinburgh; Google; Cornell University; iNaturalist"^^xsd:string ;
    dcterms:title "iNaturalist Datasets" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:biology ;
    fdo:sampleSize "3M images from 10K different species of plants and animals" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:94 ;
    dcat:landingPage "https://github.com/visipedia/inat_comp"^^xsd:anyURI .

fdo:shapes3D a dcat:Dataset ;
    dcterms:creator "DeepMind; Wayve"^^xsd:string ;
    dcterms:description "this dataset is an artificial benchmark for unsupervised methods aimed at learning disentangled data representations. It consists of imagesof 3D shapes in a walled environment, with variable floor colour, wall colour, object colour, scale, shape and orientation" ;
    dcterms:isReferencedBy "\\citet{kim2018disentangling}" ;
    dcterms:issued "2018"^^xsd:gYear ;
    dcterms:modified "2018"^^xsd:gYear ;
    dcterms:publisher "DeepMind; Wayve"^^xsd:string ;
    dcterms:title "shapes3D" ;
    dcterms:type "image"^^rdf:PlainLiteral ;
    fdo:domain fdo:computervision ;
    fdo:sampleSize "500K images" ;
    fdo:sensitiveFeature "none" ;
    fdo:task fdo:84 ;
    dcat:landingPage "https://github.com/deepmind/3d-shapes"^^xsd:anyURI .

